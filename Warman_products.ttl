@prefix warman: <https://nlp-tlp.org/ontology/warman/wproducts/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix manufacturer: <https://nlp-tlp.org/ontology/manufacturer/ont/> .
@prefix pfluid: <https://nlp-tlp.org/ontology/process_fluid/rdl/> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix pump: <https://nlp-tlp.org/ontology/pump/rdl/> .
@prefix pump_rule: <https://nlp-tlp.org/ontology/pump/rule/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .


<https://nlp-tlp.org/ontology/warman/wproducts/core> a owl:Ontology ;
    owl:imports <http://rds.posccaesar.org/ontology/lis14/ont/core/4.2>,
        <https://nlp-tlp.org/ontology/manufacturer/ont/core>,
        <https://nlp-tlp.org/ontology/pump/ont/core>,
        <https://nlp-tlp.org/ontology/pump/rule/core> ;
    owl:versionIRI <https://nlp-tlp.org/ontology/warman/wproducts/core/1.0.0> ;
    dcterms:title "Warman Products Ontology" ;
    dcterms:licence "Apache Licence 2.0" ;
    dcterms:contributor "https://orcid.org/0000-0002-7336-3932" ;
    dcterms:description "Examples of Warman products"@en ;
    rdfs:label "Warman Products Ontology"@en .

#################################################################
#    Annotation properties
################################################################# 

sh:class a owl:AnnotationProperty .

sh:message a owl:AnnotationProperty .

sh:path a owl:AnnotationProperty .

sh:property a owl:AnnotationProperty .

sh:qualifiedMinCount a owl:AnnotationProperty .

sh:qualifiedValueShape a owl:AnnotationProperty .



#################################################################
#    SHACL shapes
################################################################# 

warman:Warman_AH_series_Shape a owl:NamedIndividual,
        sh:NodeShape ;
    sh:class pump:CentrifugalPump ;
    sh:message "A pump in the WARMAN_AS_PUMP_series must be typed as a CentrifugalPump." ;
    sh:property [ sh:message "A pump in the WARMAN_AS_PUMP_series must have at least one assembled part that is a RadialSplitCasing." ;
            sh:path lis:hasAssembledPumpPart ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape [ sh:class pump:CasingRadialSplit ] ],
        [ sh:message "A pump in the WARMAN_AS_PUMP_series must have at least one assembled part that is a PumpShaft." ;
            sh:path lis:hasAssembledPumpPart ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape [ sh:class pump:PumpShaft ] ],
        [ sh:message "A pump in the WARMAN_AS_PUMP_series must have at least one assembled part that is a SingleStageImpeller." ;
            sh:path lis:hasAssembledPumpPart ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape [ sh:class pump:PumpImpellerSingleStage ] ],
        [ sh:message "A pump in the WARMAN_AS_PUMP_series must have at least one assembled part that is a VoluteCasing." ;
            sh:path lis:hasAssembledPumpPart ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape [ sh:class pump:PumpVoluteCasing ] ] .

sh:NodeShape a owl:Class .

