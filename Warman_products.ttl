###  https://nlp-tlp.org/ontology/warman/wproduct/Warman_AH_series
warman:Warman_AH_series rdf:type owl:Class ;
    rdfs:subClassOf pump:PumpByProductClassSeries ;
    rdfs:label "Warman AH series"@en .


###  https://nlp-tlp.org/ontology/warman/wproduct/Warman_AH_series_catalog_entry
warman:Warman_AH_series_catalog_entry rdf:type owl:Class ;
    rdfs:subClassOf pump:ProductCatalogEntry ;
    rdfs:label "Warman AH series catalog entry"@en .


###  https://nlp-tlp.org/ontology/warman/wproducts/core/Warman_8_6_FAH_model
warman:Warman_8_6_FAH_model rdf:type owl:Class ;
    rdfs:subClassOf warman:Warman_AH_series ;
    rdfs:label "Warman 8/6 FAH model"@en .



#################################################################
#    Named Individuals
#################################################################


###  https://nlp-tlp.org/ontology/warman/wproducts/Warman_AH_series
warman:Warman_AH_series
    rdf:type owl:NamedIndividual ,
             pump:PumpByProductClassSeries ;
    rdfs:label "Warman AH series"@en ;
    pump:hasProductSuitabilityClaim warman:Warman_AH_series_slurry_pumping_suitability_claim .

###  https://nlp-tlp.org/ontology/warman/wproducts/WarmanProductCatalog
warman:WarmanProductCatalog rdf:type owl:NamedIndividual , 
                                     pump:ProductCatalog ;
    rdfs:label "Warman product catalog"@en .

###  https://nlp-tlp.org/ontology/warman/wproducts/Warman_AH_series_slurry_pumping_suitability_claim
warman:Warman_AH_series_slurry_pumping_suitability_claim
    rdf:type owl:NamedIndividual ,
             pump:ProductSuitabilityClaim ;
    rdfs:label "Warman AH series slurry pumping suitability claim"@en ;
    lis:isAbout warman:Warman_AH_series ;
    pump:hasClaimSource warman:WarmanProductCatalog ;
    pump:claimsSuitableForService pump:SlurryPumpingService ;
    pump:claimsSuitableForPumpedMaterial pfluid:Slurry .



###  https://nlp-tlp.org/ontology/warman/wproducts/core/Pump_W101
warman:Pump_W101 rdf:type owl:NamedIndividual ,
                            pump:PumpByProductClass ;
    rdfs:label "Warman Pump W101"@en ;
    pump:hasPumpModelSeries warman:Warman_AH_series .



#################################################################
#    SHACL
#################################################################

###  http://www.w3.org/ns/shacl#NodeShape
sh:NodeShape rdf:type owl:Class .

###  https://nlp-tlp.org/ontology/warman/wproducts/Warman_AH_series_Shape
warman:Warman_AH_series_Shape rdf:type owl:NamedIndividual ,
                                       sh:NodeShape ;
                              sh:message "A pump in the WARMAN_AS_PUMP_series must be typed as a CentrifugalPump." ;
                              sh:property [ sh:message "A pump in the WARMAN_AS_PUMP_series must have at least one assembled part that is a RadialSplitCasing." ;
                                            sh:path lis:hasAssembledPumpPart ;
                                            sh:qualifiedMinCount 1 ;
                                            sh:qualifiedValueShape [ sh:class pump:CasingRadialSplit
                                                                   ]
                                          ] ,
                                          [ sh:message "A pump in the WARMAN_AS_PUMP_series must have at least one assembled part that is a SingleStageImpeller." ;
                                            sh:path lis:hasAssembledPumpPart ;
                                            sh:qualifiedMinCount 1 ;
                                            sh:qualifiedValueShape [ sh:class pump:PumpImpellerSingleStage
                                                                   ]
                                          ] ,
                                          [ sh:message "A pump in the WARMAN_AS_PUMP_series must have at least one assembled part that is a VoluteCasing." ;
                                            sh:path lis:hasAssembledPumpPart ;
                                            sh:qualifiedMinCount 1 ;
                                            sh:qualifiedValueShape [ sh:class pump:PumpVoluteCasing
                                                                   ]
                                          ] ,
                                          [ sh:message "A pump in the WARMAN_AS_PUMP_series must have at least one assembled part that is a PumpShaft." ;
                                            sh:path lis:hasAssembledPumpPart ;
                                            sh:qualifiedMinCount 1 ;
                                            sh:qualifiedValueShape [ sh:class pump:PumpShaft
                                                                   ]
                                          ] ;
                              sh:targetclass pump:CentrifugalPump .


