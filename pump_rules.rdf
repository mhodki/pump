    <!-- https://nlp-tlp.org/ontology/pump/rdl/hasPumpFeature -->

    <rdf:Description rdf:about="https://nlp-tlp.org/ontology/pump/rdl/hasPumpFeature">
        <rdfs:domain>
            <owl:Class>
