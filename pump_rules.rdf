    <!-- https://nlp-tlp.org/ontology/pump/rdl/DoubleSuctionImpeller -->

    <rdf:Description rdf:about="https://nlp-tlp.org/ontology/pump/rdl/DoubleSuctionImpeller">
        <owl:disjointWith rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/SingleSuctionImpeller"/>
    </rdf:Description>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/PositiveDisplacementPump -->

