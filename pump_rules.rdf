                    <rdf:Description rdf:about="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpFeature"/>
    </rdf:Description>
    


