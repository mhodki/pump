@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pump: <https://nlp-tlp.org/ontology/pump/rdl/> .
@prefix pump_ex: <https://nlp-tlp.org/ontology/pump/example/> .

lis:hasAssembledPart a owl:AnnotationProperty .

lis:hasAssembledPumpPart a owl:AnnotationProperty .

<https://nlp-tlp.org/ontology/pump/example> a owl:Ontology ;
    owl:imports <https://nlp-tlp.org/ontology/grundfos/gproducts/1.0>,
        <https://nlp-tlp.org/ontology/pump/ont/core>,
        <https://nlp-tlp.org/ontology/pump/rule/core/1.0.0>,
        <https://nlp-tlp.org/ontology/warman/wproducts/1.0> ;
    owl:versionIRI pump_ex:1.0 .

pump_ex:PumpG101 a owl:NamedIndividual ;
    pump:hasAssembledPumpPart pump_ex:PumpG101_impeller,
        pump_ex:PumpG101_volute .

pump_ex:PumpG102 a owl:NamedIndividual .

pump_ex:PumpW101 a owl:NamedIndividual,
        pump:CentrifugalPump ;
    pump:hasAssembledPumpPart pump_ex:PumpW101_casing,
        pump_ex:PumpW101_impeller,
        pump_ex:PumpW101_shaft .

pump_ex:PumpG101_impeller a owl:NamedIndividual,
        pump:PumpImpeller .

pump_ex:PumpG101_volute a owl:NamedIndividual,
        pump:PumpVoluteCasing .

pump_ex:PumpW101_casing a owl:NamedIndividual,
        pump:CasingRadialSplit,
        pump:PumpVoluteCasing .

pump_ex:PumpW101_impeller a owl:NamedIndividual,
        pump:PumpImpellerSingleStage .

pump_ex:PumpW101_shaft a owl:NamedIndividual,
        pump:PumpShaft .

