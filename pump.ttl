@prefix pump: <https://nlp-tlp.org/ontology/pump/rdl/> .
@prefix pfluid: <https://nlp-tlp.org/ontology/process_fluid/rdl/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <http://schema.org/> .

<https://nlp-tlp.org/ontology/pump/ont/core> a owl:Ontology ;
    owl:imports <http://rds.posccaesar.org/ontology/lis14/ont/core/4.2> ;
    owl:imports <https://nlp-tlp.org/ontology/process_fluid/rdl> ;
    owl:versionIRI <https://nlp-tlp.org/ontology/pump/ont/core/1.0.0> ;
    dcterms:title "Pump Ontology Reference Data Library" ;
    dcterms:licence "Apache Licence 2.0" ;
    dcterms:contributor "https://orcid.org/0000-0002-7336-3932" ;
    dcterms:description "Core classes and properties for the pump ontology"@en ;
    rdfs:label "Pump Ontology Reference Data Library"@en .

#################################################################
#    Annotation properties
################################################################# 


pump:ISO15926_ID a owl:AnnotationProperty ;
    rdfs:label "ISO 15926-4 ID"@en ;
    rdfs:comment "ISO 15926-4 unique number for this class"@en .

pump:ISO15926_URI a owl:AnnotationProperty ;
    rdfs:label "ISO 15926-4 URI"@en ;
    rdfs:comment "15926-4 URI for this class"@en .

pump:ISO15926_desc a owl:AnnotationProperty ;
    rdfs:label "ISO 15926-4 description"@en ;
    rdfs:comment "15926-4 description for this class"@en .

pump:ISO15926_name a owl:AnnotationProperty ;
    rdfs:label "ISO 15926-4 name"@en ;
    rdfs:comment "15926-4 name for this class"@en .  

pump:HI_ID a owl:AnnotationProperty ;
    rdfs:label "HI ID"@en ;
    rdfs:comment "Hydraulic Institute ID for this class"@en .      

schema:category a owl:AnnotationProperty ;
    rdfs:label "Category"@en .

schema:manufacturer a owl:AnnotationProperty ;
    rdfs:label "Manufacturer"@en .

schema:name a owl:AnnotationProperty ;
    rdfs:label "Name"@en .

schema:catalog a owl:AnnotationProperty ;
    rdfs:label "Catalog"@en .

schema:product_model a owl:AnnotationProperty ;
    rdfs:label "Product Model"@en ;
    skos:example "Product Model XYZ"@en .

pump:pump_product_class a owl:AnnotationProperty ;
     rdfs:label "Pump Product Class"@en ;
     skos:example "Pump Product Class ABC e.g. Warman AH slurry pump class"@en .

pump:pump_product_class_series a owl:AnnotationProperty ;
     rdfs:label "Pump Product Class Series"@en ;
     skos:example "Pump Product Class Series ABC e.g. Warman AH slurry pump series"@en .     

pump:pump_product_class_series_variant a owl:AnnotationProperty ;
     rdfs:label "Pump Product Class Series Variant"@en ;
     skos:example "Pump Product Class Series Variant XYZ e.g. Warman AH slurry pump variant 8/6 EAH"@en .


#################################################################
#    Object properties - pump parts
#################################################################   

pump:hasAssembledPumpPart a owl:ObjectProperty ;
    rdfs:subPropertyOf lis:hasAssembledPart ;
    rdfs:label "has assembled pump part"@en .

pump:hasBase a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart ;
    rdfs:label "has base"@en .

pump:hasBearing a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart ;
    rdfs:label "has bearing"@en .

pump:hasCasing a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart ;
    rdfs:label "has casing"@en .

pump:hasCasingLiner a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart ;
    rdfs:label "has casing liner"@en .

pump:hasImpeller a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart ;
    rdfs:label "has impeller"@en .

pump:hasPiston a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart ;
    rdfs:label "has piston"@en .

pump:hasPumpFeature a owl:ObjectProperty ;
    rdfs:subPropertyOf lis:hasFeature ;
    rdfs:label "has pump feature"@en .

pump:hasShaft a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart ;
    rdfs:label "has shaft"@en .

pump:hasShaftSeal a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart ;
    rdfs:label "has shaft seal"@en .

#################################################################
#    Object properties - relating to products and services
################################################################# 

pump:hasProductCatalog a owl:ObjectProperty ;
    rdfs:label "has product catalog"@en ;
     rdfs:subPropertyOf lis:representedIn ;
    rdfs:subPropertyOf lis:representedIn ;
    rdfs:domain pump:Manufacturer ;
    rdfs:range pump:ProductCatalog .

pump:hasPumpByProductClass a owl:ObjectProperty ;
    rdfs:label "has pump product class"@en ;
    rdfs:subPropertyOf lis:representedIn ;
    rdfs:domain pump:Manufacturer ;
    rdfs:range pump:PumpByProductClass .

pump:hasPumpByProductClassSeries a owl:ObjectProperty ;
    rdfs:label "has pump product class series"@en ;
    rdfs:subPropertyOf pump:hasPumpByProductClass ;
    rdfs:domain pump:Manufacturer ;     
    rdfs:range pump:PumpByProductClassSeries .

pump:hasPumpByProductClassSeriesVariant a owl:ObjectProperty ;
    rdfs:label "has pump product class series variant"@en ;
    rdfs:subPropertyOf pump:hasPumpByProductClassSeries ;
    rdfs:domain pump:Manufacturer ;     
    rdfs:range pump:PumpByProductClassSeries .    

pump:hasProductSuitabilityClaim a owl:ObjectProperty ;
    rdfs:label "has product suitability claim"@en ;
    rdfs:subPropertyOf lis:representedIn ;
    rdfs:domain pump:PumpByProductClass ;
    rdfs:range pump:ProductSuitabilityClaim . 

pump:claimsSuitableForService a owl:ObjectProperty ;
    rdfs:label "claims suitable for service"@en ;
    rdfs:domain pump:ProductSuitabilityClaim ;
    rdfs:range pump:PumpingService .

pump:claimsSuitableForPumpedMaterial a owl:ObjectProperty ;
    rdfs:label "claims suitable for pumped material"@en ;
    rdfs:domain pump:ProductSuitabilityClaim ;
    rdfs:range pfluid:FluidMaterial .    

pump:hasClaimSource a owl:ObjectProperty ;
    rdfs:label "has claim source"@en ;
    rdfs:subPropertyOf lis:representedIn ;
    rdfs:range pump:ProductCatalog .  

#################################################################
#    Pump general classes
#################################################################    

pump:Pump a owl:Class ;
    rdfs:label "Pump"@en ;
    rdfs:isDefinedBy "https://nlp-tlp.org/ontology/pump/ont/core" ;
    rdfs:subClassOf lis:PhysicalArtefact ;
    owl:disjointWith pump:PumpPart .

pump:PumpByImpellerDesign a owl:Class ;
    rdfs:label "Pump by impeller design"@en ;
    rdfs:subClassOf pump:Pump .

pump:PumpFeature a owl:Class ;
    rdfs:label "Pump feature"@en ;
    rdfs:subClassOf lis:Feature .     

pump:PumpByType a owl:Class ;
    rdfs:label "Pump by type"@en ;
    rdfs:subClassOf pump:Pump .

pump:PumpPart a owl:Class ;
    rdfs:label "Pump part"@en ;
    rdfs:subClassOf lis:PhysicalArtefact .

pump:PumpWithSpecifiedMotion a owl:Class ;
    rdfs:label "Pump with specified motion"@en ;
    rdfs:subClassOf pump:Pump .

pump:PumpWithSpecifiedStages a owl:Class ;
    rdfs:label "Pump with specified stages"@en ;
    rdfs:subClassOf pump:Pump .    

#################################################################
#    Pump type Classes
#################################################################   

pump:CentrifugalPump a owl:Class ;
    rdfs:label "Centrifugal pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute centrifugal pump terminology, with API 610 / ISO 13709 applying centrifugal pump configuration categories."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotordynamicPump ;
    skos:definition "type of rotordynamic pump in which liquid enters the impeller near the axis of rotation and is discharged primarily by centrifugal action"@en ;
    pump:ISO15926_ID "7436" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/CENTRIFUGAL_PUMP" ;
    pump:ISO15926_desc "A <CENTRIFUGAL PUMP> is an <ARTEFACT> and a <PUMP> in which centrifugal force imparted by impeller is convered to pressure in the volute casing. NOTE - Combine with either  BARE PUMP or PUMP SYSTEM," ;
    pump:ISO15926_name "CENTRIFUGAL PUMP" .

pump:CircumferentialPistonPump a owl:Class ;
    rdfs:label "Circumferential piston pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses timed circumferential pistons or rotors to form expanding and contracting cavities that transfer fluid from inlet to outlet"@en .



pump:DiaphragmPump a owl:Class ;
    rdfs:label "Diaphragm pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute reciprocating pump and diaphragm pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:ReciprocatingPump ;
    skos:definition "type of reciprocating positive displacement pump that uses the cyclic flexing of a diaphragm and check valves to draw liquid into a chamber and discharge it under pressure"@en ;
    pump:ISO15926_ID "7550" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/DIAPHRAGM_PUMP" ;
    pump:ISO15926_desc "A <DIAPHRAGM PUMP> is a <RECIPROCATING PUMP> intended to pump a liquid with a small capacity. This is done by means of thin flexible diaphragms to seal pumped fluid from leakage to atmosphere; flow rate is achieved through reciprocatory motion of the diaphragm" ;
    pump:ISO15926_name "DIAPHRAGM PUMP" .



pump:GearPump a owl:Class ;
    rdfs:label "Gear pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses meshing gears to trap liquid between gear teeth and casing and carry it from inlet to outlet"@en ;
    pump:ISO15926_ID "7691" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/GEAR_PUMP" ;
    pump:ISO15926_desc "A <GEAR PUMP> is a <ROTARY PUMP> that contains gear teeth within an casing or enclosure to transport liquid at relatively high back pressures" ;
    pump:ISO15926_name "GEAR PUMP" .



pump:HorizontalMixedFlowPump a owl:Class ;
    rdfs:label "Horizontal mixed flow pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute mixed-flow pump terminology and API 610 / ISO 13709 configuration terminology."@en ;
    rdfs:subClassOf pump:MixedFlowPump,
        pump:PumpByType ;
    skos:definition "type of rotodynamic mixed-flow pump with a horizontal shaft arrangement in which the impeller imparts both radial and axial velocity components to the liquid"@en .



pump:LobePump a owl:Class ;
    rdfs:label "Lobe pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses two or more timed lobed rotors to trap liquid in spaces between the lobes and casing and move it from inlet to outlet"@en ;
    pump:ISO15926_ID "7825" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/LOBE_PUMP" ;
    pump:ISO15926_desc "A <LOBE PUMP> is a <ROTARY PUMP> intended to carry a liquid in cavities within a chamber, between meshed and timed rotor lobe surfaces, from the inlet to the outlet." ;
    pump:ISO15926_name "LOBE PUMP" .

pump:MeteringPump a owl:Class ;
    rdfs:label "Metering pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute controlled-volume metering pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:ReciprocatingPump ;
    skos:definition "type of controlled-volume positive displacement pump designed to deliver an accurately adjustable and repeatable rate of flow"@en .

pump:MixedAxialFlow a owl:Class ;
    rdfs:label "Mixed axial flow"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute mixed-flow and axial-flow pump terminology."@en ;
    rdfs:subClassOf pump:AxialFlowPump ;
    skos:definition "type of rotodynamic pump in which the impeller produces liquid flow with both axial and radial components, with the axial component predominating"@en .

pump:PeristalticPump a owl:Class ;
    rdfs:label "Peristaltic pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute positive displacement pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotaryPDPump ;
    skos:definition "type of positive displacement pump that moves fluid by the progressive compression and release of a flexible tube or hose by rollers or shoes"@en .

pump:PistonPump a owl:Class ;
    rdfs:label "Piston pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute reciprocating pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:ReciprocatingPump ;
    skos:definition "type of reciprocating positive displacement pump operated by using the back-and-forth motion of one or more tightly sealed pistons inside a cylindrical bore to trap, move, and pressurize fluid"@en ;
    pump:ISO15926_ID "7944" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/PISTON_PUMP" ;
    pump:ISO15926_desc "A <PISTON PUMP> is a <RECIPROCATING PUMP> that contains pistons intended to reciprocate within cylinders with the valving accomplished by rotation of the pistons and cylinders relative to the ports. The cylinders may be axially or radially disposed and arranged." ;
    pump:ISO15926_name "PISTON PUMP" .



pump:PlungerPump a owl:Class ;
    rdfs:label "Plunger pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute reciprocating pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:ReciprocatingPump ;
    skos:definition "type of reciprocating positive displacement pump operated by using the back-and-forth motion of one or more plungers through packing to displace and pressurize liquid in a cylinder"@en .

pump:ProgressingCavityPump a owl:Class ;
    rdfs:label "Progressing cavity pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses an eccentrically rotating helical rotor inside a stator to form sealed cavities that progress from suction to discharge"@en .

pump:PropellerPump a owl:Class ;
    rdfs:label "Propeller pump"@en ;
    rdfs:subClassOf pump:PumpByType ;
    skos:definition "type of axial-flow rotodynamic pump that uses a propeller-shaped impeller to move liquid mainly parallel to the pump shaft"@en ;
    pump:ISO15926_ID "19720" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/PROPELLER_PUMP" ;
    pump:ISO15926_desc "A <PROPELLER PUMP> is an <ARTEFACT> and a <PUMP> that is provided with a propeller type impeller to generate relativly low head at large flows" ;
    pump:ISO15926_name "PROPELLER PUMP" .

pump:RotaryPDPump a owl:Class ;
    rdfs:label "Rotary pd pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology, with supporting ISO 15926-4 reference data item ROTARY_PUMP."@en ;
    rdfs:subClassOf pump:PositiveDisplacementPump ;
    skos:definition "type of positive displacement pump that moves liquid by the rotary motion of gears, screws, lobes, vanes, or similar elements that form moving enclosed volumes"@en .

pump:ReciprocatingPump a owl:Class ;
    rdfs:label "Reciprocating pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute reciprocating pump terminology, with supporting ISO 15926-4 reference data item RECIPROCATING_PUMP."@en ;
    rdfs:subClassOf pump:PositiveDisplacementPump ;
    skos:definition "type of positive displacement pump that moves liquid by the back-and-forth motion of a piston, plunger, or diaphragm and usually uses inlet and discharge check valves"@en ;
    pump:ISO15926_ID "8023" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/RECIPROCATING_PUMP" ;
    pump:ISO15926_desc "A <RECIPROCATING PUMP> is a <POSITIVE DISPLACEMENT PUMP> which contains a displacing element intended to be moved in a reciprocating movement to exert pressure on a fluid, typically moving within a cylindrical space." ;
    pump:ISO15926_name "RECIPROCATING PUMP" .

pump:ScrewPump a owl:Class ;
    rdfs:label "Screw pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses one or more screws to move liquid axially through enclosed cavities from suction to discharge"@en ;
    pump:ISO15926_ID "8059" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/SCREW_PUMP" ;
    pump:ISO15926_desc "A <SCREW PUMP> is a <ROTARY PUMP> that contains one or more meshing screws within a casing to form liquid cavities that are transported axially from suction to discharge." ;
    pump:ISO15926_name "SCREW PUMP" .

pump:SubmersiblePump a owl:Class ;
    rdfs:label "Submersible pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType ;
    skos:definition "type of rotodynamic pump designed to be submerged in the fluid it pumps"@en ;
    pump:ISO15926_ID "8212" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/SUBMERSIBLE_PUMP" ;
    pump:ISO15926_desc "A <SUBMERSIBLE PUMP> is an <ARTEFACT> and a <PUMP> that is capable of operating when submerged in the liquid it is intended to pump." ;
    pump:ISO15926_name "SUBMERSIBLE PUMP" .

pump:VanePump a owl:Class ;
    rdfs:label "Vane pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses sliding or flexible vanes in a rotor to form variable-volume chambers that draw in and discharge liquid"@en .

pump:VerticalAxialFlow a owl:Class ;
    rdfs:label "Vertical axial flow"@en ;
    rdfs:subClassOf pump:AxialFlowPump ;
    skos:definition "type of axial-flow rotodynamic pump with a vertical shaft arrangement in which the impeller moves liquid mainly parallel to the pump shaft"@en .

pump:VerticalMixedFlowPump a owl:Class ;
    rdfs:label "Vertical mixed flow pump"@en ;
    rdfs:subClassOf pump:MixedFlowPump ;
    skos:definition "type of rotodynamic mixed-flow pump with a vertical shaft arrangement in which the impeller imparts both radial and axial velocity components to the liquid"@en .


pump:AxialFlowPump a owl:Class ;
    rdfs:label "Axial flow pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute axial-flow pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotordynamicPump ;
    skos:definition "type of rotodynamic pump in which the impeller causes liquid to flow mainly parallel to the pump shaft"@en ;
    pump:ISO15926_ID "7320" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/AXIAL_FLOW_PUMP" ;
    pump:ISO15926_desc "An <AXIAL FLOW PUMP> is a <CENTRIFUGAL PUMP> that is provided with an axial flow impeller to generate relatively low head at large flows" ;
    pump:ISO15926_name "AXIAL FLOW PUMP" .

pump:MixedFlowPump a owl:Class ;
    rdfs:label "Mixed flow pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute mixed-flow pump terminology."@en ;
    rdfs:subClassOf pump:PumpByType,
        pump:RotordynamicPump ;
    skos:definition "type of rotodynamic pump in which the impeller causes liquid to flow with both radial and axial velocity components"@en ;
    pump:ISO15926_ID "7868" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/MIXED_FLOW_PUMP" ;
    pump:ISO15926_desc "A <MIXED FLOW PUMP> is a <CENTRIFUGAL PUMP> that uses a mixed flow pump impeller." ;
    pump:ISO15926_name "MIXED FLOW PUMP" .

pump:PositiveDisplacementPump a owl:Class ;
    rdfs:label "Positive displacement pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute pump type terminology for positive displacement pumps, with supporting ISO 15926-4 reference data categories for rotary and reciprocating pumps."@en ;
    rdfs:subClassOf pump:PumpWithSpecifiedMotion ;
    skos:definition "type of pump that displaces a fixed volume of liquid by periodically enclosing it and forcing it from suction to discharge"@en ;
    pump:ISO15926_ID "7967" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/POSITIVE_DISPLACEMENT_PUMP" ;
    pump:ISO15926_desc "A <POSITIVE DISPLACEMENT PUMP> is an <ARTEFACT> and a <PUMP> intended to transport liquid through the reciprocating or rotary displacement principle and with either fixed or adjustable volume flow rates. NOTE - Combine with either BARE PUMP or PUMP SYSTEM," ;
    pump:ISO15926_name "POSITIVE DISPLACEMENT PUMP" .


#################################################################
#    Pump with specific motion
#################################################################       
pump:RotordynamicPump a owl:Class ;
    rdfs:label "Rotordynamic pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotodynamic pump definitions and terminology."@en ;
    rdfs:subClassOf pump:PumpWithSpecifiedMotion ;
    skos:definition "type of pump in which a rotating impeller or rotor continuously imparts kinetic energy to liquid and converts that energy into pressure or head"@en .

pump:PumpWithDoubleActingStroke a owl:Class ;
    rdfs:label "Pump with double acting stroke"@en ;
    rdfs:subClassOf pump:ReciprocatingPump .

pump:PumpWithDuplexDoubleCylinder a owl:Class ;
    rdfs:label "Pump with duplex double cylinder"@en ;
    rdfs:subClassOf pump:ReciprocatingPump .

pump:PumpWithSimplexSingleCylinder a owl:Class ;
    rdfs:label "Pump with simplex single cylinder"@en ;
    rdfs:subClassOf pump:ReciprocatingPump .

pump:PumpWithSingleActingStroke a owl:Class ;
    rdfs:label "Pump with simplex acting stroke" ;
    rdfs:subClassOf pump:ReciprocatingPump .

pump:PumpWithTriplexTripleCylinder a owl:Class ;
    rdfs:label "Pump with triplex triple cylinder"@en ;
    rdfs:subClassOf pump:ReciprocatingPump .



#################################################################
#    Pump with specific stages
#################################################################   
pump:PumpWithSingleStage a owl:Class ;
    rdfs:label "Pump with single stage"@en ;
    rdfs:subClassOf pump:PumpWithSpecifiedStages .

pump:PumpWithMultiStage a owl:Class ;
    rdfs:label "Pump with multi stage"@en ;
    rdfs:subClassOf pump:PumpWithSpecifiedStages .

#################################################################
#    Pump impeller design classes
#################################################################   

pump:AxialFlowImpeller a owl:Class ;
    rdfs:label "Axial flow impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign .

pump:ClosedImpeller a owl:Class ;
    rdfs:label "Closed impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign .    

pump:DoubleSuctionImpeller a owl:Class ;
    rdfs:label "Double suction impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign .    

pump:InducedVortexImpeller a owl:Class ;
    rdfs:label "Induced vortex impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign .  

pump:MixedFlowImpeller a owl:Class ;
    rdfs:label "Mixed flow impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign .

pump:OpenImpeller a owl:Class ;
    rdfs:label "Open impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign .

pump:PlainVaneImpeller a owl:Class ;
    rdfs:label "Plain vane impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign . 

pump:ScrewVaneImpeller a owl:Class ;
    rdfs:label "Screw vane impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign .

pump:SemiOpenImpeller a owl:Class ;
    rdfs:label "Semi open impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign .

pump:SingleSuctionImpeller a owl:Class ;
    rdfs:label "Single suction impeller"@en ;
    rdfs:subClassOf pump:PumpByImpellerDesign .
   

