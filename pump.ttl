<https://nlp-tlp.org/ontology/pump/rdl/PumpShaftSealExpeller> a owl:Class ;
    rdfs:subClassOf pump:PumpShaftSeal .

<https://nlp-tlp.org/ontology/pump/rdl/PumpShaftSealGland> a owl:Class ;
    rdfs:subClassOf pump:PumpShaftSeal .

<https://nlp-tlp.org/ontology/pump/rdl/PumpShaftSealMechanical> a owl:Class ;
    rdfs:subClassOf pump:PumpShaftSeal .

<https://nlp-tlp.org/ontology/pump/rdl/PumpShaftSealOilChamber> a owl:Class ;
    rdfs:label "Pump shaft sleeve oil chamber"@en ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpShaftSleeve> a owl:Class ;
    rdfs:label "Pump shaft sleeve"@en ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpShaftVerticalOrientation> a owl:Class ;
    rdfs:subClassOf pump:PumpShaft .

<https://nlp-tlp.org/ontology/pump/rdl/PumpShaftVerticalSuspendedDesign> a owl:Class ;
