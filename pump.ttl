    rdfs:label "Pump with duplex double cylinder"@en ;
    rdfs:subClassOf pump:ReciprocatingPump .

<https://nlp-tlp.org/ontology/pump/rdl/PumpWithMultiStage> a owl:Class ;
    rdfs:label "Pump with multi stage"@en ;
    rdfs:subClassOf pump:PumpWithSpecifiedStages .

<https://nlp-tlp.org/ontology/pump/rdl/PumpWithSimplexSingleCylinder> a owl:Class ;
    rdfs:label "Pump with simplex single cylinder"@en ;
    rdfs:subClassOf pump:ReciprocatingPump .

<https://nlp-tlp.org/ontology/pump/rdl/PumpWithSingleActingStroke> a owl:Class ;
    rdfs:label "Pump with simplex acting stroke" ;
    rdfs:subClassOf pump:ReciprocatingPump .

<https://nlp-tlp.org/ontology/pump/rdl/PumpWithSingleStage> a owl:Class ;
    rdfs:label "Pump with single stage"@en ;
    rdfs:subClassOf pump:PumpWithSpecifiedStages .

<https://nlp-tlp.org/ontology/pump/rdl/PumpWithTriplexTripleCylinder> a owl:Class ;
    rdfs:label "Pump with triplex triple cylinder"@en ;
    rdfs:subClassOf pump:ReciprocatingPump .

<https://nlp-tlp.org/ontology/pump/rdl/ScrewPump> a owl:Class ;
    rdfs:label "Screw pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses one or more screws to move liquid axially through enclosed cavities from suction to discharge"@en ;
    pump:ISO15926_ID "8059" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/SCREW_PUMP" ;
    pump:ISO15926_desc "A <SCREW PUMP> is a <ROTARY PUMP> that contains one or more meshing screws within a casing to form liquid cavities that are transported axially from suction to discharge." ;
    pump:ISO15926_name "SCREW PUMP" .

<https://nlp-tlp.org/ontology/pump/rdl/ScrewVaneImpeller> a owl:Class ;
    rdfs:label "Screw vane impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/SemiOpenImpeller> a owl:Class ;
    rdfs:label "Semi open impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/SingleSuctionImpeller> a owl:Class ;
    rdfs:label "Single suction impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/SubmersiblePump> a owl:Class ;
    rdfs:label "Submersible pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpType ;
    skos:definition "type of rotodynamic pump designed to be submerged in the fluid it pumps"@en ;
    pump:ISO15926_ID "8212" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/SUBMERSIBLE_PUMP" ;
    pump:ISO15926_desc "A <SUBMERSIBLE PUMP> is an <ARTEFACT> and a <PUMP> that is capable of operating when submerged in the liquid it is intended to pump." ;
    pump:ISO15926_name "SUBMERSIBLE PUMP" .

<https://nlp-tlp.org/ontology/pump/rdl/VanePump> a owl:Class ;
    rdfs:label "Vane pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses sliding or flexible vanes in a rotor to form variable-volume chambers that draw in and discharge liquid"@en .

<https://nlp-tlp.org/ontology/pump/rdl/VerticalAxialFlow> a owl:Class ;
    rdfs:label "Vertical axial flow"@en ;
    rdfs:subClassOf pump:AxialFlowPump ;
    skos:definition "type of axial-flow rotodynamic pump with a vertical shaft arrangement in which the impeller moves liquid mainly parallel to the pump shaft"@en .

<https://nlp-tlp.org/ontology/pump/rdl/VerticalMixedFlowPump> a owl:Class ;
    rdfs:label "Vertical mixed flow pump"@en ;
    rdfs:subClassOf pump:MixedFlowPump ;
    skos:definition "type of rotodynamic mixed-flow pump with a vertical shaft arrangement in which the impeller imparts both radial and axial velocity components to the liquid"@en .

