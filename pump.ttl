@prefix pump: <https://nlp-tlp.org/ontology/pump/rdl/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://nlp-tlp.org/ontology/pump/ont/core> a owl:Ontology ;
    owl:imports <http://rds.posccaesar.org/ontology/lis14/ont/core/4.2> ;
    owl:versionIRI <https://nlp-tlp.org/ontology/pump/ont/core/1.0.0> ;
    dcterms:title "Pump Ontology Reference Data Library" ;
    dcterms:licence "Apache Licence 2.0" ;
    dcterms:contributor "https://orcid.org/0000-0002-7336-3932" ;
    dcterms:description "Core classes and properties for the pump ontology"@en ;
    rdfs:label "Pump Ontology Reference Data Library"@en .

#################################################################
#    Annotation properties
################################################################# 


<https://nlp-tlp.org/ontology/pump/rdl/ISO15926_ID> a owl:AnnotationProperty ;
    rdfs:label "ISO 15926-4 ID"@en ;
    rdfs:comment "ISO 15926-4 unique number for this class"@en .

<https://nlp-tlp.org/ontology/pump/rdl/ISO15926_URI> a owl:AnnotationProperty ;
    rdfs:label "ISO 15926-4 URI"@en ;
    rdfs:comment "15926-4 URI for this class"@en .

<https://nlp-tlp.org/ontology/pump/rdl/ISO15926_desc> a owl:AnnotationProperty ;
    rdfs:label "ISO 15926-4 description"@en ;
    rdfs:comment "15926-4 description for this class"@en .

<https://nlp-tlp.org/ontology/pump/rdl/ISO15926_name> a owl:AnnotationProperty ;
    rdfs:label "ISO 15926-4 name"@en ;
    rdfs:comment "15926-4 name for this class"@en .    


#################################################################
#    Object properties
#################################################################   

<https://nlp-tlp.org/ontology/pump/rdl/hasBase> a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/hasBearing> a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/hasCasing> a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/hasCasingLiner> a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/hasImpeller> a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/hasPiston> a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/hasPumpFeature> a owl:ObjectProperty ;
    rdfs:subPropertyOf lis:hasFeature .

<https://nlp-tlp.org/ontology/pump/rdl/hasShaft> a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/hasShaftSeal> a owl:ObjectProperty ;
    rdfs:subPropertyOf pump:hasAssembledPumpPart .


#################################################################
#    Classes
#################################################################    

<https://nlp-tlp.org/ontology/pump/rdl/AxialFlowImpeller> a owl:Class ;
    rdfs:label "Axial flow impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/BearingHousingBetweenBearingDesign> a owl:Class ;
    rdfs:subClassOf pump:PumpBearingHousing .

<https://nlp-tlp.org/ontology/pump/rdl/BearingHousingOverhungDesign> a owl:Class ;
    rdfs:subClassOf pump:PumpBearingHousing .

<https://nlp-tlp.org/ontology/pump/rdl/CasingAxialSplit> a owl:Class ;
    rdfs:label "Casing axial split"@en ;
    rdfs:subClassOf pump:PumpSplitCasing .

<https://nlp-tlp.org/ontology/pump/rdl/CasingConcentric> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingDiffuser> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingRadialSplit> a owl:Class ;
    rdfs:label "Casing radial split"@en ;
    rdfs:subClassOf pump:PumpSplitCasing .

<https://nlp-tlp.org/ontology/pump/rdl/CasingSinglePiece> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingSplitAxial> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingSplitRadial> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingVolute> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingWithBottomSuction> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingWithEndSuction> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingWithSideDischarge> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingWithSideSuction> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingWithTopDischarge> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CasingWithTopSuction> a owl:Class ;
    rdfs:subClassOf pump:PumpCasingFeature .

<https://nlp-tlp.org/ontology/pump/rdl/CentrifugalPump> a owl:Class ;
    rdfs:label "Centrifugal pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute centrifugal pump terminology, with API 610 / ISO 13709 applying centrifugal pump configuration categories."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:RotordynamicPump ;
    skos:definition "type of rotodynamic pump in which liquid enters the impeller near the axis of rotation and is discharged primarily by centrifugal action"@en ;
    pump:ISO15926_ID "7436" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/CENTRIFUGAL_PUMP" ;
    pump:ISO15926_desc "A <CENTRIFUGAL PUMP> is an <ARTEFACT> and a <PUMP> in which centrifugal force imparted by impeller is convered to pressure in the volute casing. NOTE - Combine with either  BARE PUMP or PUMP SYSTEM," ;
    pump:ISO15926_name "CENTRIFUGAL PUMP" .

<https://nlp-tlp.org/ontology/pump/rdl/CircumferentialPistonPump> a owl:Class ;
    rdfs:label "Circumferential piston pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses timed circumferential pistons or rotors to form expanding and contracting cavities that transfer fluid from inlet to outlet"@en .

<https://nlp-tlp.org/ontology/pump/rdl/ClosedImpeller> a owl:Class ;
    rdfs:label "Closed impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/DiaphragmPump> a owl:Class ;
    rdfs:label "Diaphragm pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute reciprocating pump and diaphragm pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:ReciprocatingPump ;
    skos:definition "type of reciprocating positive displacement pump that uses the cyclic flexing of a diaphragm and check valves to draw liquid into a chamber and discharge it under pressure"@en ;
    pump:ISO15926_ID "7550" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/DIAPHRAGM_PUMP" ;
    pump:ISO15926_desc "A <DIAPHRAGM PUMP> is a <RECIPROCATING PUMP> intended to pump a liquid with a small capacity. This is done by means of thin flexible diaphragms to seal pumped fluid from leakage to atmosphere; flow rate is achieved through reciprocatory motion of the diaphragm" ;
    pump:ISO15926_name "DIAPHRAGM PUMP" .

<https://nlp-tlp.org/ontology/pump/rdl/DoubleSuctionImpeller> a owl:Class ;
    rdfs:label "Double suction impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/GearPump> a owl:Class ;
    rdfs:label "Gear pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses meshing gears to trap liquid between gear teeth and casing and carry it from inlet to outlet"@en ;
    pump:ISO15926_ID "7691" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/GEAR_PUMP" ;
    pump:ISO15926_desc "A <GEAR PUMP> is a <ROTARY PUMP> that contains gear teeth within an casing or enclosure to transport liquid at relatively high back pressures" ;
    pump:ISO15926_name "GEAR PUMP" .

<https://nlp-tlp.org/ontology/pump/rdl/HI_ID> a owl:AnnotationProperty ;
    rdfs:label "HI ID"@en ;
    rdfs:comment "Hydraulic Institute ID for this class"@en .

<https://nlp-tlp.org/ontology/pump/rdl/HorizontalMixedFlowPump> a owl:Class ;
    rdfs:label "Horizontal mixed flow pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute mixed-flow pump terminology and API 610 / ISO 13709 configuration terminology."@en ;
    rdfs:subClassOf pump:MixedFlowPump,
        pump:PumpType ;
    skos:definition "type of rotodynamic mixed-flow pump with a horizontal shaft arrangement in which the impeller imparts both radial and axial velocity components to the liquid"@en .


<https://nlp-tlp.org/ontology/pump/rdl/InducedVortexImpeller> a owl:Class ;
    rdfs:label "Induced vortex impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/LobePump> a owl:Class ;
    rdfs:label "Lobe pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses two or more timed lobed rotors to trap liquid in spaces between the lobes and casing and move it from inlet to outlet"@en ;
    pump:ISO15926_ID "7825" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/LOBE_PUMP" ;
    pump:ISO15926_desc "A <LOBE PUMP> is a <ROTARY PUMP> intended to carry a liquid in cavities within a chamber, between meshed and timed rotor lobe surfaces, from the inlet to the outlet." ;
    pump:ISO15926_name "LOBE PUMP" .

<https://nlp-tlp.org/ontology/pump/rdl/MeteringPump> a owl:Class ;
    rdfs:label "Metering pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute controlled-volume metering pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:ReciprocatingPump ;
    skos:definition "type of controlled-volume positive displacement pump designed to deliver an accurately adjustable and repeatable rate of flow"@en .

<https://nlp-tlp.org/ontology/pump/rdl/MixedAxialFlow> a owl:Class ;
    rdfs:label "Mixed axial flow"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute mixed-flow and axial-flow pump terminology."@en ;
    rdfs:subClassOf pump:AxialFlowPump ;
    skos:definition "type of rotodynamic pump in which the impeller produces liquid flow with both axial and radial components, with the axial component predominating"@en .

<https://nlp-tlp.org/ontology/pump/rdl/MixedFlowImpeller> a owl:Class ;
    rdfs:label "Mixed flow impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/OpenImpeller> a owl:Class ;
    rdfs:label "Open impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/PeristalticPump> a owl:Class ;
    rdfs:label "Peristaltic pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute positive displacement pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:RotaryPDPump ;
    skos:definition "type of positive displacement pump that moves fluid by the progressive compression and release of a flexible tube or hose by rollers or shoes"@en .

<https://nlp-tlp.org/ontology/pump/rdl/PistonPump> a owl:Class ;
    rdfs:label "Piston pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute reciprocating pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:ReciprocatingPump ;
    skos:definition "type of reciprocating positive displacement pump operated by using the back-and-forth motion of one or more tightly sealed pistons inside a cylindrical bore to trap, move, and pressurize fluid"@en ;
    pump:ISO15926_ID "7944" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/PISTON_PUMP" ;
    pump:ISO15926_desc "A <PISTON PUMP> is a <RECIPROCATING PUMP> that contains pistons intended to reciprocate within cylinders with the valving accomplished by rotation of the pistons and cylinders relative to the ports. The cylinders may be axially or radially disposed and arranged." ;
    pump:ISO15926_name "PISTON PUMP" .

<https://nlp-tlp.org/ontology/pump/rdl/PlainVaneImpeller> a owl:Class ;
    rdfs:label "Plain vane impeller"@en ;
    rdfs:subClassOf pump:PumpImpellerDesign .

<https://nlp-tlp.org/ontology/pump/rdl/PlungerPump> a owl:Class ;
    rdfs:label "Plunger pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute reciprocating pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:ReciprocatingPump ;
    skos:definition "type of reciprocating positive displacement pump operated by using the back-and-forth motion of one or more plungers through packing to displace and pressurize liquid in a cylinder"@en .

<https://nlp-tlp.org/ontology/pump/rdl/ProgressingCavityPump> a owl:Class ;
    rdfs:label "Progressing cavity pump"@en ;
    rdfs:comment "Source: adapted from Hydraulic Institute rotary pump terminology."@en ;
    rdfs:subClassOf pump:PumpType,
        pump:RotaryPDPump ;
    skos:definition "type of rotary positive displacement pump that uses an eccentrically rotating helical rotor inside a stator to form sealed cavities that progress from suction to discharge"@en .

<https://nlp-tlp.org/ontology/pump/rdl/PropellerPump> a owl:Class ;
    rdfs:label "Propeller pump"@en ;
    rdfs:subClassOf pump:PumpType ;
    skos:definition "type of axial-flow rotodynamic pump that uses a propeller-shaped impeller to move liquid mainly parallel to the pump shaft"@en ;
    pump:ISO15926_ID "19720" ;
    pump:ISO15926_URI "https://standards.iso.org/iso/15926/-4/reference-data-item/PROPELLER_PUMP" ;
    pump:ISO15926_desc "A <PROPELLER PUMP> is an <ARTEFACT> and a <PUMP> that is provided with a propeller type impeller to generate relativly low head at large flows" ;
    pump:ISO15926_name "PROPELLER PUMP" .

<https://nlp-tlp.org/ontology/pump/rdl/PumpAnnularCasing> a owl:Class ;
    rdfs:label "Pump annular casing"@en ;
    rdfs:subClassOf pump:PumpCasing .

<https://nlp-tlp.org/ontology/pump/rdl/PumpBase> a owl:Class ;
    rdfs:label "Pump base" ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpBearingAssembly> a owl:Class ;
    rdfs:label "Pump bearing assembly" ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpBearingInboard> a owl:Class ;
    rdfs:label "Pump bearing inboard"@en ;
    rdfs:subClassOf pump:PumpBearing .

<https://nlp-tlp.org/ontology/pump/rdl/PumpBearingOutboard> a owl:Class ;
    rdfs:label "Pump bearing outboard"@en ;
    rdfs:subClassOf pump:PumpBearing .

<https://nlp-tlp.org/ontology/pump/rdl/PumpConcentricCasing> a owl:Class ;
    rdfs:label "Pump concentric casing"@en ;
    rdfs:subClassOf pump:PumpCasing .

<https://nlp-tlp.org/ontology/pump/rdl/PumpConnectingRod> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpCrankshaft> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpCrosshead> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpCylinder> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpDiaphragm> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpDiffuser> a owl:Class ;
    rdfs:label "Pump diffuser casing"@en ;
    rdfs:subClassOf pump:PumpCasing .

<https://nlp-tlp.org/ontology/pump/rdl/PumpDischargeBowl> a owl:Class ;
    rdfs:label "Pump discharge bowl"@en ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpDoubleVolute> a owl:Class ;
    rdfs:label "Pump double volute"@en ;
    rdfs:subClassOf pump:PumpVoluteCasing ;
    skos:definition "type of volute that  features two channels offset by 180 degrees that merge into a single discharge, equally balancing the hydraulic forces"@en .

<https://nlp-tlp.org/ontology/pump/rdl/PumpExpeller> a owl:Class ;
    rdfs:label "Pump expeller" ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpFrame> a owl:Class ;
    rdfs:label "Pump frame"@en ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpFramePlate> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpGland> a owl:Class ;
    rdfs:label "Pump gland"@en ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpGrinderSystem> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerMultiStage> a owl:Class ;
    rdfs:subClassOf pump:PumpImpeller .

<https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerSingleStage> a owl:Class ;
    rdfs:subClassOf pump:PumpImpeller .

<https://nlp-tlp.org/ontology/pump/rdl/PumpLinerElastomer> a owl:Class ;
    rdfs:subClassOf pump:PumpVoluteLiner .

<https://nlp-tlp.org/ontology/pump/rdl/PumpLinerMetal> a owl:Class ;
    rdfs:subClassOf pump:PumpVoluteLiner .

<https://nlp-tlp.org/ontology/pump/rdl/PumpMultiVolute> a owl:Class ;
    rdfs:label "Pump multi-volute"@en ;
    rdfs:subClassOf pump:PumpVoluteCasing ;
    skos:definition "type of volute for some specialized or large high-pressure pumps incorporate three, four, or more volutes around the impeller designed to further balance hydraulic forces and reduce pressure pulsations"@en .

<https://nlp-tlp.org/ontology/pump/rdl/PumpNonReturnValve> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpPacking> a owl:Class ;
    rdfs:label "Pump packing"@en ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpPiston> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpPistonRod> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpPropeller> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpPulsationDampner> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpRotorGear> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpRotorLobe> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpRotorScrew> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpShaftHorizontalOrientation> a owl:Class ;
