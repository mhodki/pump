<https://nlp-tlp.org/ontology/pump/rdl/PumpSinglePieceCasing> a owl:Class ;
    rdfs:label "Pump single piece casing"@en ;
    rdfs:subClassOf pump:PumpCasing .

<https://nlp-tlp.org/ontology/pump/rdl/PumpSingleVolute> a owl:Class ;
    rdfs:label "Pump single volute"@en ;
    rdfs:subClassOf pump:PumpVoluteCasing ;
    skos:definition "type of volute that features a single channel around the impeller and one cutwater" .

<https://nlp-tlp.org/ontology/pump/rdl/PumpSleeveShaft> a owl:Class ;
    rdfs:label "Pump sleeve shaft"@en ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpSuctionBell> a owl:Class ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpThroatbush> a owl:Class ;
    rdfs:label "Pump throatbush" ;
    rdfs:subClassOf pump:PumpPart .

<https://nlp-tlp.org/ontology/pump/rdl/PumpVortexCasing> a owl:Class ;
    rdfs:label "Pump vortex casing"@en ;
    rdfs:subClassOf pump:PumpCasing .

