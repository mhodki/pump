#################################################################
#    Named Individuals
#################################################################

###  https://nlp-tlp.org/ontology/grundfos/gproducts/GrundfosProductCatalog
grundfos:GrundfosProductCatalog rdf:type owl:NamedIndividual , 
                                     pump:ProductCatalog ;
    rdfs:label "Grundfos product catalog"@en .

###  https://nlp-tlp.org/ontology/grundfos/gproducts/Grundfos_APG_series
grundfos:Grundfos_APG_series
    rdf:type owl:NamedIndividual ,
             pump:PumpProductClassSeries ;
    rdfs:label "Grundfos APG series"@en ;
    pump:hasProductSuitabilityClaim grundfos:Grundfos_APG_series_sewage_pumping_suitability_claim .

###  https://nlp-tlp.org/ontology/grundfos/gproducts/Grundfos_APG_series_sewage_pumping_suitability_claim
grundfos:Grundfos_APG_series_sewage_pumping_suitability_claim
    rdf:type owl:NamedIndividual ,
             pump:ProductSuitabilityClaim ;
    rdfs:label "Grundfos APG series sewage pumping suitability claim"@en ;
    lis:isAbout grundfos:Grundfos_APG_series ;
    pump:hasClaimSource grundfos:GrundfosProductCatalog ;
    pump:claimsSuitableForService pump:SewagePumpingService ;
    pump:claimsSuitableForPumpedMaterial pfluid:Sewage .

###  https://nlp-tlp.org/ontology/grundfos/gproducts/Grundfos_TPE_series
grundfos:Grundfos_TPE_series
    rdf:type owl:NamedIndividual ,
             pump:PumpProductClassSeries ;
    rdfs:label "Grundfos TPE series"@en ;
    pump:hasProductSuitabilityClaim grundfos:Grundfos_TPE_series_water_pumping_suitability_claim .

###  https://nlp-tlp.org/ontology/grundfos/gproducts/Grundfos_TPE_series_water_pumping_suitability_claim
grundfos:Grundfos_TPE_series_water_pumping_suitability_claim
    rdf:type owl:NamedIndividual ,
             pump:ProductSuitabilityClaim ;
    rdfs:label "Grundfos TPE series water pumping suitability claim"@en ;
    lis:isAbout grundfos:Grundfos_TPE_series ;
    pump:hasClaimSource grundfos:GrundfosProductCatalog ;
    pump:claimsSuitableForService pump:WaterPumpingService ;
    pump:claimsSuitableForPumpedMaterial pfluid:Water .

###  https://nlp-tlp.org/ontology/grundfos/gproducts/Grundfos_NB_series
grundfos:Grundfos_NB_series
    rdf:type owl:NamedIndividual ,
             pump:PumpProductClassSeries ;
    rdfs:label "Grundfos NB series"@en ;
    pump:hasProductSuitabilityClaim grundfos:Grundfos_NB_series_catalog_entry .

###  https://nlp-tlp.org/ontology/grundfos/gproducts/Grundfos_NB_series_water_pumping_suitability_claim
grundfos:Grundfos_NB_series_water_pumping_suitability_claim
    rdf:type owl:NamedIndividual ,
             pump:ProductSuitabilityClaim ;
    rdfs:label "Grundfos NB series water pumping suitability claim"@en ;
    lis:isAbout grundfos:Grundfos_NB_series ;
    pump:hasClaimSource grundfos:GrundfosProductCatalog ;
    pump:claimsSuitableForService pump:WaterPumpingService ;
    pump:claimsSuitableForPumpedMaterial pfluid:Water .

###  https://nlp-tlp.org/ontology/grundfos/gproducts/core/Pump_G101
grundfos:Pump_G101 rdf:type owl:NamedIndividual ,
                            pump:PumpProductClass ;
    rdfs:label "Grundfos Pump G101"@en ;
    pump:hasPumpModelSeries grundfos:Grundfos_APG_series .




