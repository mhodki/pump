###  https://nlp-tlp.org/ontology/grundfos/gproduct/Grundfos_TPE_series
grundfos:Grundfos_TPE_series rdf:type owl:Class ;
    rdfs:subClassOf pump:PumpProductClassSeries ;
    rdfs:label "Grundfos TP series"@en .

###  https://nlp-tlp.org/ontology/grundfos/gproduct/Grundfos_TPE_series_catalog_entry
grundfos:Grundfos_TPE_series_catalog_entry rdf:type owl:Class ;
    rdfs:subClassOf pump:ProductCatalogEntry ;
    rdfs:label "Grundfos TPE series catalog entry"@en .   

###  https://nlp-tlp.org/ontology/grundfos/gproducts/Grundfos_TPE_25_90_2
grundfos:Grundfos_TPE_25_90_2 rdf:type owl:Class ;
    rdfs:subClassOf grundfos:Grundfos_TPE_series ;
    rdfs:label "Grundfos TPE 25-90/2 A-O-A-BQQE-DWB"@en .     

###  https://nlp-tlp.org/ontology/grundfos/gproduct/Grundfos_APG_series
grundfos:Grundfos_APG_series rdf:type owl:Class ;
    rdfs:subClassOf pump:PumpProductClassSeries ;
    rdfs:label "Grundfos APG series"@en .    

###  https://nlp-tlp.org/ontology/grundfos/gproduct/Grundfos_APG_series_catalog_entry
grundfos:Grundfos_APG_series_catalog_entry rdf:type owl:Class ;
    rdfs:subClassOf pump:ProductCatalogEntry ;
    rdfs:label "Grundfos APG series catalog entry"@en .

###  https://nlp-tlp.org/ontology/grundfos/gproducts/Grundfos_APG.50.48.3
grundfos:Grundfos_APG.50.48.3 rdf:type owl:Class ;
    rdfs:subClassOf grundfos:Grundfos_APG_series ;
    rdfs:label "Grundfos APG 50-48/3"@en . 


###  https://nlp-tlp.org/ontology/grundfos/gproduct/Grundfos_SP_series
grundfos:Grundfos_SP_series rdf:type owl:Class ;
    rdfs:subClassOf pump:PumpProductClassSeries ;
    rdfs:label "Grundfos SP series"@en .


###  https://nlp-tlp.org/ontology/grundfos/gproduct/Grundfos_NB_series
grundfos:Grundfos_NB_series rdf:type owl:Class ;
    rdfs:subClassOf pump:PumpProductClassSeries ;
    rdfs:label "Grundfos NB series"@en .

###  https://nlp-tlp.org/ontology/grundfos/gproduct/Grundfos_NB_series_catalog_entry
grundfos:Grundfos_NB_series_catalog_entry rdf:type owl:Class ;
    rdfs:subClassOf pump:ProductCatalogEntry ;
    rdfs:label "Grundfos NB series catalog entry"@en .

###  https://nlp-tlp.org/ontology/grundfos/gproducts/Grundfos_NB_50-315_344
grundfos:Grundfos_NB_50-315_344 rdf:type owl:Class ;
