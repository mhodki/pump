grundfos:Grundfos_NB_series a owl:Class ;
    rdfs:subClassOf pump:PumpProductClass .

grundfos:Grundfos_NB_series2 a owl:Class ;
    rdfs:subClassOf pump:PumpProductClass .

grundfos:Grundfos_NB_series_incorrect a owl:Class ;
    rdfs:subClassOf pump:CentrifugalPump,
        pump:PumpProductClass .

grundfos:Grundfos_SP_series a owl:Class ;
    rdfs:subClassOf pump:PumpProductClass .
