@prefix grundfos: <https://nlp-tlp.org/ontology/grundfos/gproducts/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix pfluid: <https://nlp-tlp.org/ontology/process_fluid/rdl/> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix pump: <https://nlp-tlp.org/ontology/pump/rdl/> .
@prefix pump_rule: <https://nlp-tlp.org/ontology/pump/rule/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://nlp-tlp.org/ontology/grundfos/gproducts/core> a owl:Ontology ;
    owl:imports <http://rds.posccaesar.org/ontology/lis14/ont/core/4.2>,
        <https://nlp-tlp.org/ontology/manufacturer/ont/core>,
        <https://nlp-tlp.org/ontology/pump/ont/core>,
        <https://nlp-tlp.org/ontology/pump/rule/core> ;
    owl:versionIRI <https://nlp-tlp.org/ontology/grundfos/gproducts/core/1.0.0> ;
    dcterms:title "Grundfos Products Ontology" ;
    dcterms:licence "Apache Licence 2.0" ;
    dcterms:contributor "https://orcid.org/0000-0002-7336-3932" ;
    dcterms:description "Examples of Grundfos products"@en ;
    rdfs:label "Grundfos Products Ontology"@en .

