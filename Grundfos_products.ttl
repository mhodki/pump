@prefix grundfos: <https://nlp-tlp.org/ontology/grundfos/gproducts/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pump: <https://nlp-tlp.org/ontology/pump/rdl/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://nlp-tlp.org/ontology/grundfos/gproducts> a owl:Ontology ;
    owl:imports <http://rds.posccaesar.org/ontology/lis14/ont/core/4.2>,
        <https://nlp-tlp.org/ontology/manufacturer/ont/core/1.0.0>,
        <https://nlp-tlp.org/ontology/pump/ont/core>,
        <https://nlp-tlp.org/ontology/pump/rule/core/1.0.0> ;
    owl:versionIRI grundfos:1.0 .

grundfos:Grundfos_NB_series a owl:Class ;
    rdfs:subClassOf <https://nlp-tlp.org/ontology/pump/rdl/core/PumpProductClass> .

grundfos:Grundfos_NB_series2 a owl:Class ;
    rdfs:subClassOf <https://nlp-tlp.org/ontology/pump/rdl/core/PumpProductClass> .

grundfos:Grundfos_NB_series_incorrect a owl:Class ;
    rdfs:subClassOf pump:CentrifugalPump,
        <https://nlp-tlp.org/ontology/pump/rdl/core/PumpProductClass> .

grundfos:Grundfos_SP_series a owl:Class ;
    rdfs:subClassOf <https://nlp-tlp.org/ontology/pump/rdl/core/PumpProductClass> .

