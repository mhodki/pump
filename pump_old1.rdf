        <rdfs:label xml:lang="en">Plain vane impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/PlungerPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/PlungerPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute reciprocating pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Plunger pump</rdfs:label>
        <skos:definition xml:lang="en">type of reciprocating positive displacement pump operated by using the back-and-forth motion of one or more plungers through packing to displace and pressurize liquid in a cylinder</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/Pump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/Pump">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact"/>
        <owl:disjointWith rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
        <rdfs:isDefinedBy>https://nlp-tlp.org/ontology/pump/ont</rdfs:isDefinedBy>
