    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/hasShaft -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/ont/hasShaft">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/hasShaftSeal -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/ont/hasShaftSeal">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact -->

    <owl:Class rdf:about="http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact"/>
    


    <!-- https://nlp-tlp.org/ontology/pump/example/PumpManufacturerName -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/example/PumpManufacturerName">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/InformationObject"/>
        <rdfs:label xml:lang="en">Pump manufacturer name</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/example/PumpManufacturerPumpClass -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/example/PumpManufacturerPumpClass">
        <rdfs:subClassOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/InformationObject"/>
        <rdfs:label xml:lang="en">Pump manufacturer pump class</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/example/PumpVolute -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/example/PumpVolute">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpCasing"/>
        <rdfs:label xml:lang="en">Pump volute casing</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/example/PumpWithBottomSuction -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/example/PumpWithBottomSuction">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedFeatures"/>
        <rdfs:label xml:lang="en">Pump with bottom suction</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/example/PumpWithEndSuction -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/example/PumpWithEndSuction">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedFeatures"/>
        <rdfs:label xml:lang="en">Pump with end suction</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/example/PumpWithSideDischarge -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/example/PumpWithSideDischarge">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedFeatures"/>
        <owl:disjointWith rdf:resource="https://nlp-tlp.org/ontology/pump/example/PumpWithTopDischarge"/>
        <rdfs:label xml:lang="en">Pump with side discharge</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/example/PumpWithSideSuction -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/example/PumpWithSideSuction">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedFeatures"/>
        <rdfs:label xml:lang="en">Pump with side suction</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/example/PumpWithTopDischarge -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/example/PumpWithTopDischarge">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedFeatures"/>
        <rdfs:label xml:lang="en">Pump with top discharge</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/example/PumpWithTopSuction -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/example/PumpWithTopSuction">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedFeatures"/>
        <rdfs:label xml:lang="en">Pump with top suction</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/AxialFlowPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/AxialFlowPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/ont/RotordynamicPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute axial-flow pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Axial flow pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic pump in which the impeller causes liquid to flow mainly parallel to the pump shaft</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/CircumferentialPistonPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/CircumferentialPistonPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Circumferential piston pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses timed circumferential pistons or rotors to form expanding and contracting cavities that transfer fluid from inlet to outlet</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/DiaphragmPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/DiaphragmPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute reciprocating pump and diaphragm pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Diaphragm pump</rdfs:label>
        <skos:definition xml:lang="en">type of reciprocating positive displacement pump that uses the cyclic flexing of a diaphragm and check valves to draw liquid into a chamber and discharge it under pressure</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/GearPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/GearPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Gear pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses meshing gears to trap liquid between gear teeth and casing and carry it from inlet to outlet</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/HorizontalMixedFlowPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/HorizontalMixedFlowPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/ont/MixedFlowPump"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute mixed-flow pump terminology and API 610 / ISO 13709 configuration terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Horizontal mixed flow pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic mixed-flow pump with a horizontal shaft arrangement in which the impeller imparts both radial and axial velocity components to the liquid</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/LobePump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/LobePump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Lobe pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses two or more timed lobed rotors to trap liquid in spaces between the lobes and casing and move it from inlet to outlet</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/MeteringPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/MeteringPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute controlled-volume metering pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Metering pump</rdfs:label>
        <skos:definition xml:lang="en">type of controlled-volume positive displacement pump designed to deliver an accurately adjustable and repeatable rate of flow</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/MixedAxialFlow -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/MixedAxialFlow">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/ont/AxialFlowPump"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute mixed-flow and axial-flow pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Mixed axial flow</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic pump in which the impeller produces liquid flow with both axial and radial components, with the axial component predominating</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/MixedFlowPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/MixedFlowPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/ont/RotordynamicPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute mixed-flow pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Mixed flow pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic pump in which the impeller causes liquid to flow with both radial and axial velocity components</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PeristalticPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PeristalticPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute positive displacement pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Peristaltic pump</rdfs:label>
        <skos:definition xml:lang="en">type of positive displacement pump that moves fluid by the progressive compression and release of a flexible tube or hose by rollers or shoes</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PistonPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PistonPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute reciprocating pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Piston pump</rdfs:label>
        <skos:definition xml:lang="en">type of reciprocating positive displacement pump operated by using the back-and-forth motion of one or more tightly sealed pistons inside a cylindrical bore to trap, move, and pressurize fluid</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PositiveDisplacementPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PositiveDisplacementPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedMotion"/>
        <owl:disjointWith rdf:resource="https://nlp-tlp.org/ontology/pump/ont/RotordynamicPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute pump type terminology for positive displacement pumps, with supporting ISO 15926-4 reference data categories for rotary and reciprocating pumps.</rdfs:comment>
        <rdfs:label xml:lang="en">Positive displacement pump</rdfs:label>
        <skos:definition xml:lang="en">type of pump that displaces a fixed volume of liquid by periodically enclosing it and forcing it from suction to discharge</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/ProgressingCavityPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/ProgressingCavityPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Progressing cavity pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses an eccentrically rotating helical rotor inside a stator to form sealed cavities that progress from suction to discharge</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PropellerPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PropellerPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:label xml:lang="en">Propeller pump</rdfs:label>
        <skos:definition xml:lang="en">type of axial-flow rotodynamic pump that uses a propeller-shaped impeller to move liquid mainly parallel to the pump shaft</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpAnnularCasing -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpAnnularCasing">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpCasing"/>
        <rdfs:label xml:lang="en">Pump annular casing</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpBase -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpBase">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpBearing -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpBearing">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
        <rdfs:label xml:lang="en">Pump bearing</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpBearingAssembly -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpBearingAssembly">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpConnectingRod -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpConnectingRod">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpCrankshaft -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpCrankshaft">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpCrosshead -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpCrosshead">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpCylinder -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpCylinder">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpDiaphragm -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpDiaphragm">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpDiffuser -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpDiffuser">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpDoubleVolute -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpDoubleVolute">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/example/PumpVolute"/>
        <rdfs:label xml:lang="en">Pump double volute</rdfs:label>
        <skos:definition xml:lang="en">type of volute that  features two channels offset by 180 degrees that merge into a single discharge, equally balancing the hydraulic forces</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpFramePlate -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpFramePlate">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpGrinderSystem -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpGrinderSystem">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpPart"/>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/PumpMultiVolute -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/PumpMultiVolute">
