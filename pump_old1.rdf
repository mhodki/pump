    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/hasCasingLiner -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/ont/hasCasingLiner">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/hasImpeller -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/ont/hasImpeller">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/hasPiston -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/ont/hasPiston">
