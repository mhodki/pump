        <rdfs:label xml:lang="en">Pump with volute casing</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/RotordynamicPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/RotordynamicPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedMotion"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://nlp-tlp.org/ontology/pump/ont/hasCasing"/>
                <owl:someValuesFrom rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpCasing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://nlp-tlp.org/ontology/pump/ont/hasImpeller"/>
                <owl:someValuesFrom rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpeller"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://nlp-tlp.org/ontology/pump/ont/hasShaft"/>
                <owl:someValuesFrom rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpShaft"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotodynamic pump definitions and terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Rotordynamic pump</rdfs:label>
        <skos:definition xml:lang="en">type of pump in which a rotating impeller or rotor continuously imparts kinetic energy to liquid and converts that energy into pressure or head</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/ScrewPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/ScrewPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Screw pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses one or more screws to move liquid axially through enclosed cavities from suction to discharge</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/VanePump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/VanePump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Vane pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses sliding or flexible vanes in a rotor to form variable-volume chambers that draw in and discharge liquid</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/VerticalAxialFlow -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/VerticalAxialFlow">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:label xml:lang="en">Vertical axial flow</rdfs:label>
        <skos:definition xml:lang="en">type of axial-flow rotodynamic pump with a vertical shaft arrangement in which the impeller moves liquid mainly parallel to the pump shaft</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/VerticalMixedFlowPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/ont/VerticalMixedFlowPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:label xml:lang="en">Vertical mixed flow pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic mixed-flow pump with a vertical shaft arrangement in which the impeller imparts both radial and axial velocity components to the liquid</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/AxialFlowImpeller -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/AxialFlowImpeller">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerDesign"/>
        <rdfs:label xml:lang="en">Axial flow impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/CentrifugalPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/CentrifugalPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/ont/RotordynamicPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute centrifugal pump terminology, with API 610 / ISO 13709 applying centrifugal pump configuration categories.</rdfs:comment>
        <rdfs:label xml:lang="en">Centrifugal pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic pump in which liquid enters the impeller near the axis of rotation and is discharged primarily by centrifugal action</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/ClosedImpeller -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/ClosedImpeller">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerDesign"/>
        <owl:disjointWith rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/OpenImpeller"/>
        <owl:disjointWith rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/SemiOpenImpeller"/>
        <rdfs:label xml:lang="en">Closed impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/DoubleSuctionImpeller -->

