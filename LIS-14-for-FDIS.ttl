###  http://rds.posccaesar.org/ontology/lis14/rdl/qualityQuantifiedAs
lis:qualityQuantifiedAs rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf lis:representedIn ;
                        owl:inverseOf lis:quantifiesQuality ;
                        rdfs:domain lis:Quality ;
                        rdfs:range lis:QualityDatum ;
                        rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                        rdfs:label "qualityQuantifiedAs" ;
                        rdfs:seeAlso obo:IAO_0000417 ,
                                     lis:quantifiesQuality ,
                                     ssn:observedProperty ,
                                     "ISO 15926-2:2003 'property_quantification'" ;
                        skos:example "The nominal outer diameter of a pipe is 324 mm, the measured temperature of a boiler is 150 degrees Celsius, the colour of a surface is 'red'." ;
                        iof-av:naturalLanguageDefinition "If x is a 'quality quantified as' y, then x is an 'quality' that is 'represented in' the 'quality datum' y." ;
                        iof-av:usageNote "The range of 'quality quantified as' is 'quality datum', which includes data that do not follow the \"unit of measure with value\" pattern. Examples are colours and chemical composition categories." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:qualityQuantifiedAs ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:IAO_0000417 ;
   iof-av:explanatoryNote "IAO_0000417 is 'is quality measured as' of the Information Artifact Ontology. In IDO, the term \"quantified\" replaces \"measured\" to support cases where measurement is not involved, as in, e.g., estimates."
 ] .


