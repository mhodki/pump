 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/siteDeterminedBy
lis:siteDeterminedBy rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf lis:locatedRelativeTo ;
                     rdfs:domain lis:Site ;
                     rdfs:range lis:PhysicalObject ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "siteDeterminedBy" ;
                     rdfs:seeAlso lis:determinesSite ,
                                  lis:hasArrangedPart ;
                     skos:example "The interior of a ship's hold is a site determined by the hull of the ship; a room is a site determined by the walls, floor, and ceiling that enclose it." ;
                     iof-av:naturalLanguageDefinition "If x is 'site determined by' y, then x is a 'site' and y is a 'physical object' that demarcates or otherwise determines x." ;
                     iof-av:usageNote "Physical objects that demarcate sites can include aggregate or non-contiguous physical objects, as customarily modelled in IDO using the object property 'has arranged part'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/siteInsideOf
lis:siteInsideOf rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf lis:containedBy ;
                 rdfs:domain lis:Site ;
                 rdfs:range lis:PhysicalObject ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "siteInsideOf" ;
                 rdfs:seeAlso lis:determinesSite ,
                              lis:hasSiteInside ,
                              "ISO 15926-2:2003 'relative_location'" ;
                 skos:example "A compartment space is inside a cabinet; an indoor site is inside a building." ;
                 iof-av:naturalLanguageDefinition "If x 'site inside of' y, then x is a 'site', y is a 'physical object', and a part of y 'determines site' x such that the spatial extent of x is a sublocation of the spatial extent of y." ;
                 iof-av:usageNote "This relation may be used where a site represents a space defined relative to the boundaries of a physical object, such as a compartment, room, or enclosed area." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/siteOf
lis:siteOf rdf:type owl:ObjectProperty ;
           rdfs:domain lis:Site ;
           rdfs:range lis:Activity ;
           rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
           rdfs:label "siteOf" ;
           rdfs:seeAlso obo:BFO_0000067 ,
                        obo:BFO_0000183 ,
                        obo:BFO_0000217 ,
                        lis:occursIn ;
           skos:altLabel "environs" ;
           skos:example "Mixing takes place within a vessel, transport takes place in a pipeline" ;
           iof-av:naturalLanguageDefinition "If x 'site of' y, then x is a 'site', y is an 'activity', and y takes place entirely within x." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:siteOf ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000067 ;
   iof-av:explanatoryNote "BFO_0000067 is 'contains process', from RO, where an annotation says the 'editor preferred term' is \"site of\". There are subtle differences in the range and domain restrictions between BFO's 'environs' and RO's 'contains process': where RO has domain as the broad 'independent continuant' only, BFO has ('site' or 'material entity'); where RO has range as 'occurrent', BFO has ('process' or 'process boundary')."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:siteOf ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000183 ;
   iof-av:explanatoryNote "BFO_0000183 is 'environs' from BFO"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:siteOf ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000217 ;
   iof-av:explanatoryNote "BFO_0000217 is 'spatially projects onto at all times'."
 ] .


