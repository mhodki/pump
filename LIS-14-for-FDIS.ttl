#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( lis:Activity
                lis:SpatiotemporalRegion
                lis:TemporalRegion
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( lis:Dependent
                lis:Object
                lis:Temporal
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( lis:InformationObject
                lis:Location
                lis:Organization
                lis:PhysicalObject
              )
] .


