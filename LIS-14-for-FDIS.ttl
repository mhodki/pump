###  http://rds.posccaesar.org/ontology/lis14/rdl/residesIn
lis:residesIn rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf lis:containedBy ;
              rdfs:domain lis:PhysicalObject ;
              rdfs:range lis:Site ;
              rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
              rdfs:label "residesIn" ;
              rdfs:seeAlso lis:hasResident ,
                           "ISO 15926-2:2003 'relative_location'" ;
              skos:example "An engine is located in a machine room; a pressure vessel is located in an outdoors plant area." ;
              iof-av:naturalLanguageDefinition "If x 'resides in' y, then x is a 'physical object', y is a 'location', and x is located entirely within y." ;
              iof-av:usageNote "This relation may be used where an object x is located in a site y, defined in terms of boundaries of a physical object, that may change its location over time." .


