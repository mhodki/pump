###  http://rds.posccaesar.org/ontology/lis14/rdl/profileOfQuality
lis:profileOfQuality rdf:type owl:ObjectProperty ;
                     owl:inverseOf lis:qualityProfiledIn ;
                     rdfs:domain lis:ActivityProfile ;
                     rdfs:range lis:Quality ;
                     owl:propertyChainAxiom ( lis:profileQuantityDatum
                                              lis:quantifiesQuality
                                            ) ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "profileOfQuality" ;
                     rdfs:seeAlso lis:qualityProfiledIn ;
                     skos:example "A temperature activity profile of a heating process represents just that part of the process which is a variation in temperature." ;
                     skos:scopeNote "'profile of quality' should be considered a functional property (i.e., an 'activity profile' is a profile of only a single 'quality'). However, in OWL, an object property with property chain restrictions may not be combined with cardinality restrictions. Correct cardinalities must therefore be maintained with rules external to the ontology." ;
                     iof-av:naturalLanguageDefinition "x is a 'profile of quality' y if and only if x is an 'activity profile' that varies only in the 'quality' y." ;
                     iof-av:usageNote "A property chain axiom ensures that a quantity datum individual associated with an activity profile by 'profile quantity datum' quantifies a quality which defines the activity profile by 'profile of quality'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/profileQuantityDatum
lis:profileQuantityDatum rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf lis:hasParticipantQualityQuantifiedAs ;
                         owl:inverseOf lis:quantityDatumOfProfile ;
                         rdfs:domain lis:ActivityProfile ;
                         rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                         rdfs:label "profileQuantityDatum" ;
                         rdfs:seeAlso lis:quantityDatumOfProfile ;
                         skos:example "The pressure of a liquid is measured at 10, 11, and 12 bar at different points of time during a transport activity." ;
                         iof-av:naturalLanguageDefinition "If x has 'profile quantity datum' y, then x is an 'activity profile', and x 'has participant quality quantified as' y." ;
                         iof-av:usageNote "Assume y is an 'activity profile', obtained from some containing activity z by selective abstraction on a quality q of a participant in z. Then, relate y by 'profile quantity datum' to magnitudes of q that are recorded during the execution of y." ,
                                          "Intuitively, 'profile quantity datum' should only point to quantity data recorded while the activity is taking place. This can not be enforced with OWL restrictions on the relation (it would require a \"diamond\" pattern). However, with a suitable date or time data property value restriction, an individual activity can constrain related quantity data." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/qualityOf
lis:qualityOf rdf:type owl:ObjectProperty ;
              rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
              rdfs:label "qualityOf" ;
              rdfs:seeAlso lis:hasQuality ;
              iof-av:usageNote "For annotations, see the inverse relation 'has quality'." .


