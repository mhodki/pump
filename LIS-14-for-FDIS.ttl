                rdfs:isDefinedBy dcterms: ;
                rdfs:subPropertyOf dcterms:contributor .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty ;
                    rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty ;
                 rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/publisher
dcterms:publisher rdf:type owl:AnnotationProperty ;
                  rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty ;
              rdfs:isDefinedBy dcterms: .


###  http://purl.org/pav/contributedBy
pav:contributedBy rdf:type owl:AnnotationProperty ;
                  rdfs:isDefinedBy pav: ;
                  rdfs:subPropertyOf dcterms:contributor .


###  http://purl.org/pav/createdBy
pav:createdBy rdf:type owl:AnnotationProperty ;
              rdfs:isDefinedBy pav: ;
              rdfs:subPropertyOf dcterms:creator .


###  http://purl.org/pav/derivedFrom
pav:derivedFrom rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy pav: .


###  http://purl.org/pav/hasEarlierVersion
pav:hasEarlierVersion rdf:type owl:AnnotationProperty ;
                      rdfs:isDefinedBy pav: .


###  http://purl.org/pav/lastUpdateOn
pav:lastUpdateOn rdf:type owl:AnnotationProperty ;
                 rdfs:isDefinedBy pav: .


###  http://purl.org/pav/previousVersion
pav:previousVersion rdf:type owl:AnnotationProperty ;
                    rdfs:isDefinedBy pav: .


###  http://rds.posccaesar.org/ontology/lis14/rdl/mergedFrom
lis:mergedFrom rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "mergedFrom" ;
               iof-av:usageNote "This annotation property is used for stating that the current resource originates from one or several other resources by merging." ;
               rdfs:subPropertyOf lis:originatesFrom .


###  http://rds.posccaesar.org/ontology/lis14/rdl/originatesFrom
lis:originatesFrom rdf:type owl:AnnotationProperty ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "originatesFrom" ;
                   iof-av:usageNote "This is a super-property for associating a resource with a resource it originated from." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/splitFrom
lis:splitFrom rdf:type owl:AnnotationProperty ;
              rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
              rdfs:label "splitFrom" ;
              iof-av:usageNote "This annotation property is used for stating that the current resource originates from another resource by splitting." ;
              rdfs:subPropertyOf lis:originatesFrom .


###  http://rds.posccaesar.org/ontology/lis14/rdl/transformedFrom
lis:transformedFrom rdf:type owl:AnnotationProperty ;
                    rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                    rdfs:label "transformedFrom" ;
                    iof-av:usageNote "This annotation property is used for stating that the current resource originates from another resource by transformation." ;
                    rdfs:subPropertyOf lis:originatesFrom .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty ;
             rdfs:isDefinedBy rdfs: .


###  http://www.w3.org/2000/01/rdf-schema#isDefinedBy
rdfs:isDefinedBy rdf:type owl:AnnotationProperty ;
                 rdfs:isDefinedBy rdfs: ;
                 rdfs:subPropertyOf rdfs:seeAlso .


###  http://www.w3.org/2000/01/rdf-schema#label
rdfs:label rdf:type owl:AnnotationProperty ;
           rdfs:isDefinedBy rdfs: .


###  http://www.w3.org/2000/01/rdf-schema#seeAlso
rdfs:seeAlso rdf:type owl:AnnotationProperty ;
             rdfs:isDefinedBy rdfs: .


###  http://www.w3.org/2002/07/owl#versionInfo
owl:versionInfo rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty ;
              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
              iof-av:usageNote "Alternative label for the ontology resource." ;
              rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty ;
             rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty ;
          rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
               iof-av:usageNote "Preferred label for the ontology resource." ;
               rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
               iof-av:usageNote "Note to clarify meaning or use of an ontology resource." .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom
iof-av:adaptedFrom rdf:type owl:AnnotationProperty ;
                   rdfs:isDefinedBy iof-av: ;
                   rdfs:subPropertyOf dcterms:source .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/directSource
iof-av:directSource rdf:type owl:AnnotationProperty ;
                    rdfs:isDefinedBy iof-av: ;
                    rdfs:subPropertyOf dcterms:source .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote
iof-av:explanatoryNote rdf:type owl:AnnotationProperty ;
                       rdfs:isDefinedBy iof-av: .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/firstOrderLogicDefinition
iof-av:firstOrderLogicDefinition rdf:type owl:AnnotationProperty ;
                                 rdfs:isDefinedBy iof-av: ;
                                 rdfs:subPropertyOf skos:definition .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/isPrimitive
iof-av:isPrimitive rdf:type owl:AnnotationProperty ;
                   rdfs:isDefinedBy iof-av: .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition
iof-av:naturalLanguageDefinition rdf:type owl:AnnotationProperty ;
                                 rdfs:isDefinedBy iof-av: ;
                                 rdfs:subPropertyOf skos:definition .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/primitiveRationale
iof-av:primitiveRationale rdf:type owl:AnnotationProperty ;
                          rdfs:isDefinedBy iof-av: ;
                          rdfs:subPropertyOf skos:note .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/semiFormalNaturalLanguageAxiom
iof-av:semiFormalNaturalLanguageAxiom rdf:type owl:AnnotationProperty ;
                                      rdfs:isDefinedBy iof-av: ;
                                      rdfs:subPropertyOf skos:note .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/semiFormalNaturalLanguageDefinition
iof-av:semiFormalNaturalLanguageDefinition rdf:type owl:AnnotationProperty ;
                                           rdfs:isDefinedBy iof-av: ;
                                           rdfs:subPropertyOf skos:definition .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/synonym
iof-av:synonym rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy iof-av: ;
               rdfs:subPropertyOf skos:altLabel .


###  https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote
iof-av:usageNote rdf:type owl:AnnotationProperty ;
                 rdfs:isDefinedBy iof-av: .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2000/01/rdf-schema#Literal
rdfs:Literal rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#boolean
xsd:boolean rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#dateTime
xsd:dateTime rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#string
xsd:string rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://rds.posccaesar.org/ontology/lis14/rdl/activeParticipantIn
lis:activeParticipantIn rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf lis:participantIn ;
                        owl:inverseOf lis:hasActiveParticipant ;
                        rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                        rdfs:label "activeParticipantIn" ;
                        rdfs:seeAlso lis:hasActiveParticipant ;
                        iof-av:usageNote "For annotations, see the inverse relation 'has active participant'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/activityBoundOf
lis:activityBoundOf rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf lis:activityPartOf ;
                    owl:inverseOf lis:hasActivityBound ;
                    rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                    rdfs:label "activityBoundOf" ;
                    rdfs:seeAlso lis:hasActivityBound ;
                    iof-av:usageNote "For annotations, see the inverse relation 'has activity bound'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/activityPartOf
lis:activityPartOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf lis:temporalPartOf ;
                   owl:inverseOf lis:hasActivityPart ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "activityPartOf" ;
                   rdfs:seeAlso lis:hasActivityPart ;
                   iof-av:usageNote "For annotations, see the inverse relation 'has activity part'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/activityProfileOf
lis:activityProfileOf rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf lis:activityPartOf ;
                      owl:inverseOf lis:hasActivityProfile ;
                      rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                      rdfs:label "activityProfileOf" ;
                      rdfs:seeAlso lis:hasActivityProfile ;
                      iof-av:usageNote "For annotations, see the inverse relation 'has activity profile'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/after
lis:after rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf lis:occursRelativeTo ;
          owl:inverseOf lis:before ;
          rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
          rdfs:label "after" ;
          rdfs:seeAlso obo:BFO_0000062 ,
                       lis:before ,
                       "ISO 15926-2:2003 'class_of_temporal_sequence'" ;
          iof-av:usageNote "For annotations, see the inverse relation 'before'." ,
                           "Use this relation to state that one activity occurs after another." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:after ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000062 ;
   iof-av:explanatoryNote "BFO_0000062 is 'preceded by' in BFO-ISO."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/arrangedPartOf
lis:arrangedPartOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf lis:partOf ;
                   owl:inverseOf lis:hasArrangedPart ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "arrangedPartOf" ;
                   rdfs:seeAlso lis:hasArrangedPart ;
                   iof-av:usageNote "For annotations, see the inverse relation 'has arranged part'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/assembledPartOf
lis:assembledPartOf rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf lis:arrangedPartOf ;
                    owl:inverseOf lis:hasAssembledPart ;
                    rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                    rdfs:label "assembledPartOf" ;
                    rdfs:seeAlso lis:hasAssembledPart ;
                    iof-av:usageNote "For annotations, see the inverse relation 'has assembled part'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/before
lis:before rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf lis:occursRelativeTo ;
           rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
           rdfs:label "before" ;
           rdfs:seeAlso obo:BFO_0000063 ,
                        lis:after ,
                        "ISO 15926-2:2003 'class_of_temporal_sequence'" ;
           skos:example "The cooling stage takes place before separation." ;
           iof-av:naturalLanguageDefinition "If x is 'before' y, then x ends no later than the start of y." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:before ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000063 ;
   iof-av:explanatoryNote "BFO_0000063 is 'precedes' in BFO-ISO."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/begins
lis:begins rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf lis:activityBoundOf ;
           owl:inverseOf lis:hasBeginning ;
           rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
           rdfs:label "begins" ;
           rdfs:seeAlso lis:hasBeginning ;
           iof-av:usageNote "For annotations, see the inverse relation 'has beginning'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/capabilityOf
lis:capabilityOf rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf lis:dispositionOf ;
                 owl:inverseOf lis:hasCapability ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "capabilityOf" ;
                 rdfs:seeAlso lis:hasCapability ;
                 iof-av:usageNote "For annotations, see the inverse relation 'has capability'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/concretizedBy
lis:concretizedBy rdf:type owl:ObjectProperty ;
                  owl:inverseOf lis:concretizes ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "concretizedBy" ;
                  rdfs:seeAlso lis:concretizes ;
                  iof-av:usageNote "For annotations, see the inverse relation 'concretizes'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/concretizes
lis:concretizes rdf:type owl:ObjectProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( lis:Activity
                                            lis:PhysicalObject
                                          )
                            ] ;
                rdfs:range lis:InformationObject ;
                rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                rdfs:label "concretizes" ;
                rdfs:seeAlso obo:BFO_0000059 ,
                             obo:BFO_0000164 ,
                             obo:RO_0000059 ,
                             lis:concretizedBy ;
                skos:example "A report is produced as paper copies, a spreadsheet document is shown on a computer screen, a plan is carried out, a device operates according to a functional specification, a software program is executed." ;
                skos:scopeNote "Inspired by BFO's \"concretizes\". The constraints on 'concretizes' in IDO closely matches that employed in BFO-ISO (obo:BFO_0000059), and not the RO or the IAO (obo:RO_0000059)." ;
                iof-av:naturalLanguageDefinition "If x 'concretizes' y, then y is an 'information object', and x is a 'physical object' copy of y, or an 'activity' performance of y." ;
                iof-av:usageNote "There are two main, and very different, uses of 'concretizes' for an information object y.  (1) The information object is made concrete in printed or electronic copies. Each copy will have patterns of ink or configurations of electrons that map to y: a quality of appropriate similarity.  (2) The information object is made concrete by a performance according to the specification given by y." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:concretizes ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000059 ;
   iof-av:explanatoryNote "BFO_0000059 is 'concretizes at some time', from BFO-ISO"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:concretizes ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000164 ;
   iof-av:explanatoryNote "BFO_0000164 is 'concretizes at all times', from BFO-ISO"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:concretizes ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0000059 ;
   iof-av:explanatoryNote "RO_0000059 is 'concretizes', from the Relations Ontology; also used in the Information Artifact Ontology."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/connectedTo
lis:connectedTo rdf:type owl:ObjectProperty ,
                         owl:SymmetricProperty ;
                rdfs:domain lis:PhysicalObject ;
                rdfs:range lis:PhysicalObject ;
                rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                rdfs:label "connectedTo" ;
                rdfs:seeAlso obo:RO_0002170 ,
                             "ISO 15926-2:2003 'connection_of_individual'" ;
                skos:example "A three-pin electrical plug is connected to a three-pin socket, two flanges are connected with bolts and a gasket, a gas compressor is indirectly connected to a gearbox assembly (via a coupling)." ;
                iof-av:naturalLanguageDefinition "If x is 'connected to' y, then there is a physical connection between x and y." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:connectedTo ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0002170 ;
   iof-av:explanatoryNote "RO_0002170 is 'connected to', in the Relations Ontology."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/consumedBy
lis:consumedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf lis:passiveParticipantIn ;
               owl:inverseOf lis:consumes ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "consumedBy" ;
               rdfs:seeAlso lis:consumes ;
               iof-av:usageNote "For annotations, see the inverse relation 'consumes'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/consumes
lis:consumes rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf lis:hasPassiveParticipant ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "consumes" ;
             rdfs:seeAlso obo:RO_0002233 ,
                          lis:consumedBy ,
                          lis:creates ,
                          "ISO 15926-2:2003 'class_of_cause_of_ending_of_class_of_individual'" ;
             skos:example "A combustion activity consumes fuel, a welding activity consumes a filler rod, a chemical reaction consumes a reagent, a manufacturing activity consumes raw material." ;
             iof-av:naturalLanguageDefinition "If x 'consumes' y, then x is an 'activity', y is an 'object', and x takes y out of being." ;
             iof-av:usageNote "'consumes' is the dual of 'creates': where 'creates' marks an activity as the cause of an object's beginning, 'consumes' marks an activity as the cause of an object's ending. Consumption here may mean transformation, utilisation, or exhaustion of the consumed object." ,
                              "Together with 'creates', 'consumes' enables continuity of material or energy to be represented across system or activity boundaries: if an upstream activity creates an object and a downstream activity consumes it, the shared object expresses the flow between the two activities." ,
                              "Use this relation to express that an activity takes an object out of being." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:consumes ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0002233 ;
   iof-av:explanatoryNote "RO_0002233 is 'has input' in the OBO Relations Ontology (RO). Its complementary counterpart RO_0002234 is 'has output'. These are subproperties of 'has participant'; 'consumes' in IDO corresponds most closely to 'has input' in the RO, when 'input' denotes an entity that is used up or transformed in the process."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:consumes ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget "ISO 15926-2:2003 'class_of_cause_of_ending_of_class_of_individual'" ;
   iof-av:explanatoryNote "ISO 15926-2:2003, 5.2.10.3 provides an example: \"A car crushing activity causes the end of a car.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/containedBy
lis:containedBy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf lis:locatedRelativeTo ;
                owl:inverseOf lis:contains ;
                rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                rdfs:label "containedBy" ;
                rdfs:seeAlso lis:contains ;
                iof-av:usageNote "For annotations, see the inverse relation 'contains'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/contains
lis:contains rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf lis:locatedRelativeTo ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( lis:Location
                                         lis:PhysicalObject
                                       )
                         ] ;
             rdfs:range [ rdf:type owl:Class ;
                          owl:unionOf ( lis:Location
                                        lis:PhysicalObject
                                      )
                        ] ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "contains" ;
             rdfs:seeAlso obo:BFO_0000124 ,
                          obo:RO_0001015 ,
                          lis:containedBy ,
                          "ISO 15926-2:2003 'containment_of_individual'" ;
             skos:example "An instrument is contained in an enclosure, a pump contains an impeller, a device is contained by a volume of inert gas, a pipeline contains a pipeline inspection gauge (pig), a tank contains fluid, a building contains rooms." ;
             iof-av:naturalLanguageDefinition "If x 'contains' y, then x and y are both 'physical object' or 'location', and y is located entirely within x." ;
             iof-av:usageNote "This relation is intended to be used where an object x is located inside another object y, without implying that x is a part of y." ,
                              "While a 'location' cannot be a part of a 'physical object' or vice versa, they may be contained by each other." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:contains ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000124 ;
   iof-av:explanatoryNote "BFO_0000124 is 'location of at some time' in BFO-ISO."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:contains ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0001015 ;
   iof-av:explanatoryNote "RO_0001015 is 'location of' in the OBO Relations Ontology."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/contentPartOf
lis:contentPartOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf lis:partOf ;
                  owl:inverseOf lis:hasContentPart ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "contentPartOf" ;
                  rdfs:seeAlso lis:hasContentPart ;
                  iof-av:usageNote "For annotations, see the inverse relation 'has content part'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/createdBy
lis:createdBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf lis:passiveParticipantIn ;
              owl:inverseOf lis:creates ;
              rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
              rdfs:label "createdBy" ;
              rdfs:seeAlso lis:creates ;
              iof-av:usageNote "For annotations, see the inverse relation 'creates'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/creates
lis:creates rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf lis:hasPassiveParticipant ;
            rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
            rdfs:label "creates" ;
            rdfs:seeAlso obo:RO_0002234 ,
                         lis:consumes ,
                         lis:createdBy ,
                         "ISO 15926-2:2003 'class_of_cause_of_beginning_of_class_of_individual'" ;
            skos:example "A manufacturing activity produces a car, a welding activity produces a piping spool, a measurement activity produces a performance log." ;
            iof-av:naturalLanguageDefinition "If x 'creates' y, then x is an 'activity', y is an 'object', and x brings y into being." ;
            iof-av:usageNote "Use this relation to express that an activity brings an object into being." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:creates ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0002234 ;
   iof-av:explanatoryNote "RO_0002234 is 'has output' in the OBO Relations Ontology. It complements RO_0002233 'has input'. IDO's 'creates' corresponds to 'has output' when the output is an entity brought into being by the activity."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:creates ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget "ISO 15926-2:2003 'class_of_cause_of_beginning_of_class_of_individual'" ;
   iof-av:explanatoryNote "ISO 15926-2:2003, 5.2.10.2 provides an example as, \"A car manufacturing activity causes the beginning of a car\"."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/datumUOM
lis:datumUOM rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf lis:hasContentPart ;
             owl:inverseOf lis:uomOfDatum ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain lis:QualityDatum ;
             rdfs:range lis:UnitOfMeasure ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "datumUOM" ;
             rdfs:seeAlso obo:IAO_0000039 ,
                          obo:RO_0002536 ,
                          qudt:unit ,
                          lis:uomOfDatum ,
                          om:hasUnit ,
                          <https://schema.org/unitCode> ;
             skos:example "The measured datum \"55 degrees Celsius\" has Celsius as unit of measure." ;
             iof-av:naturalLanguageDefinition "If x 'has datum uom' y, then x is a 'quality datum' for which any 'datum value' is interpreted by the 'unit of measure' y." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:datumUOM ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:IAO_0000039 ;
   iof-av:explanatoryNote "IAO_0000039 is 'has measurement unit label' in the Information Artifact Ontology."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:datumUOM ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0002536 ;
   iof-av:explanatoryNote "RO_0002536 is 'measurement property has unit', an annotation property in the Relations Ontology."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:datumUOM ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget <https://schema.org/unitCode> ;
   iof-av:explanatoryNote "unitCode is a property in the Schema.org vocabulary."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/determinesSite
lis:determinesSite rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf lis:locatedRelativeTo ;
                   owl:inverseOf lis:siteDeterminedBy ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "determinesSite" ;
                   rdfs:seeAlso lis:siteDeterminedBy ;
                   iof-av:usageNote "For annotations, see the inverse relation 'site determined by'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/directlyConnectedTo
lis:directlyConnectedTo rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf lis:connectedTo ;
                        rdf:type owl:SymmetricProperty ;
                        rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                        rdfs:label "directlyConnectedTo" ;
                        rdfs:seeAlso "ISO 15926-2:2003 'direct_connection'" ;
                        skos:example "An electrical plug is connected to a socket, a tag plate is welded to a pressure vessel." ;
                        iof-av:naturalLanguageDefinition "If x is 'directly connected to' y, then x is 'connected to' y, and any material present between x and y directly serves to maintain the connection." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/dispositionOf
lis:dispositionOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf lis:potentialOf ;
                  owl:inverseOf lis:hasDisposition ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "dispositionOf" ;
                  rdfs:seeAlso lis:hasDisposition ;
                  iof-av:usageNote "For annotations, see the inverse relation 'has disposition'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/ends
lis:ends rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf lis:activityBoundOf ;
         owl:inverseOf lis:hasEnding ;
         rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
         rdfs:label "ends" ;
         rdfs:seeAlso lis:hasEnding ;
         iof-av:usageNote "For annotations, see the inverse relation 'has ending'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/featureOf
lis:featureOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf lis:arrangedPartOf ;
              owl:inverseOf lis:hasFeature ;
              rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
              rdfs:label "featureOf" ;
              rdfs:seeAlso lis:hasFeature ;
              iof-av:usageNote "For annotations, see the inverse relation 'has feature'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/functionOf
lis:functionOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf lis:capabilityOf ;
               owl:inverseOf lis:hasFunction ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "functionOf" ;
               rdfs:seeAlso lis:hasFunction ;
               iof-av:usageNote "For annotations, see the inverse relation 'has function'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/functionalPartOf
lis:functionalPartOf rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf lis:partOf ;
                     owl:inverseOf lis:hasFunctionalPart ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "functionalPartOf" ;
                     rdfs:seeAlso lis:hasFunctionalPart ;
                     iof-av:usageNote "For annotations, see the inverse relation 'has functional part'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasActiveParticipant
lis:hasActiveParticipant rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf lis:hasParticipant ;
                         rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                         rdfs:label "hasActiveParticipant" ;
                         rdfs:seeAlso lis:activeParticipantIn ;
                         skos:example "A hammer is the tool in a nail-driving activity, a pressure transmitter outputs data in a monitoring activity, a maintenance engineer replaces an instrument in a repair activity, a light sensor controls the level of illumination." ;
                         iof-av:naturalLanguageDefinition "If x 'has active participant' y, then y is an active participant in x." ;
                         iof-av:usageNote "With OWL property chains, the right kind of participation can be secured for activities that count as realizations of 'potential' individuals. As in, a pump's primary function is realized in pumping activities, but only provided the pump is actually doing the pumping, acting as an \"agent\" or \"subject\"." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasActivityBound
lis:hasActivityBound rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf lis:hasActivityPart ;
                     rdfs:range lis:Event ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "hasActivityBound" ;
                     rdfs:seeAlso lis:activityBoundOf ,
                                  "ISO 15926-2:2003 'temporal_bounding'" ;
                     skos:example "The moment an electrical connection is broken, the time that a fluid reaches a set temperature." ;
                     iof-av:naturalLanguageDefinition "If x 'has activity bound' y, then x 'has activity part' y, and y is an 'event'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasActivityPart
lis:hasActivityPart rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf lis:hasTemporalPart ;
                    rdfs:domain lis:Activity ;
                    rdfs:range lis:Activity ;
                    rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                    rdfs:label "hasActivityPart" ;
                    rdfs:seeAlso obo:BFO_0000117 ,
                                 lis:activityPartOf ,
                                 "ISO 15926-2:2003 'temporal_whole_part'" ;
                    skos:example "The startup period of a chemical process, the inspection part of a maintenance activity, the moment a software program terminates execution." ;
                    skos:scopeNote "Parts of activities may be determined by a range of criteria, including temporal restrictions (to sub-periods), spatial restrictions (parts that occupy sub-volumes of space), by the engagement of participants (temporal or spatial parts where one or more participants are active), and \"selective abstraction\" to profiles (parts determined by that which affects variation in selected qualities)." ;
                    iof-av:naturalLanguageDefinition "If x 'has activity part' y, then x and y are activities, and x 'has temporal part' y." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasActivityPart ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000117 ;
   iof-av:explanatoryNote "BFO_0000117 is 'has occurrent part' in BFO-ISO. This relation has 'occurrent' as domain and range, where the IDO 'has activity part' is restricted to just 'activity'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasActivityProfile
lis:hasActivityProfile rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf lis:hasActivityPart ;
                       rdfs:range lis:ActivityProfile ;
                       rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                       rdfs:label "hasActivityProfile" ;
                       rdfs:seeAlso obo:BFO_0000133 ,
                                    lis:activityProfileOf ;
                       skos:example "A pipeline transport activity has a \"profile\" part which is the variation in fluid pressure." ;
                       iof-av:explanatoryNote "BFO_0000133 is 'process profile of', in the Molecular Process Ontology and other BFO-based ontologies." ;
                       iof-av:naturalLanguageDefinition "If x 'has activity profile' y, then x 'has activity part' y, and y is determined by selective abstraction to that part of x that effects variation in some quality of a participant in x." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasArrangedPart
lis:hasArrangedPart rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf lis:hasPart ;
                    rdfs:domain lis:PhysicalObject ;
                    rdfs:range lis:PhysicalObject ;
                    rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                    rdfs:label "hasArrangedPart" ;
                    rdfs:seeAlso obo:BFO_0000024 ,
                                 lis:arrangedPartOf ,
                                 "ISO 15926-2:2003 'arrangement_of_individual'" ;
                    skos:example "The upper half of a pressure vessel, the mid-section of a bridge. The buildings on a campus, arranged as parts." ;
                    iof-av:naturalLanguageDefinition "If x 'has arranged part' y, then y is a part of x with a boundary determined in relation to other parts of x." ;
                    iof-av:usageNote "The parts do not have to be connected to each other.  They may be separable or non-separable." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasArrangedPart ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000024 ;
   iof-av:explanatoryNote "BFO_0000024 is 'fiat object part' in BFO-ISO."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart
lis:hasAssembledPart rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf lis:hasArrangedPart ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "hasAssembledPart" ;
                     rdfs:seeAlso lis:assembledPartOf ,
                                  "ISO 15926-2:2003 'assembly_of_individual'" ;
                     skos:example "A pipe bend welded into a piping spool, the protective sheath on an electrical cable, a door-handle in a door, a storey of a building." ;
                     iof-av:naturalLanguageDefinition "If x 'has assembled part' y, then y is a connected 'arranged part' of x." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasBeginning
lis:hasBeginning rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf lis:hasActivityBound ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "hasBeginning" ;
                 rdfs:seeAlso obo:BFO_0000222 ,
                              lis:begins ,
                              "ISO 15926-2:2003 'beginning'" ;
                 skos:example "The event that light is switched on, the start of filling a tank." ;
                 iof-av:naturalLanguageDefinition "If x 'has beginning' y, then y is an 'event' which 'has temporal extent' some 'instant' which is the first instant of the temporal extent of x." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasBeginning ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000222 ;
   iof-av:explanatoryNote "BFO_0000222 is 'has first instant' in BFO-ISO, defined for 'temporal region' (differently from 'has beginning' in IDO, defined for 'activity')."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasCapability
lis:hasCapability rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf lis:hasDisposition ;
                  rdfs:range lis:Capability ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "hasCapability" ;
                  rdfs:seeAlso lis:capabilityOf ;
                  skos:example "A pressure sensor has the capability of being a level sensor, a wall has the capability of noise insulation." ;
                  iof-av:naturalLanguageDefinition "x 'has capability' y if and only if x 'has potential' y, and y is a 'capability'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasContentPart
lis:hasContentPart rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf lis:hasPart ;
                   rdfs:domain lis:InformationObject ;
                   rdfs:range lis:InformationObject ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "hasContentPart" ;
                   rdfs:seeAlso lis:contentPartOf ;
                   skos:example "A part of a document such as a chapter, section or figure" ;
                   iof-av:explanatoryNote "Introduced February 2024 as superproperty for parts of information objects." ;
                   iof-av:naturalLanguageDefinition "If x 'has content part' y, then x and y are information objects, and x 'has part' y." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasDisposition
lis:hasDisposition rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf lis:hasPotential ;
                   rdfs:range lis:Disposition ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "hasDisposition" ;
                   rdfs:seeAlso obo:BFO_0000197 ,
                                obo:RO_0000091 ,
                                lis:dispositionOf ;
                   skos:example "A bolted joint has a disposition to come loose, a motor has a disposition to vibrate, a steel bar has a disposition to rust, a vessel has a disposition to leak, a volatile gas has a disposition to flow upwards." ;
                   iof-av:naturalLanguageDefinition "x 'has disposition' y if and only if x 'has potential' y, and y is a 'disposition'." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasDisposition ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000197 ;
   iof-av:explanatoryNote "BFO_0000197 is 'inheres in'"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasDisposition ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0000091 ;
   iof-av:explanatoryNote "RO_0000091 is 'has disposition'"
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasEnding
lis:hasEnding rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf lis:hasActivityBound ;
              rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
              rdfs:label "hasEnding" ;
              rdfs:seeAlso obo:BFO_0000224 ,
                           lis:ends ,
                           "ISO 15926-2:2003 'ending'" ;
              skos:example "The event that light is switched off, the end of filling a tank." ;
              iof-av:naturalLanguageDefinition "If x 'has ending' y, then y is an 'event' which 'has temporal extent' some 'instant' which is the last instant of the temporal extent of x." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasEnding ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000224 ;
   iof-av:explanatoryNote "BFO_0000224 is 'has last instant' in BFO-ISO, defined for 'temporal region' (differently from 'has ending' in IDO, defined for 'activity')."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasFeature
lis:hasFeature rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf lis:hasArrangedPart ;
               rdfs:range lis:Feature ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "hasFeature" ;
               rdfs:seeAlso lis:featureOf ,
                            "ISO 15926-2:2003 'feature_whole_part'" ;
               skos:example "A flange face: the flat surface geometry grounds a sealing function; A bolt thread: the helical surface geometry grounds a fastening function; An optical lens surface: the curvature grounds a light-focusing capability; A mirror surface: the smoothness and reflectivity ground an optical reflection function; A sponge or absorber body: the porosity grounds a fluid-absorption disposition." ;
               iof-av:naturalLanguageDefinition "If x 'has feature' y, then y is an arranged part of x that bears a material quality on which a disposition of x depends." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasFunction
lis:hasFunction rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf lis:hasCapability ;
                rdfs:range lis:Function ;
                rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                rdfs:label "hasFunction" ;
                rdfs:seeAlso obo:BFO_0000197 ,
                             obo:RO_0000085 ,
                             lis:functionOf ,
                             "ISO 15926-2:2003 'functional_physical_object'" ;
                skos:example "A pump has the function of moving fluids, a door has the function of an explosion barrier." ;
                iof-av:naturalLanguageDefinition "x 'has function' y if and only if x 'has potential' y, and y is a 'function'." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasFunction ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0000085 ;
   iof-av:explanatoryNote "RO_0000085 is 'has function'"
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasFunctionalPart
lis:hasFunctionalPart rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf lis:hasPart ;
                      rdfs:domain lis:System ;
                      rdfs:range lis:FunctionalObject ;
                      rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                      rdfs:label "hasFunctionalPart" ;
                      rdfs:seeAlso lis:partOf ;
                      skos:example "A separation system has a cooling system as functional part." ;
                      iof-av:naturalLanguageDefinition "If x 'has functional part' y, then x is a 'system' of which y is a part, and y has one or more functions that contribute to the function of x." ;
                      iof-av:usageNote "'has functional part' is used to represent the functional break-down of a system. Where x is a functional part of a system y, the realisation of one or more functions of x contributes to the performance of y." ,
                                       "'has functional part' provides a compact way of modeling that is not expressive enough to model multiple functional breakdowns. Note that modeling 'has part' directly between Function/Disposition instances gives a higher flexibility and precision, in particular when objects have multiple functions or dispositions." ,
                                       "If 'has part' relationship is modeled between Function/Disposition instances, 'has functional part' can be inferred between the objects that are bearers of the respective functions/dispositions if the corresponding rules are implemented." ,
                                       "Note that, for physical objects, 'has functional part' is a specialization of 'has arranged part'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasInterest
lis:hasInterest rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf lis:hasPotential ;
                owl:inverseOf lis:interestOf ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( lis:Organism
                                            lis:Organization
                                          )
                            ] ;
                rdfs:range lis:Interest ;
                rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                rdfs:label "hasInterest" ;
                rdfs:seeAlso obo:IAO_0000033 ,
                             lis:interestOf ,
                             "ISO 15926-2:2003 'lifecycle_stage'" ;
                skos:example "An intention to start a process, a plan to modify a plant, an approval of a certification." ;
                skos:scopeNote "Note, the use of \"potential\" in the definition does not imply \"not actual\", only \"not necessarily actual\"." ;
                iof-av:naturalLanguageDefinition "x 'has interest' y if and only if x is an 'organization' or 'organism', x 'has potential' y, and y is an 'interest'." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasInterest ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:IAO_0000033 ;
   iof-av:explanatoryNote "IAO_0000033 is 'directive information entity' in the Information Artifact Ontology. See, e.g., subtypes 'action specification', 'objective specification', 'plan specification'; and specifically, 'software' as a subtype of 'plan specification'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasInterest ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget "ISO 15926-2:2003 'lifecycle_stage'" ;
   iof-av:explanatoryNote "Derived from the relation 'lifecycle_stage' of ISO 15926-2:2003, which has the attribute pair 'interest'/'interested'; 'class_of_lifecycle_stage' provides examples of specialisations as, \"EXAMPLE Planned, required, expected, and proposed can be represented by instances of [class_of_lifecycle_stage].\" Following this, 'interest of' is a superproperty suitable for various intentional relationships, such as planning, approving, or ordering. With IDO, we restrict interest to 'potential' entities, while in ISO 15926-2:2003 the domain and range are both unrestricted."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasMaterialPart
lis:hasMaterialPart rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf lis:hasPart ;
                    owl:inverseOf lis:materialPartOf ;
                    rdfs:domain lis:PhysicalObject ;
                    rdfs:range lis:Compound ;
                    rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                    rdfs:label "hasMaterialPart" ;
                    rdfs:seeAlso lis:materialPartOf ;
                    skos:example "A laptop cover has aluminium and plastic material parts." ;
                    iof-av:naturalLanguageDefinition "If x 'has material part' y, then x is a 'physical object', and y is a maximal part of x that has a certain 'material composition quality'." ;
                    iof-av:usageNote "An RDL can include parthood relations that identify parts by their materials, supporting recyclability efforts and similar use cases.  This relation is suitable as the top node of a taxonomy of such relations. These include \"reinforced with material\"  or \"has a matrix with material\" which cannot be aligned with  lis:hasAssembledPart or lis:hasArrangedPart." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasPart
lis:hasPart rdf:type owl:ObjectProperty ;
            owl:inverseOf lis:partOf ;
            rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
            rdfs:label "hasPart" ;
            rdfs:seeAlso obo:BFO_0000051 ,
                         obo:BFO_0000117 ,
                         obo:BFO_0000178 ,
                         lis:partOf ,
                         dol:part ,
                         ssn:hasSubSystem ,
                         "ISO 15926-2:2003 'composition_of_individual'" ;
            skos:example "A system has functional parts, a process has stages, a plant is partitioned into areas." ;
            iof-av:naturalLanguageDefinition "If x 'has part' y, then y is a part of x." ;
            iof-av:usageNote "Individuals that are instances of disjoint classes, such as 'physical object' and 'location' cannot be parts of each other." ,
                             "The relationship x 'has part' y implies that y  is physically or conceptually associated with x, contributing to its  structure, functionality, or characteristics." ,
                             "Where possible, the sub-properties should be used. This property can be used for arbitrary aggregates." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasPart ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000051 ;
   iof-av:explanatoryNote "BFO_0000051 is 'has part', in the Information Artifact Ontology and in the Relations Ontology (in the latter, BFO_0000051 appears as a subrelation of 'overlaps')."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasPart ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000117 ;
   iof-av:explanatoryNote "BFO_0000117 is 'has occurrent part' in BFO-ISO."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasPart ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000178 ;
   iof-av:explanatoryNote "BFO_0000178 is 'has continuant part of at some time' in BFO-ISO."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipant
lis:hasParticipant rdf:type owl:ObjectProperty ;
                   owl:inverseOf lis:participantIn ;
                   rdfs:domain lis:Activity ;
                   rdfs:range lis:Object ;
                   owl:propertyChainAxiom ( lis:hasActivityPart
                                            lis:hasParticipant
                                          ) ,
                                          ( lis:profileOfQuality
                                            lis:qualityOf
                                          ) ,
                                          ( lis:realizes
                                            lis:potentialOf
                                          ) ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "hasParticipant" ;
                   rdfs:seeAlso obo:BFO_0000057 ,
                                obo:RO_0000057 ,
                                lis:participantIn ,
                                "ISO 15926-2:2003 'participation'" ;
                   skos:example "A pump participates in (a) pumping (activity), an electric transformer participates in voltage conversion, a stream of water participates in dilution, a bolt participates in a connection." ;
                   iof-av:naturalLanguageDefinition "If x 'has participant' y, then x is an 'activity', and y is an 'object' that participates in x." ;
                   iof-av:usageNote "A property chain axiom secures that a participant in part of an activity participates in the activity as a whole." ,
                                    "A property chain axiom secures that when a realizable (a 'disposition' or 'role') is 'realized in' an activity, the activity has the bearer as a participant." ,
                                    "A property chain axiom secures that when an activity has a 'profile quantity datum', the bearer of the quantity is a participant in the activity." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasParticipant ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000057 ;
   iof-av:explanatoryNote "BFO_0000057 is 'has participant at some time'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasParticipant ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0000057 ;
   iof-av:explanatoryNote "RO_0000057 is 'has participant'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasParticipantQualityQuantifiedAs
lis:hasParticipantQualityQuantifiedAs rdf:type owl:ObjectProperty ;
                                      rdfs:subPropertyOf lis:representedIn ;
                                      owl:inverseOf lis:quantifiesQualityOfParticipantIn ;
                                      rdfs:domain lis:Activity ;
                                      rdfs:range lis:QualityDatum ;
                                      rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                                      rdfs:label "hasParticipantQualityQuantifiedAs" ;
                                      rdfs:seeAlso lis:quantifiesQualityOfParticipantIn ;
                                      skos:example "Pressure of a stream during a pumping activity, the voltage provided to a motor during a test run." ;
                                      iof-av:naturalLanguageDefinition "If x 'has participant quality quantified as' y, then x is an 'activity', y is a 'quality datum', and at a time within (inclusive) the duration of x, y 'quantifies quality' a 'quality' of a participant in x." ;
                                      iof-av:usageNote "This relation is suitable as the top node in a taxonomy of relations that assign aggregate datums to activities." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasPassiveParticipant
lis:hasPassiveParticipant rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf lis:hasParticipant ;
                          owl:inverseOf lis:passiveParticipantIn ;
                          rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                          rdfs:label "hasPassiveParticipant" ;
                          rdfs:seeAlso lis:passiveParticipantIn ;
                          skos:example "A metal plate is perforated in a drilling activity, a volume of liquid is heated in a heat transmission activity, a loading ramp is the location of an offloading activity, a fluid medium is pumped, a piece of metal is shaped, a stream of data is filtered." ;
                          iof-av:naturalLanguageDefinition "If x 'has passive participant' y, then y is a passive participant in x." ;
                          iof-av:usageNote "With OWL property chains, the right kind of participation can be secured for activities that count as realizations of 'potential' individuals. As in, a bolt is a passive participant in a bolt-driving activity, where its disposition to enter a threaded hole is realized (distinct from the bolt's function, which is realized in a subsequent activity of holding pieces together)." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasPhysicalQuantity
lis:hasPhysicalQuantity rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf lis:hasQuality ;
                        owl:inverseOf lis:physicalQuantityOf ;
                        rdfs:domain lis:PhysicalObject ;
                        rdfs:range lis:PhysicalQuantity ;
                        rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                        rdfs:label "hasPhysicalQuantity" ;
                        rdfs:seeAlso lis:physicalQuantityOf ;
                        skos:example "A section of pipe has length, a crane has lifting power, a flange has inner diameter." ;
                        iof-av:naturalLanguageDefinition "x 'has physical quantity' y if and only if x 'has quality' y, and y is a 'physical quantity'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasPotential
lis:hasPotential rdf:type owl:ObjectProperty ;
                 owl:inverseOf lis:potentialOf ;
                 rdfs:domain lis:Object ;
                 rdfs:range lis:Potential ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "hasPotential" ;
                 rdfs:seeAlso obo:BFO_0000196 ,
                              obo:RO_0000053 ,
                              lis:potentialOf ;
                 skos:example "Having a role, function, obligation, or plan (intention to act)." ;
                 skos:scopeNote "The pre-defined types of 'potential' entities in IDO are 'role', 'disposition', and 'interest'. If other kinds are needed for use case, then 'has potential' is a suitable superrelation for the corresponding bearer relations." ;
                 iof-av:naturalLanguageDefinition "If x 'has potential' y, then x is an 'object', and y is a 'potential' that is dependent on x." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasPotential ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000196 ;
   iof-av:explanatoryNote "BFO_0000196 is 'bearer of', a more generic relation than 'has potential' in that its range is any 'specifically dependent continuant', which in IDO corresponds to 'dependent'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasPotential ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0000053 ;
   iof-av:explanatoryNote "RO_0000053 is 'has characteristic', which in the Relation Ontology also has 'quality of' as a subrelation."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasPrimaryParticipant
lis:hasPrimaryParticipant rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf lis:hasParticipant ;
                          owl:inverseOf lis:primaryParticipantIn ;
                          rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                          rdfs:label "hasPrimaryParticipant" ;
                          rdfs:seeAlso lis:primaryParticipantIn ;
                          skos:example "A pump is the performer in a pumping activity, a thermometer is the performer in a temperature measurement." ;
                          iof-av:naturalLanguageDefinition "If x 'has primary participant' y, then x is a realization of a disposition or role of y that is essential to the identification of x." ;
                          iof-av:usageNote "Assume p is a pump, a an activity that realizes the function fp of p, and no subactivity x of a realizes fp (except for subactivities determined solely by restriction to a temporal sub-interval). For instance, the subactivity of the motor that drives the impeller realizes a function of the motor, but this is not by itself a realization of the function of the pump as a whole, hence the motor is not a 'primary participant'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasQuality
lis:hasQuality rdf:type owl:ObjectProperty ;
               owl:inverseOf lis:qualityOf ;
               rdfs:domain lis:Object ;
               rdfs:range lis:Quality ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "hasQuality" ;
               rdfs:seeAlso obo:BFO_0000196 ,
                            obo:RO_0000086 ,
                            lis:qualityOf ;
               skos:example "A motor has rated output power, a lightbulb has luminance, an amount of liquid has mass, a bar of metal has chemical composition, a document has readability." ;
               iof-av:naturalLanguageDefinition "If x 'has quality' y, then x is an 'object', and y is a 'quality' that is dependent on x." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasQuality ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000196 ;
   iof-av:explanatoryNote "BFO_0000196 is 'bearer of', a more generic relation than 'has quality' in that its range is any 'specifically dependent continuant', which in IDO corresponds to 'dependent'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasQuality ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:RO_0000086 ;
   iof-av:explanatoryNote "RO_0000086 is 'has quality' in the Relations Ontology."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasQualityQuantifiedAs
lis:hasQualityQuantifiedAs rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf lis:representedIn ;
                           owl:inverseOf lis:quantifiesQualityOf ;
                           rdfs:domain lis:Object ;
                           rdfs:range lis:QualityDatum ;
                           owl:propertyChainAxiom ( lis:hasQuality
                                                    lis:qualityQuantifiedAs
                                                  ) ;
                           rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                           rdfs:label "hasQualityQuantifiedAs" ;
                           rdfs:seeAlso lis:quantifiesQualityOf ;
                           skos:example "The GeoSPARQL object property geo:hasLength relates (spatial) objects to datums that provide length with number and unit of measure. lis:hasQualityQuantifiedAs is suitable as a superproperty in an alignment with GeoSPARQL data that includes geo:hasLength relationships." ;
                           iof-av:naturalLanguageDefinition "If x 'has quality quantified as' y, then x is an 'object', and y is a 'quality datum' that 'quantifies quality' a 'quality' of x." ;
                           iof-av:usageNote "This relation is suitable as the top node in a taxonomy of \"shortcut\" relations that relate objects directly to quality datums, leaving the quality implicit." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasResident
lis:hasResident rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf lis:contains ;
                owl:inverseOf lis:residesIn ;
                rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                rdfs:label "hasResident" ;
                rdfs:seeAlso lis:residesIn ,
                             "ISO 15926-2:2003 'relative_location'" ;
                iof-av:usageNote "For annotations, see the inverse relation 'resides in'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasRole
lis:hasRole rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf lis:hasPotential ;
            owl:inverseOf lis:roleOf ;
            rdfs:range lis:Role ;
            rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
            rdfs:label "hasRole" ;
            rdfs:seeAlso obo:RO_0000087 ,
                         lis:roleOf ,
                         "ISO 15926-2:2003 'role'" ;
            skos:example "An window has the role of a ventilation opening, a room has the role of a storage space, a gas sensor has the role of a leak detector, a person has the role of inspector." ;
            iof-av:explanatoryNote "Inspired by BFO's \"has role\" (RO_0000087)" ;
            iof-av:naturalLanguageDefinition "x 'has role' y if and only if x 'has potential' y, and y is a 'role'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasSiteInside
lis:hasSiteInside rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf lis:contains ;
                  owl:inverseOf lis:siteInsideOf ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "hasSiteInside" ;
                  rdfs:seeAlso lis:siteInsideOf ,
                               "ISO 15926-2:2003 'relative_location'" ;
                  iof-av:usageNote "For annotations, see the inverse relation 'site inside of'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasSpatialExtent
lis:hasSpatialExtent rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf lis:locatedRelativeTo ;
                     owl:inverseOf lis:spatialExtentOf ;
                     rdfs:domain [ rdf:type owl:Class ;
                                   owl:unionOf ( lis:Location
                                                 lis:PhysicalObject
                                               )
                                 ] ;
                     rdfs:range lis:SpatialLocation ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "hasSpatialExtent" ;
                     rdfs:seeAlso obo:BFO_0000210 ,
                                  lis:spatialExtentOf ,
                                  dol:exact-location ;
                     skos:example "The volume occupied by an process skid, the volume occupied by a volume of flammable gas." ;
                     iof-av:naturalLanguageDefinition "If x 'has spatial extent' y, then x is a 'physical object', and y is the 'spatial location' determined as the extension in space of x." ;
                     iof-av:usageNote "The site of an object will occupy different spatial locations over time if the location and size of the object changes." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasSpatialExtent ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000210 ;
   iof-av:explanatoryNote "BFO_0000210 is 'occupies spatial region at some time' (from BFO-ISO)"
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasSpatiotemporalExtent
lis:hasSpatiotemporalExtent rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf lis:occursRelativeTo ;
                            owl:inverseOf lis:spatiotemporalExtentOf ;
                            rdfs:domain lis:Activity ;
                            rdfs:range lis:SpatiotemporalRegion ;
                            rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                            rdfs:label "hasSpatiotemporalExtent" ;
                            rdfs:seeAlso obo:BFO_0000200 ;
                            skos:example "A pipeline pig occupies the spatiotemporal region which is its trajectory (adopted from BFO-ISO)." ;
                            iof-av:naturalLanguageDefinition "If x 'has spatiotemporal extent' y, then x is an activity, and y is a spatiotemporal region which is the spatiotemporal extent of x." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasSpatiotemporalExtent ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000200 ;
   iof-av:explanatoryNote "BFO_0000200 is 'occupies spatiotemporal region'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasSubLocation
lis:hasSubLocation rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf lis:contains ,
                                      lis:hasPart ;
                   owl:inverseOf lis:subLocationOf ;
                   rdfs:domain lis:Location ;
                   rdfs:range lis:Location ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "hasSubLocation" ;
                   rdfs:seeAlso lis:subLocationOf ;
                   skos:example "The landing area is a sublocation of the helicopter deck." ;
                   iof-av:naturalLanguageDefinition "If x 'has sublocation' y, then x and y are locations, and x 'has part' y." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasTemporalExtent
lis:hasTemporalExtent rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf lis:hasTemporalRegion ;
                      owl:inverseOf lis:temporalExtentOf ;
                      rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                      rdfs:label "hasTemporalExtent" ;
                      rdfs:seeAlso lis:temporalExtentOf ;
                      skos:example "A well drilling activity takes place in a 20-hour interval, a control system is switched on at 10:00 AM." ;
                      iof-av:naturalLanguageDefinition "If x 'has temporal extent' y, then x is a 'temporal' entity, and y is a temporal region which is the temporal extent of x." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasTemporalPart
lis:hasTemporalPart rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf lis:hasPart ;
                    owl:inverseOf lis:temporalPartOf ;
                    rdfs:domain lis:Temporal ;
                    rdfs:range lis:Temporal ;
                    rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                    rdfs:label "hasTemporalPart" ;
                    rdfs:seeAlso lis:temporalPartOf ;
                    skos:example "A specific day is a temporal part of a specific week." ;
                    iof-av:naturalLanguageDefinition "If x 'has temporal part' y, then x and y are temporal entities, and y is a part of x." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/hasTemporalRegion
lis:hasTemporalRegion rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf lis:occursRelativeTo ;
                      owl:inverseOf lis:temporalRegionOf ;
                      rdfs:domain lis:Activity ;
                      rdfs:range lis:TemporalRegion ;
                      rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                      rdfs:label "hasTemporalRegion" ;
                      rdfs:seeAlso obo:BFO_0000199 ,
                                   lis:hasTemporalExtent ,
                                   lis:temporalRegionOf ;
                      skos:example "A maintenance activity has a temporal region representing the total planned outage window, and another temporal region representing the actual hands-on work period." ;
                      iof-av:naturalLanguageDefinition "If x 'has temporal region' y, then x is an 'activity', and y is a 'temporal region' associated with x." ;
                      iof-av:usageNote "Use this relation to associate an activity with any temporal region of interest, not only its maximal temporal extent. For example, an activity may be related to a temporal region representing a lag, a lead time, or a partial interval. The sub-property 'has temporal extent' is reserved for the maximal temporal extension of the activity." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:hasTemporalRegion ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000199 ;
   iof-av:explanatoryNote "BFO_0000199 is 'occupies temporal region'. 'has temporal region' is more general than BFO's 'occupies temporal region' - it is not restricted to the maximal temporal extent but also covers, e.g., lags and partial intervals associated with the activity."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/implementedBy
lis:implementedBy rdf:type owl:ObjectProperty ;
                  owl:inverseOf lis:implements ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "implementedBy" ;
                  rdfs:seeAlso lis:implements ;
                  iof-av:usageNote "For annotations, see the inverse relation 'implements'" .


###  http://rds.posccaesar.org/ontology/lis14/rdl/implements
lis:implements rdf:type owl:ObjectProperty ;
               rdfs:domain lis:Actual ;
               rdfs:range lis:Specified ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "implements" ;
               rdfs:seeAlso lis:implementedBy ;
               skos:example "In a design study, candidate compressor models from different vendors are each asserted to implement the specified compressor C-201, to evaluate which candidates satisfy the design requirements." ,
                            "The ASME pumps with serial numbers 457636 and 457711 implement (have been installed as) the P-101 pump described in the specification." ;
               skos:scopeNote "The 'implements' relation is central to the intended use of IDO. It allows for a record of concrete individuals corresponding to specified individuals — whether through physical installation over time, or through analytical association in a design case. Typically, a serial-numbered physical artefact is installed as the counterpart of a \"specification\" individual (a \"tag\") at one time, and later replaced with another serial-numbered physical artefact; alternatively, candidate objects may be associated with specifications for the purpose of simulation or case evaluation. The 'implements' relation carries semantic restrictions only to ensure no object is both Actual and Specified. No further constraints are given, to allow 'implements' relationships even where restrictions on the specification object are inconsistent with those on the implementing object." ;
               iof-av:explanatoryNote "The domain and range restrictions to disjunct classes 'actual' and 'specified' prevent chains of 'implements' relationships." ;
               iof-av:naturalLanguageDefinition "If x 'implements' y, then x is an 'actual' entity, y is a 'specified' entity, and x is asserted to correspond to y as its concrete realization for a given period of time or in a given analytical context." ;
               iof-av:usageNote "'implements' records that a concrete individual (classified as 'actual') corresponds to an individual in the asset specification (classified as 'specified'). This correspondence may be physical — as when a serial-numbered artefact is installed at a tag position — or analytical, as when a candidate object is evaluated against a specification in a design simulation. Because OWL DL lacks temporal indexing, the relation is defined atemporally: it does not encode when or whether a physical installation occurred." ,
                                "An asset model with 'implements' relationships supports compatibility checks for implementing objects, to uncover possible violations of requirements. This requires a transformation of the asset model, as follows: replace each 'implements'/'implementedBy' relationship with identity (owl:sameAs) and replace classifications as 'specified' or 'actual' with just 'object' for the participant individuals. Any semantic inconsistency between the specified object and the implementing object may then be discovered by OWL reasoning." ,
                                "In process design, 'implements' may be used to associate a candidate object with a specification for the purpose of case analysis (e.g., simulating six design cases). In this use, the relation expresses analytical correspondence — the candidate is evaluated as-if it were the installed counterpart — without implying that physical deployment has occurred." ,
                                "The mechanism for checking requirement consistency on 'implements' relationships must be implemented as a transformation that is external to the OWL ontology." ,
                                "When 'implements' is used to record physical installation, the period of correspondence should be recorded using OWL annotations on the relation instance, or through a detailed representation using 'role'. This enables prescriptive objects to be matched with installed objects for selected points or periods in time." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/interestOf
lis:interestOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf lis:potentialOf ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "interestOf" ;
               rdfs:seeAlso lis:hasInterest ;
               iof-av:usageNote "For annotations, see the inverse relation 'has interest'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/isAbout
lis:isAbout rdf:type owl:ObjectProperty ;
            owl:inverseOf lis:representedIn ;
            rdfs:domain lis:InformationObject ;
            rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
            rdfs:label "isAbout" ;
            rdfs:seeAlso obo:IAO_0000136 ,
                         lis:representedIn ,
                         "ISO 15926-2:2003 'representation_of_thing'" ;
            skos:example "A regulation describes a procedure, a datum quantifies a quality, a nameplate provides basic information about a pressure vessel, a log file traces quantity values during an activity." ;
            skos:scopeNote "This relation is suitable as the top node in a taxonomy of relations between information objects and entities, including describing, naming, characterisation, and evaluation." ;
            iof-av:naturalLanguageDefinition "If x 'is about' y, then x is an 'information object' of relevance to y." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:isAbout ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:IAO_0000136 ;
   iof-av:explanatoryNote "IAO_0000136 is 'is about', in the Information Artifact Ontology."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/locatedRelativeTo
lis:locatedRelativeTo rdf:type owl:ObjectProperty ,
                               owl:SymmetricProperty ;
                      rdfs:domain lis:Object ;
                      rdfs:range lis:Object ;
                      rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                      rdfs:label "locatedRelativeTo" ;
                      rdfs:seeAlso obo:BFO_0000171 ,
                                   obo:BFO_0000210 ,
                                   dol:generic-location ,
                                   "ISO 15926-2:2003 'relative_location'" ;
                      skos:example "An outlet is below an inlet, a door is inside an opening, a motor is inside an enclosure." ;
                      iof-av:naturalLanguageDefinition "If x is 'located relative to' y, then x and y are 'object's with location in space." ;
                      iof-av:usageNote "This relation is \"abstract\" (in the object-orientation sense of the word) in that it serves only as a parent relation to specialized relations of relative location." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:locatedRelativeTo ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000171 ;
   iof-av:explanatoryNote "BFO_0000171 is 'located in at some time' in BFO-ISO. This relation has domain and range restricted to 'independent continuant' and not 'spatial region', meaning it's a relation between entities that are material objects or determined by material objects, only."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:locatedRelativeTo ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000210 ;
   iof-av:explanatoryNote "BFO_0000210 is 'occupies spatial region at some time' in BFO-ISO. This relation has domain restricted to 'independent continuant' and not 'spatial region', and range to 'spatial region', meaning it's a relation from entities that are material objects or determined by material objects, to spatial regions determined independently of material objects."
 ] .


