###  http://rds.posccaesar.org/ontology/lis14/rdl/subLocationOf
lis:subLocationOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf lis:containedBy ,
                                     lis:partOf ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "subLocationOf" ;
                  rdfs:seeAlso lis:hasSubLocation ;
                  iof-av:usageNote "For annotations, see the inverse relation 'has sub location'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/temporalExtentOf
lis:temporalExtentOf rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf lis:temporalRegionOf ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "temporalExtentOf" ;
                     rdfs:seeAlso lis:hasTemporalExtent ;
                     iof-av:usageNote "For annotations, see the inverse relation 'has temporal extent'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/temporalPartOf
lis:temporalPartOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf lis:partOf ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "temporalPartOf" ;
                   rdfs:seeAlso lis:hasTemporalPart ;
                   iof-av:usageNote "For annotations, see the inverse relation 'has temporal part'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/temporalRegionOf
lis:temporalRegionOf rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf lis:occursRelativeTo ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "temporalRegionOf" ;
                     rdfs:seeAlso lis:hasTemporalRegion ;
                     iof-av:usageNote "For annotations, see the inverse relation 'has temporal region'." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/temporalRegionQuantifiedAs
lis:temporalRegionQuantifiedAs rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf lis:representedIn ;
                               rdfs:domain lis:TemporalRegion ;
                               rdfs:range lis:TemporalDatum ;
                               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                               rdfs:label "temporalRegionQuantifiedAs" ;
                               rdfs:seeAlso lis:qualityQuantifiedAs ,
                                            lis:quantifiesTemporalRegion ;
                               skos:example "A 20-hour interval associated with a well drilling activity is quantified as a temporal datum of \"20 hours (observed)\" and another of \"18 hours (estimated)\"." ;
                               iof-av:naturalLanguageDefinition "If x is 'temporal region quantified as' y, then x is a 'temporal region' that is represented in the 'temporal datum' y." ;
                               iof-av:usageNote "Multiple temporal datums may quantify the same temporal region, for example an observed duration value and an estimated duration value." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/uomOfDatum
lis:uomOfDatum rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf lis:contentPartOf ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "uomOfDatum" ;
               rdfs:seeAlso lis:datumUOM ;
               iof-av:explanatoryNote "Relation from 'unit of measure' to 'quantity datum'. The inverse relation of datumUOM." ;
               iof-av:usageNote "For annotations, see the inverse relation 'datumUOM'." .


#################################################################
#    Data properties
#################################################################

###  http://rds.posccaesar.org/ontology/lis14/rdl/datumValue
lis:datumValue rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain lis:QualityDatum ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "datumValue" ;
               rdfs:seeAlso obo:IAO_0000004 ,
                            qudt:numericValue ,
                            om:hasNumericalValue ,
                            ssn:hasSimpleResult ;
               skos:example "The measured datum \"55 degrees Celsius\" has \"55\" as literal value." ;
               iof-av:naturalLanguageDefinition "If x 'datum value' y, then x is a 'quality datum', and y is the literal value of x." ;
               iof-av:usageNote "A literal value is uninterpreted. Provide a unit of measure, or other category, for a 'quality datum' to be interpretable." ,
                                "For numeric non-integer values, the recommended data type is xsd:float." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:datumValue ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:IAO_0000004 ;
   iof-av:explanatoryNote "BFO-ISO declares no data properties." ,
                          "IAO_0000004 is the data property 'has measurement value', in the Information Artifact Ontology."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:datumValue ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget qudt:numericValue ;
   iof-av:explanatoryNote "numericValue is a data property in QUDT."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:datumValue ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget om:hasNumericalValue ;
   iof-av:explanatoryNote "hasNumericalValue is a data property in the Ontology of Units of Measure."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:datumValue ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget ssn:hasSimpleResult ;
   iof-av:explanatoryNote "hasSimpleResult is a data property in the Semantic Sensor Networks ontology."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/qualityQuantityValue
lis:qualityQuantityValue rdf:type owl:DatatypeProperty ;
                         rdfs:domain lis:Object ;
                         rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                         rdfs:label "qualityQuantityValue" ;
                         skos:example "Mass in kilograms, pressure in barg." ;
                         iof-av:naturalLanguageDefinition "If x has 'quality quantity value' y, then x is an 'object', and y is a literal value that quantifies a quality of x." ;
                         iof-av:usageNote "This relation is suitable as the top node in a taxonomy of \"shortcut\" relations that combine quality and unit of measure into a single, simple data property." ,
                                          "When introducing shortcut properties as subproperties, annotations should be provided to explain the intended quantity type, any quantification type (e.g., measured, nominal, etc.), and unit of measure." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/temporalValue
lis:temporalValue rdf:type owl:DatatypeProperty ;
                  rdfs:domain lis:TemporalDatum ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "temporalValue" ;
                  skos:example "The temporal datum \"20 hours observed duration\" has \"PT20H\"^^xsd:duration as temporal value; the temporal datum \"start time\" has \"2026-03-15T08:00:00Z\"^^xsd:dateTime as temporal value." ;
                  iof-av:naturalLanguageDefinition "If x 'temporal value' y, then x is a 'temporal datum', and y is the literal value of x." ;
                  iof-av:usageNote "Suitable data types include xsd:duration for durations, xsd:dateTime for time stamps, and xsd:date for calendar dates." .


#################################################################
#    Classes
#################################################################

###  http://rds.posccaesar.org/ontology/lis14/rdl/Activity
lis:Activity rdf:type owl:Class ;
             rdfs:subClassOf lis:Temporal ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty lis:hasParticipant ;
                               owl:someValuesFrom lis:PhysicalObject
                             ] ;
             owl:disjointWith lis:SpatiotemporalRegion ,
                              lis:TemporalRegion ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "Activity" ;
             rdfs:seeAlso obo:BFO_0000015 ,
                          dol:accomplishment ,
                          dol:process ,
                          prov:Activity ,
                          "ISO 15926-2:2003 'activity'" ;
             skos:example "A pumping, an inspection, a report writing, a fastening (the activity of a bolt in holding two pieces together)." ;
             skos:scopeNote "An 'activity' may have temporal gaps. For example, intermittent operation of a heater over a week may be represented by a single 'activity' individual; it will occupy a non-connected 'interval region'. The details of each connected activity part (“singular activities”) may be modelled by relating the activity to 'interval' individuals." ;
             iof-av:naturalLanguageDefinition "A temporal entity in which one or more physical objects participate." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Activity ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget "ISO 15926-2:2003 'activity'" ;
   iof-av:explanatoryNote "ISO 15926-2:2003, 4.7.17 states, \"... activities are considered to be space-time extensions in which other individuals and events participate.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/ActivityProfile
lis:ActivityProfile rdf:type owl:Class ;
                    rdfs:subClassOf lis:Activity ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty lis:profileOfQuality ;
                                      owl:someValuesFrom lis:Quality
                                    ] ;
                    rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                    rdfs:label "ActivityProfile" ;
                    skos:example "An 'activity profile' of an 'activity' involving rotating equipment, instantiating a class \"100 revolutions per minute\"." ,
                                 "The BFO 2.0 reference guide provides good examples, like \"constant speed profile\", \"acceleration profile\", and \"irregular beat profile\"." ;
                    skos:scopeNote "An 'activity profile' is a part of an 'activity', a \"selective abstraction\" (using a term from the BFO reference guide) made according to a quality of interest to the process. Typically, we will select a physical quantity such as pressure or temperature, and refer to the \"pressure profile\" of the activity. By means of the relation 'profile quantity datum', the activity profile can be related to a set of 'quantity datum' individuals, to which aggregation can be applied, giving a basis for classification." ;
                    iof-av:adaptedFrom obo:BFO_0000144 ;
                    iof-av:explanatoryNote "'activity profile' represents a projection of an activity onto a single quality of interest, analogous to the projection of a physical process onto one of its variables. Like a projection in physics, an activity profile unfolds over the same time interval as the containing activity but considers only the variation in some specified quality, such as pressure or temperature." ,
                                           "The name \"ActivityProfile\"  has been chosen because lis:Activity corresponds to BFO's 'process'." ;
                    iof-av:naturalLanguageDefinition "An activity obtained by \"selective abstraction\" to just that part of an activity that consists in varying or maintaining a specified 'quality' of a participant." ;
                    iof-av:usageNote "Typically, a physical quantity of a participant, such as a \"pressure\" individual, is selected, and the \"pressure profile\" of the activity is introduced. The relation 'profile of quality' links to that pressure quality individual that defines (is the basis for abstraction to) the activity profile. By means of the relation 'profile quantity datum', the activity profile can be related to 'quantity datum' individuals, to which aggregation can be applied, giving a basis for classification of the activity profile; for example, as a \"rising pressure\" activity." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:ActivityProfile ;
   owl:annotatedProperty iof-av:adaptedFrom ;
   owl:annotatedTarget obo:BFO_0000144 ;
   iof-av:explanatoryNote "BFO_0000144 is 'process profile'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Actual
lis:Actual rdf:type owl:Class ;
           owl:disjointWith lis:Specified ;
           rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
           rdfs:label "Actual" ;
           skos:example "A serial-numbered artefact installed at a tag, a function of a concrete artefact, a run or execution of a designed process, an industrial facility \"as built\"." ;
           iof-av:naturalLanguageDefinition "An entity that is a concrete implementation of a 'specified' entity." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Capability
lis:Capability rdf:type owl:Class ;
               rdfs:subClassOf lis:Disposition ;
               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
               rdfs:label "Capability" ;
               rdfs:seeAlso obo:MF_0000043 ,
                            obo:NCIT_C74979 ,
                            obo:SIO_000112 ,
                            lis:hasCapability ;
               skos:example "The capability of a motor to generate power, of a pump to generate head and flow. The capability to use a hammer as a paperweight, which is not its primary capability (function)." ;
               iof-av:naturalLanguageDefinition "A disposition which when realized serves a positive or desired outcome." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Capability ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:MF_0000043 ;
   iof-av:explanatoryNote "MF_0000043 is 'capability'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Capability ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:NCIT_C74979 ;
   iof-av:explanatoryNote "NCIT_C74979 is 'capability'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Capability ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:SIO_000112 ;
   iof-av:explanatoryNote "SIO_000112 is 'capability'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Compound
lis:Compound rdf:type owl:Class ;
             rdfs:subClassOf lis:PhysicalObject ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty lis:hasQuality ;
                               owl:someValuesFrom lis:MaterialCompositionQuality
                             ] ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "MateriallyClassifiedObject" ;
             rdfs:seeAlso "ISO 15926-2:2003 'class_of_compound'" ;
             skos:altLabel "Compound" ;
             skos:example "Types of material composition, such as 316 stainless steel, reinforced concrete, and carbon monoxide." ;
             skos:scopeNote "Natural kinds are expressly not to be classified as 'compound'. The class 'compound' is only to be used to classify amounts of matter, with non-semantic auxiliaries used to refer to chemical composition. The semantics of natural kinds such as \"helium\", \"steel\", or \"hydrocarbon\" is out of scope for IDO." ;
             iof-av:naturalLanguageDefinition "A physical object with a defined material composition." ;
             iof-av:usageNote "A typical RDL includes classes that categorise individuals according to material composition. This class is suitable as the top node of such a taxonomy." ,
                              "Renamed class. Checked materially in Oxford English Dictionary." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Dependent
lis:Dependent rdf:type owl:Class ;
              owl:disjointWith lis:Object ,
                               lis:Temporal ;
              rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
              rdfs:label "Dependent" ;
              rdfs:seeAlso lis:ActivityProfile ,
                           lis:hasParticipantQualityQuantifiedAs ,
                           "ISO 15926-2:2003 'property', 'functional_physical_object'" ;
              skos:altLabel "Dependent Entity" ;
              skos:example "The colour of a surface, the temperature of a medium, a technical contact role, the storage-space role of a room." ;
              skos:scopeNote "Any 'object' will be the bearer of various 'dependent' entities, but any 'temporal' entity has only an indirect relationship to 'dependent's. This is in line with BFO." ,
                             "The class Dependent is closely related to \"specifically dependent continuant\" in BFO (BFO_0000020)." ;
              iof-av:adaptedFrom obo:BFO_0000020 ;
              iof-av:naturalLanguageDefinition "An entity that is an inherent quality or realizable potential of an object." ;
              iof-av:usageNote "A common need is to relate a measure based on a 'physical quantity' to an 'activity', like average speed to a transport activity. This may not be implemented with an 'average speed' entity that is dependent on the transport. For a suitable representation pattern, see the class 'activity profile' and related resources. A \"shortcut\" approach may use the relation 'has participant quality quantified as'." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Dependent ;
   owl:annotatedProperty iof-av:adaptedFrom ;
   owl:annotatedTarget obo:BFO_0000020 ;
   iof-av:explanatoryNote "BFO_0000020 is 'specifically dependent continuant'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Disposition
lis:Disposition rdf:type owl:Class ;
                rdfs:subClassOf lis:Potential ;
                rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                rdfs:label "Disposition" ;
                rdfs:seeAlso lis:hasDisposition ;
                skos:example "The disposition of a steel bar to corrode, the disposition of a gasket to leak. The disposition to overflow a memory buffer." ;
                skos:scopeNote "An object may not lose a disposition without undergoing physical change." ;
                iof-av:adaptedFrom obo:BFO_0000016 ;
                iof-av:naturalLanguageDefinition "A potential whose realization is dependent on an object's structure." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Disposition ;
   owl:annotatedProperty iof-av:adaptedFrom ;
   owl:annotatedTarget obo:BFO_0000016 ;
   iof-av:explanatoryNote "BFO_0000016 is 'disposition'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Event
lis:Event rdf:type owl:Class ;
          rdfs:subClassOf lis:Activity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty lis:hasTemporalExtent ;
                            owl:allValuesFrom lis:InstantRegion
                          ] ;
          rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
          rdfs:label "Event" ;
          rdfs:seeAlso obo:BFO_0000035 ,
                       lis:hasParticipant ,
                       dol:achievement ,
                       "ISO 15926-2:2003 'event'" ;
          skos:example "The beginning of a lifting operation, the end of a measurement activity, the midpoint between beginning and end of an activity." ;
          skos:scopeNote "An 'event' doesn't need to be temporally connected. For example, several instances of switching on a heater over a week may be represented by a single 'event' individual; it will occupy a non-singular 'instant region'. The details of a singular event part may be modelled by relating the event to 'instant' individuals." ,
                         "Event is close in meaning to BFO's 'process boundary', and to DOLCE's 'achievement'." ;
          iof-av:explanatoryNote "'event' is a subclass of 'activity': an occurrence in which physical objects participate. What distinguishes an event is the restriction that its temporal extent is an instant region rather than an interval. The term 'event' and the subclass placement are inherited from ISO 15926-2." ,
                                 "The IDO treatment of 'event' differs from BFO, where 'process boundary' (BFO_0000035) is a sibling class to 'process' rather than a subclass. With IDO, a property chain axiom on 'has participant' implies that activity-bounding events share participants with the activities they bound." ;
          iof-av:naturalLanguageDefinition "An 'activity' that occurs at one or more specific points in time." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Event ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000035 ;
   iof-av:explanatoryNote "BFO_0000035 is 'process boundary'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Feature
lis:Feature rdf:type owl:Class ;
            rdfs:subClassOf lis:PhysicalObject ;
            rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
            rdfs:label "Feature" ;
            rdfs:seeAlso obo:BFO_0000024 ,
                         dol:relevant-part ,
                         "ISO 15926-2:2003 'class_of_feature'" ;
            skos:example "A flange face, a connection port (terminal), the inside surface of a pump, a painted area of a manifold, a bolt threading." ;
            iof-av:naturalLanguageDefinition "An arranged part that bears a material quality on which a disposition of the object depends." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Feature ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000024 ;
   iof-av:explanatoryNote "BFO_0000024 is 'fiat object part'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Function
lis:Function rdf:type owl:Class ;
             rdfs:subClassOf lis:Capability ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "Function" ;
             rdfs:seeAlso lis:hasFunction ,
                          "ISO 15926-2:2003 'functional_physical_object'" ;
             skos:example "The function of a motor to apply a specified torque to a shaft." ;
             iof-av:adaptedFrom obo:BFO_0000034 ;
             iof-av:naturalLanguageDefinition "A capability that meets a design requirement." ;
             iof-av:usageNote "The typical 'function' of a hammer is realized when the hammer participates as the tool in a successful nail-driving activity. If the hammer has multiple functions, such as extracting nails using a claw or shaping objects with a ball, each function should be represented with a distinct individual." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Function ;
   owl:annotatedProperty iof-av:adaptedFrom ;
   owl:annotatedTarget obo:BFO_0000034 ;
   iof-av:explanatoryNote "BFO_0000034 is 'function'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/FunctionalObject
lis:FunctionalObject rdf:type owl:Class ;
                     rdfs:subClassOf lis:Object ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty lis:hasFunction ;
                                       owl:someValuesFrom lis:Function
                                     ] ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "FunctionalObject" ;
                     rdfs:seeAlso "ISO 15926-2:2003 'functional_physical_object'" ;
                     skos:example "A password is concretized when it is entered, and it allows the computer to be unlocked. The password participates in the unlocking process through its concretization." ,
                                  "A pump, a hammer, a password." ;
                     iof-av:naturalLanguageDefinition "An 'Object' that provides a required 'Function'." ;
                     iof-av:usageNote "A \"tag\", when included in an IDO asset model, should in general have a type that is subclass of both 'functional object' and 'physical artefact'." ,
                                      "Artefact types tend to be described primarily in terms of 'function'; for example, the \"minimal\" definition of a pump would be, \"a physical artefact, the function of which is to pump (to be the active participant in a pumping activity)\". This kind of definition places no restriction on physical make-up and is suitable for a subclass of 'functional object'. Note that the activity type of 'pumping' is here a precursor to the definition of the physical object type 'pump'. A taxonomy of pump classes should extend from a class 'pump' defined solely in terms of function, as above." ,
                                      "Most artefacts are both physical and functional objects as a functional object is any object that has a function." ,
                                      "Note that it is possible to model without explicitly using this class, as any object that has a function can be inferred to be a functional object." ,
                                      "This class can be used as a root class for functional classification of objects, including physical objects." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:FunctionalObject ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget "ISO 15926-2:2003 'functional_physical_object'" ;
   iof-av:explanatoryNote "ISO 15926-2:2003, p. 110, states, \"A functional_physical_object is a physical_object that has functional, rather than material, continuity as its basis for identity. Adjacent temporal parts of a functional_physical_object need not have common matter or energy, provided the matter or energy of each temporal part fulfils the same function.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/InanimatePhysicalObject
lis:InanimatePhysicalObject rdf:type owl:Class ;
                            rdfs:subClassOf lis:PhysicalObject ;
                            rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                            rdfs:label "InanimatePhysicalObject" ;
                            rdfs:seeAlso "ISO 15926-2:2003 'class_of_inanimate_physical_object'" ;
                            skos:example "A tool, a building, a vehicle, an instrument, a parking lot." ;
                            iof-av:naturalLanguageDefinition "A 'physical object' that is not living." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:InanimatePhysicalObject ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget "ISO 15926-2:2003 'class_of_inanimate_physical_object'" ;
   iof-av:explanatoryNote "ISO 15926-2:2003, p. 122: \"A class_of_inanimate_physical_object is a class_of_arranged\\-_individual whose members are not living.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/InformationObject
lis:InformationObject rdf:type owl:Class ;
                      rdfs:subClassOf lis:Object ;
                      owl:disjointWith lis:Location ,
                                       lis:Organization ,
                                       lis:PhysicalObject ;
                      rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                      rdfs:label "InformationObject" ;
                      rdfs:seeAlso obo:BFO_0000031 ,
                                   obo:IAO_0000030 ,
                                   "ISO 15926-2:2003 'class_of_information_object'" ;
                      skos:example "A report, a drawing, a P&ID diagram, a purchase order, a certificate, a database, a database record, a measurement datum, a unit of measure, an identifier, an algorithm, a programming language." ;
                      skos:scopeNote "The BFO class 'generically dependent continuant' represents the notion of a pattern that exists in at least one copy, e.g., \"the sequence of this protein molecule\". This is more general than 'information object', and not at present included in IDO.  'information object' is a subclass, with the added condition that the pattern 'is about' something." ;
                      iof-av:naturalLanguageDefinition "An object that captures information about something." ;
                      iof-av:usageNote "A common application of 'information object' is in representing facts about the vocabulary of the ontology itself. The OWL facility of \"punning\" treats OWL classes and properties as OWL individuals, enabling OWL object properties to be applied to them. In use cases that involve punning, the SKOS vocabulary is recommended to be used, with the SKOS classes 'concept', 'concept scheme', and 'collection'  as subclasses of 'information object'." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:InformationObject ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000031 ;
   iof-av:explanatoryNote "BFO_0000031 is 'generically dependent continuant'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:InformationObject ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:IAO_0000030 ;
   iof-av:explanatoryNote "IAO_0000030 is 'information content entity', a subclass of BFO_0000031 'generically dependent continuant' defined in the Information Artifact Ontology."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Instant
lis:Instant rdf:type owl:Class ;
            rdfs:subClassOf lis:InstantRegion ;
            rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
            rdfs:label "Instant" ;
            rdfs:seeAlso time:Instant ,
                         "ISO 15926-2:2003 'point_in_time'" ;
            skos:example "The moment a valve is closed, the time of a measurement as use for time-stamping, the moment an activity starts." ;
            iof-av:naturalLanguageDefinition "An instant region with no proper parts" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Instant ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget time:Instant ;
   iof-av:explanatoryNote "'instant' is defined in OWL Time as \"A temporal entity with zero extent or duration\"."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/InstantRegion
lis:InstantRegion rdf:type owl:Class ;
                  rdfs:subClassOf lis:TemporalRegion ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "InstantRegion" ;
                  rdfs:seeAlso obo:BFO_0000148 ;
                  skos:example "The moment a valve is closed, the instants of a series of measurements." ;
                  iof-av:naturalLanguageDefinition "A temporal region whose only parts are one or more points in time." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:InstantRegion ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000148 ;
   iof-av:explanatoryNote "obo:BFO_0000148 is 'zero-dimensional temporal region'"
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Interest
lis:Interest rdf:type owl:Class ;
             rdfs:subClassOf lis:Potential ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "Interest" ;
             skos:example "A plan to act, an approval of a survey." ;
             iof-av:naturalLanguageDefinition "A potential, the realization of which is of value for the bearer." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Interval
lis:Interval rdf:type owl:Class ;
             rdfs:subClassOf lis:IntervalRegion ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "Interval" ;
             rdfs:seeAlso obo:BFO_0000202 ,
                          dol:time-interval ,
                          time:Interval ,
                          "ISO 15926-2:2003 'period_in_time'" ;
             skos:example "The time an instrument has been in operation, the time during which a measurement was made." ;
             iof-av:naturalLanguageDefinition "A continuous period of time." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Interval ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000202 ;
   iof-av:explanatoryNote "BFO_0000202 is 'temporal interval'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Interval ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget time:Interval ;
   iof-av:explanatoryNote "'interval' is defined in OWL Time as \"A temporal entity with an extent or duration\"."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/IntervalRegion
lis:IntervalRegion rdf:type owl:Class ;
                   rdfs:subClassOf lis:TemporalRegion ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "IntervalRegion" ;
                   rdfs:seeAlso obo:BFO_0000038 ;
                   skos:example "Intermittent times of operation of a heater, maintenance periods at a plant, times that a milling machine is run, The Saturdays of 2011, the construction period for a plant modification" ;
                   iof-av:naturalLanguageDefinition "A temporal region whose only parts are one or more intervals in time." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:IntervalRegion ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000038 ;
   iof-av:explanatoryNote "BFO_0000038 is 'one-dimensional temporal region' in BFO-ISO."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/LineInSpace
lis:LineInSpace rdf:type owl:Class ;
                rdfs:subClassOf lis:SpatialLocation ;
                rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                rdfs:label "LineInSpace" ;
                skos:example "A line connecting two points with coordinates relative to the frame of reference, the path of a flexible pipe at 12:00 AM." ;
                iof-av:naturalLanguageDefinition "A spatial location consisting of one or more lines." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Location
lis:Location rdf:type owl:Class ;
             rdfs:subClassOf lis:Object ;
             owl:disjointWith lis:Organization ,
                              lis:PhysicalObject ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "Location" ;
             rdfs:seeAlso dol:space-region ,
                          "ISO 15926-2:2003 'spatial_location'" ;
             skos:example "An outdoor plant area, an opening in a wall, the space inside an enclosure" ;
             iof-av:naturalLanguageDefinition "An object that is a region in space." ;
             iof-av:usageNote "IDO is an anthropocentric ontology in the sense that it disregards complexities of the deep theories of the physical sciences that have only negligible impact at the standard industrial scale. For example, this means ignoring cosmological effects on the average industry and adopting a geocentric model of the universe where there exists a commonly agreed upon stationary earthly “spatial reference system”." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/MaterialCompositionQuality
lis:MaterialCompositionQuality rdf:type owl:Class ;
                               rdfs:subClassOf lis:Quality ;
                               rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                               rdfs:label "MaterialCompositionQuality" ;
                               skos:example "The steel grade of a cast-iron component, the plastic type of a wire sheathing." ;
                               iof-av:naturalLanguageDefinition "A quality that can be characterised in terms of chemical or material properties." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Object
lis:Object rdf:type owl:Class ;
           owl:disjointWith lis:Temporal ;
           rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
           rdfs:label "Object" ;
           rdfs:seeAlso obo:BFO_0000004 ,
                        dol:endurant ,
                        "ISO 15926-2:2003 'possible_individual'" ;
           skos:example "A process plant, a compressor, a wire, a person, an operator, a database record, an industry standard, a manual document, a site." ;
           iof-av:naturalLanguageDefinition "An entity that is not dependent on other entities for existence, and which persists through time." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Object ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000004 ;
   skos:scopeNote "In IDO, 'information object' is represented as a subclass of 'object'. According to the BFO literature, and applied in the Information Artifact Ontology and other BFO compliant ontologies, information artifacts are (multiply) dependent objects. a /sibling/ class to 'independent continuant' rather than a subclass, as used in IDO." ;
   iof-av:explanatoryNote "BFO_0000004 is 'independent continuant'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Object ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget dol:endurant ;
   iof-av:explanatoryNote "From the DOLCE description of 'endurant': \"The main characteristic of endurants is that all of them are independent essential wholes. ...\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Organism
lis:Organism rdf:type owl:Class ;
             rdfs:subClassOf lis:PhysicalObject ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "Organism" ;
             rdfs:seeAlso "ISO 15926-2:2003 'class_of_organism'" ;
             skos:example "Animal, plant, fungus, bacterium." ;
             iof-av:naturalLanguageDefinition "A physical object that is living." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Organization
lis:Organization rdf:type owl:Class ;
                 rdfs:subClassOf lis:Object ;
                 owl:disjointWith lis:PhysicalObject ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "Organization" ;
                 rdfs:seeAlso "ISO 15926-2:2003 'class_of_organization'" ;
                 skos:example "A standards body, a service team, a workgroup, a company" ;
                 iof-av:adaptedFrom <https://spec.industrialontologies.org/ontology/core/Core/Organization> ;
                 iof-av:naturalLanguageDefinition "An object comprising one or more persons who identify by some name and pursue a common set of plans and objectives." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Organization ;
   owl:annotatedProperty iof-av:adaptedFrom ;
   owl:annotatedTarget <https://spec.industrialontologies.org/ontology/core/Core/Organization> ;
   iof-av:explanatoryNote "Organization is a class in the IOF Core ontology."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Person
lis:Person rdf:type owl:Class ;
           rdfs:subClassOf lis:Organism ;
           rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
           rdfs:label "Person" ;
           rdfs:seeAlso "ISO 15926-2:2003 'class_of_person'" ;
           skos:example "A human being." ;
           skos:scopeNote "In an RDL, subclasses of 'person' will typically require 'role' restrictions to be considered fully explicit. For example, 'maintenance engineer' will be a subclass of 'person', as every engineer is a person. To capture what a maintenance engineer does, a role restriction can say that any member is the bearer of an engineering role, and what the role amounts to will be represented by the kinds of activities that count as realizations of the role." ;
           iof-av:naturalLanguageDefinition "An organism that is a human." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Phase
lis:Phase rdf:type owl:Class ;
          rdfs:subClassOf lis:PhysicalObject ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty lis:hasQuality ;
                            owl:someValuesFrom lis:PhaseQuality
                          ] ;
          rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
          rdfs:label "Phase" ;
          rdfs:seeAlso "ISO 15926-2:2003 'phase'" ;
          skos:example "Solid object, liquid object, gaseous object." ;
          iof-av:naturalLanguageDefinition "A physical object with a distinct and homogeneous form." ;
          iof-av:usageNote "An RDL can include classes that categorise individuals according to material phase. This class is suitable as the top node of such a taxonomy." ,
                           "Definition from Oxford English Dictionary." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/PhaseQuality
lis:PhaseQuality rdf:type owl:Class ;
                 rdfs:subClassOf lis:Quality ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "PhaseQuality" ;
                 skos:example "The liquid quality of an amount of molten steel, the solid quality of a steel gasket." ;
                 iof-av:naturalLanguageDefinition "A 'quality' that can be characterised in terms of material phase." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact
lis:PhysicalArtefact rdf:type owl:Class ;
                     rdfs:subClassOf lis:PhysicalObject ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "PhysicalArtefact" ;
                     skos:example "a pressure transmitter, a process plant, a wrench, a computer." ;
                     iof-av:naturalLanguageDefinition "A 'physical object' that has been created as the result of deliberate activity." ;
                     iof-av:usageNote "A typical RDL includes classes that represent industrial item types, such as equipment, devices, assemblies, buildings, and products, among other elements. This class is suitable as the top node in a taxonomy of such classes." ,
                                      "The superclass of 'physical artefact' is not 'inanimate physical object', in order to allow for artificially made organisms." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalObject
lis:PhysicalObject rdf:type owl:Class ;
                   rdfs:subClassOf lis:Object ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "PhysicalObject" ;
                   rdfs:seeAlso obo:BFO_0000040 ,
                                dol:physical-object ,
                                "ISO 15926-2:2003 'physical_object'" ;
                   skos:example "A wall, a fluid stream, a welder, a printed manual, a seafloor." ;
                   iof-av:naturalLanguageDefinition "An object that occupies space and possesses mass." ;
                   iof-av:usageNote "Installed software is considered a physical object." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:PhysicalObject ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000040 ;
   iof-av:explanatoryNote "BFO_0000040 is 'material entity'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:PhysicalObject ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget "ISO 15926-2:2003 'physical_object'" ;
   iof-av:explanatoryNote "IDO asserts that 'physical object' and 'activity' are disjunct classes. In contrast to this, and according to a 4D approach, ISO 15926-2:2003, p. 26, states that \"physical_object and activity are not mutually exclusive. A possible_individual can be both\"."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalQuantity
lis:PhysicalQuantity rdf:type owl:Class ;
                     rdfs:subClassOf lis:Quality ;
                     rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                     rdfs:label "PhysicalQuantity" ;
                     rdfs:seeAlso obo:PATO_0001018 ,
                                  qudt:QuantityKind ,
                                  dol:physical-quality ,
                                  om:Quantity ,
                                  ssn:ObservableProperty ,
                                  "ISO 15926-2:2003 'property'" ;
                     skos:example "The mass of a bar of steel, the temperature of a medium, the inner diameter of a pipe, the lift height of a crane, the head (lift height) of a pump." ;
                     iof-av:naturalLanguageDefinition "A quality that can be quantified by measurement." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:PhysicalQuantity ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:PATO_0001018 ;
   iof-av:explanatoryNote "PATO_0001018 is 'physical quality', defined in the Information Artifact Ontology as \"A quality of a physical entity that exists through action of continuants at the physical level of organisation in relation to other entities.\" Note that this is distinct from 'physical object quality'; see annotation to lis:Quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:PhysicalQuantity ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget qudt:QuantityKind ;
   iof-av:explanatoryNote "QUDT explains 'quantity kind' as, \"any observable property that can be measured and quantified numerically. Familiar examples include physical properties such as length, mass, time, force, energy, power, electric charge, etc. Less familiar examples include currency, interest rate, price to earning ratio, and information capacity.\""
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:PhysicalQuantity ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget dol:physical-quality ;
   iof-av:explanatoryNote "DOLCE defines 'physical-quality' as, \"A quality inherent in a physical endurant.\""
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:PhysicalQuantity ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget om:Quantity ;
   iof-av:explanatoryNote "OM2 explains 'quantity' as, \"A quantity is a representation of a quantifiable (standardised) aspect (such as length, mass, and time) of a phenomenon (e.g., a star, a molecule, or a food product). Quantities are classified according to similarity in their (implicit) metrological aspect, e.g. the length of my table and the length of my chair are both classified as length.\""
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:PhysicalQuantity ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget ssn:ObservableProperty ;
   iof-av:explanatoryNote "SSN offers the following examples for ObservableProperty, a subclass of Property: \"The height of a tree, the depth of a water body, or the temperature of a surface are examples of observable properties, while the value of a classic car is not (directly) observable but asserted.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/PlaneInSpace
lis:PlaneInSpace rdf:type owl:Class ;
                 rdfs:subClassOf lis:SpatialLocation ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "PlaneInSpace" ;
                 skos:example "The midway horizontal plane of a volume given by coordinates, the plane of a moving work platform at 12:00" ;
                 iof-av:naturalLanguageDefinition "A spatial location that is a two-dimensional plane." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/PointInSpace
lis:PointInSpace rdf:type owl:Class ;
                 rdfs:subClassOf lis:SpatialLocation ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "PointInSpace" ;
                 skos:example "The location of a probe at a given point in time" ;
                 iof-av:naturalLanguageDefinition "A spatial location that has zero dimension with no proper parts." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Potential
lis:Potential rdf:type owl:Class ;
              rdfs:subClassOf lis:Dependent ;
              owl:disjointWith lis:Quality ;
              rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
              rdfs:label "Potential" ;
              skos:altLabel "Realizable Entity" ;
              skos:example "The sealing function of a gasket, the disposition of a steel bar to corrode." ;
              iof-av:adaptedFrom obo:BFO_0000017 ;
              iof-av:naturalLanguageDefinition "A dependent entity that can potentially be realised through participation in an activity." ;
              iof-av:usageNote "Use OWL property chains to enforce constraints on how the bearer needs to participate in order for an activity to count as a realization." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Potential ;
   owl:annotatedProperty iof-av:adaptedFrom ;
   owl:annotatedTarget obo:BFO_0000017 ;
   iof-av:explanatoryNote "BFO_0000017 is 'realizable entity'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Quality
lis:Quality rdf:type owl:Class ;
            rdfs:subClassOf lis:Dependent ;
            rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
            rdfs:label "Quality" ;
            rdfs:seeAlso obo:BFO_0000019 ,
                         obo:PATO_0000001 ,
                         obo:PATO_0001241 ,
                         dol:quality ,
                         ssn:ActuatableProperty ,
                         ssn:Property ,
                         "ISO 15926-2:2003 'property'" ;
            skos:example "The temperature of a fluid stream, the tensile strength of a bolt, the length of a pipeline, the colour of a surface coating, the familiarity of a specialist with a modification procedure, the quality of a window of being open or closed." ;
            iof-av:explanatoryNote "The class Quality and its subclass PhysicalQuantity are inspired by corresponding classes included in the DOLCE and BFO upper ontologies." ;
            iof-av:naturalLanguageDefinition "A dependent entity that is present any time its bearer exists." ;
            iof-av:usageNote "Qualities are in general subject to change over the lifetime of the bearer. The main IDO device for representing quality changes is through 'datum' individuals: see lis:qualityQuantifiedAs." ,
                             "Qualities should only be used for root properties such as voltage, pressure, etc. Where there are variants such as nominal, rated, actual voltage, modellers should use lis:Quality for voltage and use a subclass of lis:QualityDatum for the moderator (\"nominal\", etc.)" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Quality ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000019 ;
   iof-av:explanatoryNote "BFO_0000019 is 'quality'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Quality ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:PATO_0000001 ;
   iof-av:explanatoryNote "PATO_0000001 is 'quality'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Quality ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:PATO_0001241 ;
   iof-av:explanatoryNote "PATO_0001241 is 'physical object quality', defined in the Information Artifact Ontology as \"A quality which inheres in a continuant\"."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Quality ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget dol:quality ;
   iof-av:explanatoryNote "DOLCE describes qualities as follows: \"Qualities can be seen as the basic entities we can perceive or measure: shapes, colors, sizes, sounds, smells, as well as weights, lengths, electrical charges... 'Quality' is often used as a synonymous of 'property', but this is not the case in this upper ontology: qualities are particulars, properties are universals.  Qualities inhere to entities: every entity (including qualities themselves) comes with certain qualities, which exist as long as the entity exists.\""
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Quality ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget ssn:ActuatableProperty ;
   iof-av:explanatoryNote "SSN offers the following as an example for ActuatableProperty, a subclass of Property: \"A window actuator acts by changing the state between a frame and a window. The ability of the window to be opened and closed is its ActuatableProperty.\""
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Quality ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget ssn:Property ;
   iof-av:explanatoryNote "SSN defines 'Property' as follows (2017): \"A quality of an entity. An aspect of an entity that is intrinsic to and cannot exist without the entity.\""
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Quality ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget "ISO 15926-2:2003 'property'" ;
   iof-av:explanatoryNote "In ISO 15926-2:2003, the term \"quality or characteristic\" is used to explain what the entity type 'property' represents (clause 5.2.26.5, notes 1 and 2). Note 2 reads, \"The types of characteristic or quality, such as temperature or density, are instances of class_of_property.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/QualityDatum
lis:QualityDatum rdf:type owl:Class ;
                 rdfs:subClassOf lis:InformationObject ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty lis:quantifiesQuality ;
                                   owl:someValuesFrom lis:Quality
                                 ] ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "QualityDatum" ;
                 rdfs:seeAlso obo:IAO_0000109 ,
                              lis:TemporalDatum ;
                 skos:example "10 volts, high (of pressure), low (of temperature), category 3 (as used to rate the strength 'quality' of a storm), 3 MB (a file size), qualifications, grades." ;
                 skos:scopeNote "Introduce subclasses of 'quality datum' in RDL to distinguish categories of data, such as nominal versus measured values." ;
                 iof-av:explanatoryNote "This class is inspired by the class \"measurement datum\" of the Information Artifact Ontology (IAO). The change of wording from \"measurement\" to \"quality\" is intended to support cases where measurement is not involved, such as with nominal values." ;
                 iof-av:naturalLanguageDefinition "An information object that quantifies a quality." ;
                 iof-av:usageNote "Quantification may be on nominal, ordinal, and other scales." ,
                                  "This class may be used for data that don't fit the restriction to \"single unit, single number\" of 'scalar quantity datum', including data employing vectors instead of numbers, and conventional categories like \"high\" and \"medium\"." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:QualityDatum ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:IAO_0000109 ;
   iof-av:explanatoryNote "IAO_0000109 is 'measurement datum', a class in the Information Artifact Ontology."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Role
lis:Role rdf:type owl:Class ;
         rdfs:subClassOf lis:Potential ;
         rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
         rdfs:label "Role" ;
         rdfs:seeAlso lis:hasRole ,
                      "ISO 15926-2:2003 'role', 'role_and_domain'" ;
         skos:example "The role an individual person takes in a work situation, such as a manager. A student role." ,
                      "The role of an interior space (a 'site') as a meeting room is realized when it serves as the space for conducting meetings. The site may be assigned a storage room role at a different time." ;
         skos:scopeNote "This class is intended to serve the same purpose as the ISO 15926-2:2003 'role' entity type, as well as the same-named BFO class (BFO_0000023)." ;
         iof-av:adaptedFrom obo:BFO_0000023 ;
         iof-av:naturalLanguageDefinition "A potential that is assigned to an object." ;
         iof-av:usageNote "As with any 'potential', the existence of a role is dependent on its bearer. A particular meeting room's role may therefore not be transferred to a different room; a different role individual with similar classification would be needed." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Role ;
   owl:annotatedProperty iof-av:adaptedFrom ;
   owl:annotatedTarget obo:BFO_0000023 ;
   iof-av:explanatoryNote "BFO_0000023 is 'role'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/ScalarQuantityDatum
lis:ScalarQuantityDatum rdf:type owl:Class ;
                        rdfs:subClassOf lis:QualityDatum ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty lis:datumUOM ;
                                          owl:someValuesFrom lis:UnitOfMeasure
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty lis:quantifiesQuality ;
                                          owl:someValuesFrom lis:PhysicalQuantity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty lis:datumValue ;
                                          owl:someValuesFrom rdfs:Literal
                                        ] ;
                        rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                        rdfs:label "ScalarQuantityDatum" ;
                        rdfs:seeAlso obo:IAO_0000032 ,
                                     qudt:QuantityValue ,
                                     om:Measure ;
                        skos:example "10 kilograms, 220 volt." ;
                        iof-av:naturalLanguageDefinition "A quality datum that quantifies a physical quantity with a numeric value and a scale." ;
                        iof-av:usageNote "A scalar quantity datum has a unique unit of measure and a unique numeric value. This class is inspired by the class \"scalar measurement datum\" of the Information Artifact Ontology." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:ScalarQuantityDatum ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:IAO_0000032 ;
   iof-av:explanatoryNote "IAO_0000032 is 'scalar measurement datum', a class in the Information Artifact Ontology."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:ScalarQuantityDatum ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget qudt:QuantityValue ;
   iof-av:explanatoryNote "QUDT describes 'quantity value' as follows. \"A Quantity Value expresses the magnitude and kind of a quantity and is given by the product of a numerical value n and a unit of measure U. The number multiplying the unit is referred to as the numerical value of the quantity expressed in that unit.\""
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:ScalarQuantityDatum ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget om:Measure ;
   iof-av:explanatoryNote "OM 2 describes 'measure' as follows. \"A measure combines a number to a unit of measure. For example, '3 m' is a measure.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Scale
lis:Scale rdf:type owl:Class ;
          rdfs:subClassOf lis:UnitOfMeasure ;
          rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
          rdfs:label "Scale" ;
          rdfs:seeAlso qudt:Scale ,
                       om:Scale ,
                       "ISO 15926-2:2003 'scale'" ;
          skos:example "centimetre, kilogram per minute, degree Celsius, lunar distance, kilo-lines of code" ;
          skos:scopeNote "Arguably, IDO conflates the notions of \"unit of measure\" and \"scale\" in an unhealthy way. While a unit of measure is a definite magnitude, a scale arises from fixing a number range to express multiples of the unit of measure. One may argue that a unit of measure has an implicit scale, obtained by multiplying the unit by any number; this will then allow for undefined or meaningless expressions like \"minus 10 Kelvin\"." ;
          iof-av:naturalLanguageDefinition "A unit of measure that, when paired with a number, unambiguously describes the magnitude of a physical quantity." ;
          iof-av:usageNote "'scale' corresponds to the common sense notion of unit of measure which unambiguously defines the magnitude of the measure." ,
                           "OWL data ranges can capture the acceptable numerical range for a scale. For instance, the 'datum value' of any 'quality datum' that has Celsius as 'datum uom' can be limited to the range from -273.15 upwards to infinity." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Scale ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget qudt:Scale ;
   iof-av:explanatoryNote "QUDT provides the following subclasses of 'scale': 'Enumeration scale', 'Interval scale', 'Nominal scale', 'Ordinal scale', 'Ratio scale'. Note that the notion of nominal scales diverges in being a coding scheme, with numbers not implying relative magnitude."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/ShapeQuality
lis:ShapeQuality rdf:type owl:Class ;
                 rdfs:subClassOf lis:Quality ;
                 rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                 rdfs:label "ShapeQuality" ;
                 skos:example "The flat shape of a surface feature, the cylindrical shape of a piece of pipe." ;
                 iof-av:naturalLanguageDefinition "A quality that can be characterised in terms of geometry." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Site
lis:Site rdf:type owl:Class ;
         rdfs:subClassOf lis:Location ;
         owl:disjointWith lis:SpatialLocation ;
         rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
         rdfs:label "Site" ;
         rdfs:seeAlso obo:BFO_0000029 ,
                      lis:siteDeterminedBy ,
                      "ISO 15926-2:2003 'spatial_location'" ;
         skos:example "A flight deck, the inside of a manifold, the hold of a ship, a centre of gravity, an outside area" ;
         skos:scopeNote "Locations such as countries and cities are also considered sites." ,
                        "The position of a 'site' follows the position of the 'physical object' by which it is demarcated." ;
         iof-av:explanatoryNote "This class is inspired by the BFO class 'site'." ;
         iof-av:naturalLanguageDefinition "A location determined in relation to one or more physical objects." ;
         iof-av:usageNote "The utility of a 'site' may be represented by assigning one or more 'role's, such as 'front desk role', 'storage space role', or 'entryway role'." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Site ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000029 ;
   iof-av:explanatoryNote "BFO_0000029 is 'site'"
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/SpatialLocation
lis:SpatialLocation rdf:type owl:Class ;
                    rdfs:subClassOf lis:Location ;
                    rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                    rdfs:label "SpatialLocation" ;
                    rdfs:seeAlso obo:BFO_0000006 ,
                                 "ISO 15926-2:2003 'spatial_location'" ;
                    skos:example "The cube-shaped region extending 1 metre in each direction from origo, the line extending 10 metres from origo along the z axis, two points with coordinates on a two-dimensional plane; the location of a container at 10:00 AM." ;
                    skos:scopeNote "The position of a 'spatial location' is fixed (relative to the frame of reference); it is not dependent on changing positions of 'physical object's." ;
                    iof-av:naturalLanguageDefinition "A location defined relative to a spatial reference system." ;
                    iof-av:usageNote "As with 'spatiotemporal region', a spatial location need not be connected; for example, a location may consist in several cube-shaped regions." ,
                                     "The subclasses 'point in space', 'line in space', 'plane in space', and 'volume in space' are all defined as singular: for example, a 'point in space' individual may not have multiple points as parts. This, in contrast to the analogous BFO classes 'one-dimensional spatial region', etc., which are all defined as plural, allowing for disconnected parts." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:SpatialLocation ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000006 ;
   iof-av:explanatoryNote "BFO_0000006 is 'spatial region'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/SpatiotemporalRegion
lis:SpatiotemporalRegion rdf:type owl:Class ;
                         rdfs:subClassOf lis:Temporal ;
                         owl:disjointWith lis:TemporalRegion ;
                         rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                         rdfs:label "SpatiotemporalRegion" ;
                         rdfs:seeAlso obo:BFO_0000011 ,
                                      dol:spatio-temporal-region ;
                         skos:example "The spatiotemporal region occupied by the fluid contents of a vessel over a period of time, the spatiotemporal region occupied by a pipeline inspection device (pig) during an inspection." ;
                         skos:scopeNote "An 'activity' occupies a 'spatiotemporal region'. Note that the spatiotemporal region may have temporal gaps." ;
                         iof-av:naturalLanguageDefinition "A temporal entity that extends in space and time." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:SpatiotemporalRegion ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000011 ;
   iof-av:explanatoryNote "BFO_0000011 is 'spatiotemporal region'."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Specified
lis:Specified rdf:type owl:Class ;
              rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
              rdfs:label "Specified" ;
              rdfs:seeAlso lis:Actual ;
              skos:example "A \"tag\" individual, a function of a tag, an activity as characterised in process design." ;
              iof-av:explanatoryNote "A 'specified' entity is typically an individual that represents the asset as designed, with restrictions that capture requirements." ,
                                     "A 'specified' individual may be matched with an individual representing an 'actual' individual. Naming for the according relations may include: 'installed as' for physical objects, and 'executed as' for activities." ;
              iof-av:naturalLanguageDefinition "An entity that is part of an engineering specification." ;
              iof-av:usageNote "This class is not intended to be used directly, but only for serving as the domain of 'implements' and similar relations. The disjointness axiom serves to block iterated chains of 'implements', etc., relationships." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Stream
lis:Stream rdf:type owl:Class ;
           rdfs:subClassOf lis:InanimatePhysicalObject ;
           rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
           rdfs:label "Stream" ;
           rdfs:seeAlso "ISO 15926-2:2003 'stream'" ;
           skos:example "A stream of fluid in a pipeline, electricity in an electrical wire, ore moving on a conveyor belt." ;
           iof-av:naturalLanguageDefinition "An inanimate physical object consisting of energy or homogeneous parts that flow through a system." ;
           iof-av:usageNote "The class 'stream' is intended to be used for flows of material or energy, in accordance with conventional use. There is an abundance of cases where use of the term \"stream\" can be called into question, as in, is a stream of electricity really moving; how many cars are needed to participate before it is properly called a \"flow\" of cars; while a flow of sand is a stream, maybe a succession of rolling rocks would not qualify." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Stream ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget "ISO 15926-2:2003 'stream'" ;
   iof-av:explanatoryNote "ISO 15926-2:2003, p. 112, states, \"A stream is a physical_object that is material or energy moving along a path, where the path is the basis of identity and may be constrained. The stream consists of the temporal parts of those things that are in the stream whilst they are in it.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/System
lis:System rdf:type owl:Class ;
           rdfs:subClassOf lis:FunctionalObject ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty lis:hasFunctionalPart ;
                             owl:someValuesFrom lis:FunctionalObject
                           ] ;
           rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
           rdfs:label "System" ;
           rdfs:seeAlso lis:functionalPartOf ,
                        ssn:System ;
           skos:example "An electrical network, an HVAC system, a pumping system, a compressor." ;
           iof-av:naturalLanguageDefinition "A 'functional object' with one or more functional parts whose functions contribute to its function." ;
           iof-av:usageNote "Most industrial assets are both 'system' and 'inanimate physical object'. When modelling, e.g., a pump system, that system will be an 'inanimate physical object', with the pump part related to the pump system by 'has functional part'. The domain and range restrictions on 'has functional part' then imply that the pump system has type 'system', and the pump has type 'functional object'." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:System ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget ssn:System ;
   iof-av:explanatoryNote "The SSN definition of 'System' (2017): \"System is a unit of abstraction for pieces of infrastructure that implement Procedures. A System may have components, its subsystems, which are other Systems.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/Temporal
lis:Temporal rdf:type owl:Class ;
             rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
             rdfs:label "Temporal" ;
             rdfs:seeAlso obo:BFO_0000003 ,
                          dol:perdurant ;
             skos:altLabel "Temporal Entity" ;
             skos:example "A moment in time, a period of time, an activity or process, a beginning, a closing event." ;
             iof-av:naturalLanguageDefinition "An entity that is part of time or takes place in time." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Temporal ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000003 ;
   iof-av:explanatoryNote "BFO_0000003 is 'occurrent'."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:Temporal ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget dol:perdurant ;
   iof-av:explanatoryNote "From the DOLCE description of 'perdurant': \"Perdurants (AKA occurrences) comprise what are variously called events, processes, phenomena, activities and states.\""
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/TemporalDatum
lis:TemporalDatum rdf:type owl:Class ;
                  rdfs:subClassOf lis:InformationObject ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty lis:quantifiesTemporalRegion ;
                                    owl:someValuesFrom lis:TemporalRegion
                                  ] ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "TemporalDatum" ;
                  rdfs:seeAlso lis:QualityDatum ;
                  skos:example "An observed duration of 20 hours for a well drilling activity, an estimated lag of 5 minutes between two process steps, a calculated elapsed time of 3 days for a maintenance campaign." ;
                  iof-av:explanatoryNote "'temporal datum' is the temporal counterpart of 'quality datum'. Where a 'quality datum' quantifies a 'quality' of an object, a 'temporal datum' quantifies a 'temporal region' associated with an activity. Multiple temporal datums may be assigned to the same temporal region, for example representing observed, estimated, and calculated duration values." ;
                  iof-av:naturalLanguageDefinition "An information object that quantifies a temporal region." ;
                  iof-av:usageNote "Introduce subclasses of 'temporal datum' in RDL to distinguish categories of temporal data, such as observed versus estimated duration." .


###  http://rds.posccaesar.org/ontology/lis14/rdl/TemporalRegion
lis:TemporalRegion rdf:type owl:Class ;
                   rdfs:subClassOf lis:Temporal ;
                   rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                   rdfs:label "TemporalRegion" ;
                   rdfs:seeAlso obo:BFO_0000008 ,
                                dol:temporal-region ;
                   skos:example "The moment a valve is closed, upstart time for a motor, the length of time that a bolt has been installed, intervals between maintenance." ;
                   skos:scopeNote "A 'temporal region' plays a role analogous to that of a quantity: it is an entity to which multiple temporal datums may be assigned, such as 'observed', 'estimated', or 'calculated' duration values. This avoids treating time as a physical quality of an object while preserving a modelling style parallel to the quantity--datum pattern in IDO." ;
                   iof-av:naturalLanguageDefinition "A temporal entity that extends only in time." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:TemporalRegion ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:BFO_0000008 ;
   iof-av:explanatoryNote "BFO_0000008 is 'temporal region'"
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/UnitOfMeasure
lis:UnitOfMeasure rdf:type owl:Class ;
                  rdfs:subClassOf lis:InformationObject ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "UnitOfMeasure" ;
                  rdfs:seeAlso obo:UO_0000000 ,
                               om:Unit ;
                  skos:example "carton, cup, temperature degree, instances of scales" ;
                  iof-av:naturalLanguageDefinition "An information object that defines the magnitude of a 'quality', adopted by convention or by law." ;
                  iof-av:usageNote "'unit of measure' may be used when there is ambiguity about the scale of the measure." .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:UnitOfMeasure ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget obo:UO_0000000 ;
   iof-av:explanatoryNote "UO_0000000 is 'unit', a class in the OBO Units of measure ontology."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource lis:UnitOfMeasure ;
   owl:annotatedProperty rdfs:seeAlso ;
   owl:annotatedTarget om:Unit ;
   iof-av:explanatoryNote "'unit' is a class in the Ontology of units of Measure (OM 2)."
 ] .


###  http://rds.posccaesar.org/ontology/lis14/rdl/VolumeInSpace
lis:VolumeInSpace rdf:type owl:Class ;
                  rdfs:subClassOf lis:SpatialLocation ;
                  rdfs:isDefinedBy <http://rds.posccaesar.org/ontology/lis14/ont/core> ;
                  rdfs:label "VolumeInSpace" ;
                  skos:example "A volume designated for 3D engineering at a point in time, a box-shaped volume determined by coordinates in a 3D frame of reference; the extent of a gas leak at 12:00" ;
                  iof-av:naturalLanguageDefinition "A spatial location that is a three-dimensional volume." .


