<http://rds.posccaesar.org/ontology/lis14/ont/core> rdf:type owl:Ontology ;
                                                     owl:versionIRI <http://rds.posccaesar.org/ontology/lis14/ont/core/4.2> ;
                                                     dc:rights "Copyright POSC Caesar Association" ;
                                                     dcterms:contributor <https://orcid.org/0000-0001-8076-7460> ,
                                                                         <https://orcid.org/0000-0002-4174-4634> ,
                                                                         <https://orcid.org/0000-0002-5509-8899> ,
                                                                         <https://orcid.org/0000-0002-6228-1317> ,
                                                                         <https://orcid.org/0000-0002-7167-7321> ,
                                                                         <https://orcid.org/0000-0002-7336-3932> ,
                                                                         <https://orcid.org/0000-0002-9736-8316> ,
                                                                         <https://orcid.org/0009-0000-2521-1021> ,
                                                                         <https://orcid.org/0009-0003-7263-9946> ,
                                                                         <https://orcid.org/0009-0005-8440-2238> ,
                                                                         <https://orcid.org/0009-0006-6957-0847> ,
                                                                         <https://orcid.org/0009-0008-9403-4872> ,
                                                                         <https://orcid.org/0009-0009-4214-0355> ;
                                                     dcterms:creator <https://orcid.org/0000-0002-7167-7321> ;
                                                     dcterms:description "The Industrial Data Ontology (IDO) is a Web Ontology Language (OWL) ontology. IDO is intended for building vocabularies and managing models which employ reference data libraries and exploit OWL DL. IDO is intended for use in all life cycle phases of industrial assets and processes." ;
                                                     dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
                                                     dcterms:modified "2026-04-10"^^xsd:date ;
                                                     dcterms:publisher <https://www.posccaesar.org> ;
                                                     dcterms:title "Industrial Data Ontology" ;
                                                     pav:hasEarlierVersion <http://rds.posccaesar.org/ontology/lis14/ont/core/1.0> ,
                                                                           <http://rds.posccaesar.org/ontology/lis14/ont/core/2.0> ,
                                                                           <http://rds.posccaesar.org/ontology/lis14/ont/core/3.0> ,
                                                                           <http://rds.posccaesar.org/ontology/lis14/ont/core/4.0> ,
                                                                           <http://rds.posccaesar.org/ontology/lis14/ont/core/4.1> ;
                                                     pav:lastUpdateOn "2026-04-10T16:00:00Z"^^xsd:dateTime ;
                                                     pav:previousVersion <http://rds.posccaesar.org/ontology/lis14/ont/core/4.1> ;
                                                     rdfs:label "Industrial Data Ontology" ;
                                                     owl:versionInfo "4.2 FDIS proposal submitted April 2026" .

