@prefix pump: <https://nlp-tlp.org/ontology/pump/rdl/> .
@prefix pump_rule: <https://nlp-tlp.org/ontology/pump/rule/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://nlp-tlp.org/ontology/pump/rule/core> a owl:Ontology ;
    owl:imports <http://rds.posccaesar.org/ontology/lis14/ont/core/4.2> ;
    owl:imports <https://nlp-tlp.org/ontology/pump/ont/core> ;
    owl:versionIRI <https://nlp-tlp.org/ontology/pump/rule/core/1.0.0> ;
    dcterms:title "Pump Ontology Rule Library" ;
    dcterms:licence "Apache Licence 2.0" ;
    dcterms:contributor "https://orcid.org/0000-0002-7336-3932" ;
    dcterms:description "Axioms for the pump ontology"@en ;
    rdfs:label "Pump Ontology Rule Library"@en .

#################################################################
#    Annotation properties
################################################################# 


#################################################################
#    Axioms
################################################################# 

pump:DoubleSuctionImpeller owl:disjointWith pump:SingleSuctionImpeller .

pump:PositiveDisplacementPump owl:disjointWith pump:RotordynamicPump .

pump:PumpWithDoubleActingStroke owl:disjointWith pump:PumpWithSingleActingStroke .

pump:PumpWithMultiStage owl:disjointWith pump:PumpWithSingleStage .

pump:ReciprocatingPump owl:disjointWith pump:RotaryPDPump .

#################################################################
#    AllDisjointClasses
################################################################# 

[] a owl:AllDisjointClasses ;
    owl:members ( pump:PumpWithDuplexDoubleCylinder pump:PumpWithSimplexSingleCylinder pump:PumpWithTriplexTripleCylinder ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pump:PumpDoubleVolute pump:PumpMultiVolute pump:PumpSingleVolute ) .


[] a owl:AllDisjointClasses ;
    owl:members ( pump:AxialFlowPump pump:CentrifugalPump pump:MixedFlowPump ) .


[] a owl:AllDisjointClasses ;
    owl:members ( pump:ClosedImpeller pump:OpenImpeller pump:SemiOpenImpeller ) .

#################################################################
#    Object property restrictions
#################################################################   

pump:hasAssembledPumpPart rdfs:domain pump:Pump ;
    rdfs:range pump:PumpPart .

pump:hasPumpFeature rdfs:domain [ a owl:Class ;
            owl:unionOf ( pump:Pump pump:PumpPart ) ] ;
    rdfs:range pump:PumpFeature .




