<?xml version="1.0"?>
<rdf:RDF xmlns="https://nlp-tlp.org/ontology/pump/ont/core#"
     xml:base="https://nlp-tlp.org/ontology/pump/ont/core"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ont="https://nlp-tlp.org/ontology/pump/ont/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:pav="http://purl.org/pav/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdl="http://rds.posccaesar.org/ontology/lis14/rdl/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:pump="https://www.nlp-tlp.org/ontology/pump/rdl/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:rdl1="https://nlp-tlp.org/ontology/pump/rdl/"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:pump-ont="https://www.nlp-tlp.org/ontology/pump/ont/"
     xmlns:AnnotationVocabulary="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/">
    <owl:Ontology rdf:about="https://nlp-tlp.org/ontology/pump/ont/core">
        <owl:versionIRI rdf:resource="https://nlp-tlp.org/ontology/pump/ont/core/1.0.0"/>
        <owl:imports rdf:resource="http://rds.posccaesar.org/ontology/lis14/ont/core/4.2"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://nlp-tlp.org/ontology/pump/ont/ISO15926_ID -->

    <owl:AnnotationProperty rdf:about="https://nlp-tlp.org/ontology/pump/ont/ISO15926_ID"/>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/ISO15926_URI -->

    <owl:AnnotationProperty rdf:about="https://nlp-tlp.org/ontology/pump/ont/ISO15926_URI"/>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/ISO15926_desc -->

    <owl:AnnotationProperty rdf:about="https://nlp-tlp.org/ontology/pump/ont/ISO15926_desc"/>
    


    <!-- https://nlp-tlp.org/ontology/pump/ont/ISO15926_name -->

    <owl:AnnotationProperty rdf:about="https://nlp-tlp.org/ontology/pump/ont/ISO15926_name"/>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/HI_ID -->

    <owl:AnnotationProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/HI_ID">
        <rdfs:comment xml:lang="en">Hydraulic Institute ID for this class</rdfs:comment>
        <rdfs:label xml:lang="en">HI ID</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/ISO15926_ID -->

    <owl:AnnotationProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/ISO15926_ID">
        <rdfs:comment xml:lang="en">ISO 15926-4 unique number for this class</rdfs:comment>
        <rdfs:label xml:lang="en">ISO 15926-4 ID</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/ISO15926_URI -->

    <owl:AnnotationProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/ISO15926_URI">
        <rdfs:comment xml:lang="en">15926-4 URI for this class</rdfs:comment>
        <rdfs:label xml:lang="en">ISO 15926-4 URI</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/ISO15926_desc -->

    <owl:AnnotationProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/ISO15926_desc">
        <rdfs:comment xml:lang="en">15926-4 description for this class</rdfs:comment>
        <rdfs:label xml:lang="en">ISO 15926-4 description</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/ISO15926_name -->

    <owl:AnnotationProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/ISO15926_name">
        <rdfs:comment xml:lang="en">15926-4 name for this class</rdfs:comment>
        <rdfs:label xml:lang="en">ISO 15926-4 name</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/hasBase -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/hasBase">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/hasBearing -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/hasBearing">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/hasCasing -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/hasCasing">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/hasCasingLiner -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/hasCasingLiner">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/hasImpeller -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/hasImpeller">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/hasPiston -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/hasPiston">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/hasShaft -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/hasShaft">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/hasShaftSeal -->

    <owl:ObjectProperty rdf:about="https://nlp-tlp.org/ontology/pump/rdl/hasShaftSeal">
        <rdfs:subPropertyOf rdf:resource="http://rds.posccaesar.org/ontology/lis14/rdl/hasAssembledPart"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact -->

    <owl:Class rdf:about="http://rds.posccaesar.org/ontology/lis14/rdl/PhysicalArtefact"/>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/AxialFlowImpeller -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/AxialFlowImpeller">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerDesign"/>
        <rdfs:label xml:lang="en">Axial flow impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/AxialFlowPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/AxialFlowPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotordynamicPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute axial-flow pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Axial flow pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic pump in which the impeller causes liquid to flow mainly parallel to the pump shaft</skos:definition>
        <ont:ISO15926_ID>7320</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/AXIAL_FLOW_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>An &lt;AXIAL FLOW PUMP&gt; is a &lt;CENTRIFUGAL PUMP&gt; that is provided with an axial flow impeller to generate relatively low head at large flows</ont:ISO15926_desc>
        <ont:ISO15926_name>AXIAL FLOW PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/CasingAxialSplit -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/CasingAxialSplit">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpSplitCasing"/>
        <rdfs:label xml:lang="en">Casing axial split</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/CasingRadialSplit -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/CasingRadialSplit">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpSplitCasing"/>
        <rdfs:label xml:lang="en">Casing radial split</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/CentrifugalPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/CentrifugalPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotordynamicPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute centrifugal pump terminology, with API 610 / ISO 13709 applying centrifugal pump configuration categories.</rdfs:comment>
        <rdfs:label xml:lang="en">Centrifugal pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic pump in which liquid enters the impeller near the axis of rotation and is discharged primarily by centrifugal action</skos:definition>
        <ont:ISO15926_ID>7436</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/CENTRIFUGAL_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;CENTRIFUGAL PUMP&gt; is an &lt;ARTEFACT&gt; and a &lt;PUMP&gt; in which centrifugal force imparted by impeller is convered to pressure in the volute casing. NOTE - Combine with either  BARE PUMP or PUMP SYSTEM,</ont:ISO15926_desc>
        <ont:ISO15926_name>CENTRIFUGAL PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/CircumferentialPistonPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/CircumferentialPistonPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Circumferential piston pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses timed circumferential pistons or rotors to form expanding and contracting cavities that transfer fluid from inlet to outlet</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/ClosedImpeller -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/ClosedImpeller">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerDesign"/>
        <rdfs:label xml:lang="en">Closed impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/DiaphragmPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/DiaphragmPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute reciprocating pump and diaphragm pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Diaphragm pump</rdfs:label>
        <skos:definition xml:lang="en">type of reciprocating positive displacement pump that uses the cyclic flexing of a diaphragm and check valves to draw liquid into a chamber and discharge it under pressure</skos:definition>
        <ont:ISO15926_ID>7550</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/DIAPHRAGM_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;DIAPHRAGM PUMP&gt; is a &lt;RECIPROCATING PUMP&gt; intended to pump a liquid with a small capacity. This is done by means of thin flexible diaphragms to seal pumped fluid from leakage to atmosphere; flow rate is achieved through reciprocatory motion of the diaphragm</ont:ISO15926_desc>
        <ont:ISO15926_name>DIAPHRAGM PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/DoubleSuctionImpeller -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/DoubleSuctionImpeller">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerDesign"/>
        <rdfs:label xml:lang="en">Double suction impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/GearPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/GearPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Gear pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses meshing gears to trap liquid between gear teeth and casing and carry it from inlet to outlet</skos:definition>
        <ont:ISO15926_ID>7691</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/GEAR_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;GEAR PUMP&gt; is a &lt;ROTARY PUMP&gt; that contains gear teeth within an casing or enclosure to transport liquid at relatively high back pressures</ont:ISO15926_desc>
        <ont:ISO15926_name>GEAR PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/HorizontalMixedFlowPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/HorizontalMixedFlowPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/MixedFlowPump"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute mixed-flow pump terminology and API 610 / ISO 13709 configuration terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Horizontal mixed flow pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic mixed-flow pump with a horizontal shaft arrangement in which the impeller imparts both radial and axial velocity components to the liquid</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/InducedVortexImpeller -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/InducedVortexImpeller">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerDesign"/>
        <rdfs:label xml:lang="en">Induced vortex impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/LobePump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/LobePump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Lobe pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses two or more timed lobed rotors to trap liquid in spaces between the lobes and casing and move it from inlet to outlet</skos:definition>
        <ont:ISO15926_ID>7825</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/LOBE_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;LOBE PUMP&gt; is a &lt;ROTARY PUMP&gt; intended to carry a liquid in cavities within a chamber, between meshed and timed rotor lobe surfaces, from the inlet to the outlet.</ont:ISO15926_desc>
        <ont:ISO15926_name>LOBE PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/MeteringPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/MeteringPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute controlled-volume metering pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Metering pump</rdfs:label>
        <skos:definition xml:lang="en">type of controlled-volume positive displacement pump designed to deliver an accurately adjustable and repeatable rate of flow</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/MixedAxialFlow -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/MixedAxialFlow">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/AxialFlowPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute mixed-flow and axial-flow pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Mixed axial flow</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic pump in which the impeller produces liquid flow with both axial and radial components, with the axial component predominating</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/MixedFlowImpeller -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/MixedFlowImpeller">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerDesign"/>
        <rdfs:label xml:lang="en">Mixed flow impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/MixedFlowPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/MixedFlowPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotordynamicPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute mixed-flow pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Mixed flow pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic pump in which the impeller causes liquid to flow with both radial and axial velocity components</skos:definition>
        <ont:ISO15926_ID>7868</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/MIXED_FLOW_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;MIXED FLOW PUMP&gt; is a &lt;CENTRIFUGAL PUMP&gt; that uses a mixed flow pump impeller.</ont:ISO15926_desc>
        <ont:ISO15926_name>MIXED FLOW PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/OpenImpeller -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/OpenImpeller">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerDesign"/>
        <rdfs:label xml:lang="en">Open impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/PeristalticPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/PeristalticPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute positive displacement pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Peristaltic pump</rdfs:label>
        <skos:definition xml:lang="en">type of positive displacement pump that moves fluid by the progressive compression and release of a flexible tube or hose by rollers or shoes</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/PistonPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/PistonPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute reciprocating pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Piston pump</rdfs:label>
        <skos:definition xml:lang="en">type of reciprocating positive displacement pump operated by using the back-and-forth motion of one or more tightly sealed pistons inside a cylindrical bore to trap, move, and pressurize fluid</skos:definition>
        <ont:ISO15926_ID>7944</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/PISTON_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;PISTON PUMP&gt; is a &lt;RECIPROCATING PUMP&gt; that contains pistons intended to reciprocate within cylinders with the valving accomplished by rotation of the pistons and cylinders relative to the ports. The cylinders may be axially or radially disposed and arranged.</ont:ISO15926_desc>
        <ont:ISO15926_name>PISTON PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/PlainVaneImpeller -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/PlainVaneImpeller">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpImpellerDesign"/>
        <rdfs:label xml:lang="en">Plain vane impeller</rdfs:label>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/PlungerPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/PlungerPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute reciprocating pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Plunger pump</rdfs:label>
        <skos:definition xml:lang="en">type of reciprocating positive displacement pump operated by using the back-and-forth motion of one or more plungers through packing to displace and pressurize liquid in a cylinder</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/PositiveDisplacementPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/PositiveDisplacementPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedMotion"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute pump type terminology for positive displacement pumps, with supporting ISO 15926-4 reference data categories for rotary and reciprocating pumps.</rdfs:comment>
        <rdfs:label xml:lang="en">Positive displacement pump</rdfs:label>
        <skos:definition xml:lang="en">type of pump that displaces a fixed volume of liquid by periodically enclosing it and forcing it from suction to discharge</skos:definition>
        <ont:ISO15926_ID>7967</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/POSITIVE_DISPLACEMENT_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;POSITIVE DISPLACEMENT PUMP&gt; is an &lt;ARTEFACT&gt; and a &lt;PUMP&gt; intended to transport liquid through the reciprocating or rotary displacement principle and with either fixed or adjustable volume flow rates. NOTE - Combine with either BARE PUMP or PUMP SYSTEM,</ont:ISO15926_desc>
        <ont:ISO15926_name>POSITIVE DISPLACEMENT PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/ProgressingCavityPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/ProgressingCavityPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Progressing cavity pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses an eccentrically rotating helical rotor inside a stator to form sealed cavities that progress from suction to discharge</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/PropellerPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/PropellerPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:label xml:lang="en">Propeller pump</rdfs:label>
        <skos:definition xml:lang="en">type of axial-flow rotodynamic pump that uses a propeller-shaped impeller to move liquid mainly parallel to the pump shaft</skos:definition>
        <ont:ISO15926_ID>19720</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/PROPELLER_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;PROPELLER PUMP&gt; is an &lt;ARTEFACT&gt; and a &lt;PUMP&gt; that is provided with a propeller type impeller to generate relativly low head at large flows</ont:ISO15926_desc>
        <ont:ISO15926_name>PROPELLER PUMP</ont:ISO15926_name>
    </owl:Class>
    


