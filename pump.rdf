    <!-- https://nlp-tlp.org/ontology/pump/rdl/SubmersiblePump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/SubmersiblePump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotordynamicPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Submersible pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic pump designed to be submerged in the fluid it pumps</skos:definition>
        <ont:ISO15926_ID>8212</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/SUBMERSIBLE_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;SUBMERSIBLE PUMP&gt; is an &lt;ARTEFACT&gt; and a &lt;PUMP&gt; that is capable of operating when submerged in the liquid it is intended to pump.</ont:ISO15926_desc>
        <ont:ISO15926_name>SUBMERSIBLE PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/VanePump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/VanePump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Vane pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses sliding or flexible vanes in a rotor to form variable-volume chambers that draw in and discharge liquid</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/VerticalAxialFlow -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/VerticalAxialFlow">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/AxialFlowPump"/>
        <rdfs:label xml:lang="en">Vertical axial flow</rdfs:label>
        <skos:definition xml:lang="en">type of axial-flow rotodynamic pump with a vertical shaft arrangement in which the impeller moves liquid mainly parallel to the pump shaft</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/VerticalMixedFlowPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/VerticalMixedFlowPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/MixedFlowPump"/>
        <rdfs:label xml:lang="en">Vertical mixed flow pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotodynamic mixed-flow pump with a vertical shaft arrangement in which the impeller imparts both radial and axial velocity components to the liquid</skos:definition>
    </owl:Class>
    


