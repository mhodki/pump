    <!-- https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/ReciprocatingPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PositiveDisplacementPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute reciprocating pump terminology, with supporting ISO 15926-4 reference data item RECIPROCATING_PUMP.</rdfs:comment>
        <rdfs:label xml:lang="en">Reciprocating pump</rdfs:label>
        <skos:definition xml:lang="en">type of positive displacement pump that moves liquid by the back-and-forth motion of a piston, plunger, or diaphragm and usually uses inlet and discharge check valves</skos:definition>
        <ont:ISO15926_ID>8023</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/RECIPROCATING_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;RECIPROCATING PUMP&gt; is a &lt;POSITIVE DISPLACEMENT PUMP&gt; which contains a displacing element intended to be moved in a reciprocating movement to exert pressure on a fluid, typically moving within a cylindrical space.</ont:ISO15926_desc>
        <ont:ISO15926_name>RECIPROCATING PUMP</ont:ISO15926_name>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PositiveDisplacementPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology, with supporting ISO 15926-4 reference data item ROTARY_PUMP.</rdfs:comment>
        <rdfs:label xml:lang="en">Rotary pd pump</rdfs:label>
        <skos:definition xml:lang="en">type of positive displacement pump that moves liquid by the rotary motion of gears, screws, lobes, vanes, or similar elements that form moving enclosed volumes</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/RotordynamicPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/RotordynamicPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpWithSpecifiedMotion"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotodynamic pump definitions and terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Rotordynamic pump</rdfs:label>
        <skos:definition xml:lang="en">type of pump in which a rotating impeller or rotor continuously imparts kinetic energy to liquid and converts that energy into pressure or head</skos:definition>
    </owl:Class>
    


    <!-- https://nlp-tlp.org/ontology/pump/rdl/ScrewPump -->

    <owl:Class rdf:about="https://nlp-tlp.org/ontology/pump/rdl/ScrewPump">
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/PumpType"/>
        <rdfs:subClassOf rdf:resource="https://nlp-tlp.org/ontology/pump/rdl/RotaryPDPump"/>
        <rdfs:comment xml:lang="en">Source: adapted from Hydraulic Institute rotary pump terminology.</rdfs:comment>
        <rdfs:label xml:lang="en">Screw pump</rdfs:label>
        <skos:definition xml:lang="en">type of rotary positive displacement pump that uses one or more screws to move liquid axially through enclosed cavities from suction to discharge</skos:definition>
        <ont:ISO15926_ID>8059</ont:ISO15926_ID>
        <ont:ISO15926_URI>https://standards.iso.org/iso/15926/-4/reference-data-item/SCREW_PUMP</ont:ISO15926_URI>
        <ont:ISO15926_desc>A &lt;SCREW PUMP&gt; is a &lt;ROTARY PUMP&gt; that contains one or more meshing screws within a casing to form liquid cavities that are transported axially from suction to discharge.</ont:ISO15926_desc>
        <ont:ISO15926_name>SCREW PUMP</ont:ISO15926_name>
    </owl:Class>
    


